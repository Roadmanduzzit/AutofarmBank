local function SendNotification(title, description)
	if Notifications then
		Notifications:Notify({
			Title = title,
			Description = description,
			Selection = "Done",
			Animated = true,
			Callback = function() end
		})
	else
		warn("[NOTIFY]: " .. title .. " - " .. description)
