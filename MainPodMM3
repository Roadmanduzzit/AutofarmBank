local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local espSettings = {
	Enabled = false,
	Boxes = true,
	Tracers = true,
	Chams = false,
	Names = true,
	Distance = false,
	TeamCheck = false,
	MaxDistance = 2000
}

local hasDrawing = Drawing and type(Drawing.new) == "function"
local espEntries = {}
local espConnection = nil

local function getRoleColor(targetPlayer)
	local char = targetPlayer.Character
	local backpack = targetPlayer:FindFirstChild("Backpack")
	local hasKnife = (char and char:FindFirstChild("Knife")) or (backpack and backpack:FindFirstChild("Knife"))
	local hasGun = (char and char:FindFirstChild("Gun")) or (backpack and backpack:FindFirstChild("Gun"))

	if hasKnife then
		return Color3.fromRGB(255, 70, 70)
	end
	if hasGun then
		return Color3.fromRGB(80, 160, 255)
	end
	return Color3.fromRGB(110, 255, 130)
end

local function hideEntry(entry)
	if not entry then
		return
	end
	if entry.box then entry.box.Visible = false end
	if entry.tracer then entry.tracer.Visible = false end
	if entry.name then entry.name.Visible = false end
	if entry.distance then entry.distance.Visible = false end
end

local function clearEntry(entry)
	if not entry then
		return
	end
	if entry.box then pcall(function() entry.box:Remove() end) end
	if entry.tracer then pcall(function() entry.tracer:Remove() end) end
	if entry.name then pcall(function() entry.name:Remove() end) end
	if entry.distance then pcall(function() entry.distance:Remove() end) end
end

local function clearHighlight(character)
	if not character then
		return
	end
	local highlight = character:FindFirstChild("FocusESPHighlight")
	if highlight then
		highlight:Destroy()
	end
end

local function clearAllEsp()
	for targetPlayer, entry in pairs(espEntries) do
		clearEntry(entry)
		if targetPlayer and targetPlayer.Character then
			clearHighlight(targetPlayer.Character)
		end
		espEntries[targetPlayer] = nil
	end
end

local function ensureEntry(targetPlayer)
	if not hasDrawing then
		return nil
	end

	if espEntries[targetPlayer] then
		return espEntries[targetPlayer]
	end

	local entry = {
		box = Drawing.new("Square"),
		tracer = Drawing.new("Line"),
		name = Drawing.new("Text"),
		distance = Drawing.new("Text")
	}

	entry.box.Thickness = 2
	entry.box.Filled = false
	entry.box.Visible = false

	entry.tracer.Thickness = 1.5
	entry.tracer.Visible = false

	entry.name.Size = 13
	entry.name.Center = true
	entry.name.Outline = true
	entry.name.Visible = false

	entry.distance.Size = 13
	entry.distance.Center = true
	entry.distance.Outline = true
	entry.distance.Visible = false

	espEntries[targetPlayer] = entry
	return entry
end

local function setHighlight(targetPlayer, color, enabled)
	local character = targetPlayer.Character
	if not character then
		return
	end

	local highlight = character:FindFirstChild("FocusESPHighlight")
	if enabled then
		if not highlight then
			highlight = Instance.new("Highlight")
			highlight.Name = "FocusESPHighlight"
			highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
			highlight.FillTransparency = 0.65
			highlight.OutlineTransparency = 0
			highlight.Parent = character
		end
		highlight.Adornee = character
		highlight.FillColor = color
		highlight.OutlineColor = Color3.new(0, 0, 0)
	else
		if highlight then
			highlight:Destroy()
		end
	end
end

local function updateFocusEsp()
	local camera = workspace.CurrentCamera
	if not camera then
		return
	end

	local screenBottomCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
	local activeTargets = {}

	for _, targetPlayer in ipairs(Players:GetPlayers()) do
		if targetPlayer ~= LocalPlayer then
			local character = targetPlayer.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			local root = character and character:FindFirstChild("HumanoidRootPart")
			local alive = humanoid and humanoid.Health > 0 and root
			local sameTeam = LocalPlayer.Team ~= nil and targetPlayer.Team == LocalPlayer.Team
			local valid = alive and (not espSettings.TeamCheck or not sameTeam)

			if valid then
				local distance = (root.Position - camera.CFrame.Position).Magnitude
				if distance <= espSettings.MaxDistance then
					activeTargets[targetPlayer] = true

					local color = getRoleColor(targetPlayer)
					setHighlight(targetPlayer, color, espSettings.Chams)

					local screenPos, onScreen = camera:WorldToViewportPoint(root.Position)
					local entry = ensureEntry(targetPlayer)

					if entry and onScreen then
						local head = character:FindFirstChild("Head")
						local headPos = head and head.Position or (root.Position + Vector3.new(0, 2, 0))
						local footPos = root.Position - Vector3.new(0, 3, 0)

						local topPoint = camera:WorldToViewportPoint(headPos)
						local bottomPoint = camera:WorldToViewportPoint(footPos)

						local height = math.max(18, math.abs(bottomPoint.Y - topPoint.Y))
						local width = math.max(12, height * 0.55)
						local x = screenPos.X - (width / 2)
						local y = screenPos.Y - (height / 2)

						if espSettings.Boxes then
							entry.box.Visible = true
							entry.box.Size = Vector2.new(width, height)
							entry.box.Position = Vector2.new(x, y)
							entry.box.Color = color
						else
							entry.box.Visible = false
						end

						if espSettings.Tracers then
							entry.tracer.Visible = true
							entry.tracer.From = screenBottomCenter
							entry.tracer.To = Vector2.new(screenPos.X, screenPos.Y + (height * 0.5))
							entry.tracer.Color = color
						else
							entry.tracer.Visible = false
						end

						if espSettings.Names then
							entry.name.Visible = true
							entry.name.Text = targetPlayer.Name
							entry.name.Position = Vector2.new(screenPos.X, y - 14)
							entry.name.Color = color
						else
							entry.name.Visible = false
						end

						if espSettings.Distance then
							entry.distance.Visible = true
							entry.distance.Text = tostring(math.floor(distance)) .. "m"
							entry.distance.Position = Vector2.new(screenPos.X, y + height + 2)
							entry.distance.Color = color
						else
							entry.distance.Visible = false
						end
					else
						hideEntry(entry)
					end
				else
					if espEntries[targetPlayer] then
						hideEntry(espEntries[targetPlayer])
					end
					clearHighlight(character)
				end
			else
				if espEntries[targetPlayer] then
					hideEntry(espEntries[targetPlayer])
				end
				if character then
					clearHighlight(character)
				end
			end
		end
	end

	for targetPlayer, entry in pairs(espEntries) do
		if not activeTargets[targetPlayer] then
			hideEntry(entry)
			if targetPlayer and targetPlayer.Character then
				clearHighlight(targetPlayer.Character)
			end
		end
	end
end

local function setEspEnabled(state)
	espSettings.Enabled = state
	if state then
		if not espConnection then
			if not hasDrawing then
				warn("Drawing API not found. Chams will still work.")
			end
			espConnection = RunService.RenderStepped:Connect(updateFocusEsp)
		end
	else
		if espConnection then
			espConnection:Disconnect()
			espConnection = nil
		end
		clearAllEsp()
	end
end

