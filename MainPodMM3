local function SafeTween(instance, info, props)
    if not instance then
        return
    end

    local ok, tween = pcall(function()
        return TweenService:Create(instance, info, props)
    end)

    if ok and tween then
        tween:Play()
    end
end

local function Clamp(value, minValue, maxValue)
    return math.max(minValue, math.min(maxValue, value))
end

local function Round(value, step)
    step = step or 1
    if step == 0 then
        return value
    end
    return math.floor((value / step) + 0.5) * step
end

local function ParseKey(value)
    if typeof(value) == "EnumItem" then
        return value
    end

    if type(value) == "string" then
        local cleaned = value:gsub("%s+", "")
        if cleaned == "" or cleaned == "-" or cleaned:upper() == "NONE" then
            return Enum.KeyCode.Unknown
        end
        return Enum.KeyCode[cleaned] or Enum.KeyCode.Unknown
    end

    return Enum.KeyCode.Unknown
end

local function SerializeValue(value)
    local valueType = typeof(value)

    if valueType == "EnumItem" then
        return {
            __type = "EnumItem",
            enum = "KeyCode",
            value = value.Name
        }
    end

    if valueType == "Color3" then
        return {
            __type = "Color3",
            r = math.floor(value.R * 255),
            g = math.floor(value.G * 255),
            b = math.floor(value.B * 255)
        }
    end

    return value
end

local function DeserializeValue(value)
    if type(value) ~= "table" then
        return value
    end

    if value.__type == "EnumItem" and value.enum == "KeyCode" then
        return Enum.KeyCode[value.value] or Enum.KeyCode.Unknown
    end

    if value.__type == "Color3" then
        return Color3.fromRGB(value.r or 255, value.g or 255, value.b or 255)
    end

    return value
end

local function SanitizeFileName(name)
    name = tostring(name or "default")
    name = name:gsub("[\\/:*?\"<>|]", "_")
    name = name:gsub("^%s+", ""):gsub("%s+$", "")
    if name == "" then
        name = "default"
    end
    return name
end

local function CleanTitle(name)
    local cleaned = tostring(name or "Focus V3.3")
    cleaned = cleaned:gsub("[^\32-\126]", "")
    cleaned = cleaned:gsub("%s+", " ")
    cleaned = cleaned:gsub("^%s+", ""):gsub("%s+$", "")
    if cleaned == "" then
        cleaned = "Focus V3.3"
    end
    return cleaned
end

local function JoinLines(content)
    if type(content) == "table" then
        local parts = {}
        for _, item in ipairs(content) do
            parts[#parts + 1] = tostring(item)
        end
        return table.concat(parts, "\n")
    end

    return tostring(content or "")
end

