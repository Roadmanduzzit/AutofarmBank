            function api:Set(value)
                SelectOption(tostring(value or ""), true)
            end

            function api:Get()
                return selected
            end

            function api:Refresh(refreshConfig)
                refreshConfig = refreshConfig or {}
                options = {}
                for _, option in ipairs(refreshConfig.NewList or {}) do
                    options[#options + 1] = tostring(option)
                end
                BuildOptions()
                if #options == 0 then
                    SelectOption(nil, false)
                else
                    local keepCurrent = selected and table.find(options, selected)
                    if keepCurrent then
                        SelectOption(selected, false)
                    else
                        SelectOption(options[1], false)
                    end
                end
            end

            return api
        end

