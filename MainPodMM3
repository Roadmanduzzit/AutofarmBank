            kind = "success"
        elseif selection == "warn" or selection == "warning" then
            kind = "warning"
        elseif selection == "error" then
            kind = "error"
        end

        Notify(config.Title or "Focus", config.Description or "", kind, config.Cooldown or 4)
    end

    local root = {
        gui = gui,
        restoreGui = restoreGui,
        main = main,
        shadow = mainShadow,
        setVisible = SetVisible,
        window = windowApi,
        notifications = notificationsApi,
        windowState = windowState,
