function Hawk:SaveConfig()
    if not ActiveWindow then
        return false
    end

    if not writefile then
        if ActiveWindow.notify then
            ActiveWindow.notify("Config", "writefile is not available in this executor.", "error", 4)
        end
        return false
    end

    EnsureConfigFolder()

    local payload = {}
    for key, widget in pairs(ActiveWindow.windowState.widgetRegistry) do
        local ok, value = pcall(widget.get)
        if ok then
            payload[key] = SerializeValue(value)
        end
    end

    local path = ConfigFolder .. "/" .. CurrentConfigName .. ".json"
    local success = pcall(function()
        writefile(path, HttpService:JSONEncode(payload))
    end)

    if success and ActiveWindow.notify then
        ActiveWindow.notify("Config", "Saved " .. CurrentConfigName, "success", 3)
    end

    return success
end

function Hawk:LoadConfig(name)
    if not ActiveWindow then
        return false
    end

    CurrentConfigName = SanitizeFileName(name or CurrentConfigName)

    if not readfile then
        if ActiveWindow.notify then
            ActiveWindow.notify("Config", "readfile is not available in this executor.", "error", 4)
        end
        return false
    end

    local path = ConfigFolder .. "/" .. CurrentConfigName .. ".json"
    if isfile and not isfile(path) then
        if ActiveWindow.notify then
            ActiveWindow.notify("Config", "Config not found: " .. CurrentConfigName, "warning", 4)
        end
        return false
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)

    if not ok or type(decoded) ~= "table" then
        if ActiveWindow.notify then
            ActiveWindow.notify("Config", "Could not decode " .. CurrentConfigName, "error", 4)
        end
        return false
    end

    for key, savedValue in pairs(decoded) do
        local widget = ActiveWindow.windowState.widgetRegistry[key]
        if widget and widget.set then
            pcall(widget.set, DeserializeValue(savedValue))
        end
    end

    if ActiveWindow.notify then
        ActiveWindow.notify("Config", "Loaded " .. CurrentConfigName, "success", 3)
    end

    return true
end

