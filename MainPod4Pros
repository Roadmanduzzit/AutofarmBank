local function normalizeOreName(name)
    local cleaned = string.match(tostring(name or ""), "^%s*(.-)%s*$")
    if not cleaned or cleaned == "" then
        return nil, nil
    end
    return cleaned, string.lower(cleaned)
end

local function rememberOreDisplay(name)
    local display, key = normalizeOreName(name)
    if not key then
        return nil, nil
    end
    if not STATE.oreDisplayByKey[key] then
        STATE.oreDisplayByKey[key] = display
    end
    return STATE.oreDisplayByKey[key], key
end

for _, defaultOreName in ipairs(ORE_OPTIONS) do
    rememberOreDisplay(defaultOreName)
end

local function getSelectedOreListForSet(oreSet)
    local selected = {}
    for oreKey, enabled in pairs(oreSet or {}) do
        if enabled then
            table.insert(selected, STATE.oreDisplayByKey[oreKey] or oreKey)
        end
    end
    table.sort(selected, function(a, b)
        return string.lower(a) < string.lower(b)
    end)
    return selected
end

local function formatSelectedOreSummaryForSet(oreSet)
    local selected = getSelectedOreListForSet(oreSet)
    if #selected == 0 then
        return "None"
    end
    if #selected <= 3 then
        return table.concat(selected, ", ")
    end
    return string.format("%s, %s, %s +%d", selected[1], selected[2], selected[3], #selected - 3)
end

