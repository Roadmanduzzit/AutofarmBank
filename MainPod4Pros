    local function isPointInsideGuiObject(guiObject, point)
        if not guiObject or not guiObject.Visible then
            return false
        end
        local position = guiObject.AbsolutePosition
        local size = guiObject.AbsoluteSize
        local x = point.X
        local y = point.Y
        return x >= position.X
            and x <= position.X + size.X
            and y >= position.Y
            and y <= position.Y + size.Y
    end

    local function getOreSetForMode(mode)
        if mode == "unlock" then
            return STATE.autoUnlockOreSet
        end
        return STATE.autoLockOreSet
    end

    local function rebuildOreOptionButtonsForMode(mode, optionButtons, targetScroll)
        local availableOptions = getAvailableOreOptions()
        local keep = {}

        for index, oreName in ipairs(availableOptions) do
            local _, oreKey = rememberOreDisplay(oreName)
            if oreKey then
                keep[oreKey] = true

                local oreOptionButton = optionButtons[oreKey]
                if not oreOptionButton then
                    oreOptionButton = Instance.new("TextButton")
                    oreOptionButton.Name = string.format("OreOption_%s_%s", mode, string.gsub(oreKey, "[^%w_]", "_"))
