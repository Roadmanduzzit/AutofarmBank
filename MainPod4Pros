        local hasUnlockTargets = hasSelectedAutoUnlockOres()
        if (STATE.autoLockEnabled and hasLockTargets) or (STATE.autoUnlockEnabled and hasUnlockTargets) then
            if STATE.autoLockEnabled then
                local ok, err = pcall(runAutoLockPass, toggleLockRemote)
                if not ok then
                    warn("AutoLock pass failed:", err)
                    task.wait(1)
                else
                    task.wait(AUTO_LOCK_TICK)
                end
            elseif STATE.autoUnlockEnabled then
                local ok, err = pcall(runAutoUnlockPass, toggleLockRemote)
                if not ok then
                    warn("AutoUnlock pass failed:", err)
                    task.wait(1)
                else
                    task.wait(AUTO_LOCK_TICK)
                end
            else
                task.wait(0.2)
            end
        else
            task.wait(0.2)
        end
    end
end)
