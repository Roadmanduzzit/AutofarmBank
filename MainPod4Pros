end

local function stopMerchantWayRecording()
    if not STATE.merchantWayRecording then
        if #STATE.merchantWaypoints >= 2 then
            return true, string.format("Merchant way already saved (%d points)", #STATE.merchantWaypoints)
        end
        return false, "Merchant way recording is not active"
    end

    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    local currentPos = hrp and hrp.Position or nil
    if typeof(currentPos) == "Vector3" then
        addMerchantWayPoint(currentPos, true)
    end

    STATE.merchantWayRecording = false
    STATE.lastMerchantWaySample = nil

    if #STATE.merchantWaypoints < 2 then
        return false, "Path too short, record at least 2 points"
    end

    return true, string.format("Merchant way saved (%d points)", #STATE.merchantWaypoints)
end

local function deleteMerchantWay()
