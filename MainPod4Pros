    local function speedToRatio(speed)
        return (speed - MIN_FLY_SPEED) / (MAX_FLY_SPEED - MIN_FLY_SPEED)
    end

    local function setSpeedFromRatio(ratio)
        local clamped = ratio
        if clamped < 0 then
            clamped = 0
        elseif clamped > 1 then
            clamped = 1
        end
        local speed = MIN_FLY_SPEED + (MAX_FLY_SPEED - MIN_FLY_SPEED) * clamped
        STATE.flySpeed = math.floor(speed + 0.5)
    end

    local function updateSliderVisuals()
        local ratio = speedToRatio(STATE.flySpeed)
        flySpeedFill.Size = UDim2.new(ratio, 0, 1, 0)
        flySpeedKnob.Position = UDim2.new(ratio, 0, 0.5, 0)
    end

    local function setSpeedFromPointerX(pointerX)
        local left = flySpeedTrack.AbsolutePosition.X
        local width = flySpeedTrack.AbsoluteSize.X
        if width <= 0 then
            return
        end

        local ratio = (pointerX - left) / width
        setSpeedFromRatio(ratio)
        refreshUiIfReady()
    end

    local function merchantSpeedToRatio(speed)
        return (speed - MIN_MERCHANT_SLIDE_SPEED) / (MAX_MERCHANT_SLIDE_SPEED - MIN_MERCHANT_SLIDE_SPEED)
    end

    local function setMerchantSpeedFromRatio(ratio)
        local clamped = ratio
        if clamped < 0 then
            clamped = 0
        elseif clamped > 1 then
            clamped = 1
        end
        local speed = MIN_MERCHANT_SLIDE_SPEED + (MAX_MERCHANT_SLIDE_SPEED - MIN_MERCHANT_SLIDE_SPEED) * clamped
        STATE.merchantSlideSpeed = math.floor(speed + 0.5)
    end

    local function updateMerchantSliderVisuals()
        local ratio = merchantSpeedToRatio(getMerchantSlideSpeed())
        merchantSpeedFill.Size = UDim2.new(ratio, 0, 1, 0)
        merchantSpeedKnob.Position = UDim2.new(ratio, 0, 0.5, 0)
    end

    local function setMerchantSpeedFromPointerX(pointerX)
        local left = merchantSpeedTrack.AbsolutePosition.X
        local width = merchantSpeedTrack.AbsoluteSize.X
        if width <= 0 then
            return
        end

        local ratio = (pointerX - left) / width
        setMerchantSpeedFromRatio(ratio)
        refreshUiIfReady()
    end

