local function stopThisInstance()
    if STATE.closed then
        return
    end

    STATE.running = false
    STATE.autoSell = false
    STATE.pausedForMerchant = false
    STATE.flyEnabled = false
    STATE.flyTargetPosition = nil
    STATE.showLockOreDropdown = false
    STATE.showUnlockOreDropdown = false
    STATE.merchantWayRecording = false
    STATE.lastMerchantWaySample = nil
    STATE.closed = true
    STATE.refreshUi = nil

    for index = #STATE.merchantWayDots, 1, -1 do
        local dot = STATE.merchantWayDots[index]
        if typeof(dot) == "Instance" and dot.Parent then
            dot:Destroy()
        end
        STATE.merchantWayDots[index] = nil
    end
    STATE.merchantWaypoints = {}
    local wayFolder = workspace:FindFirstChild(MERCHANT_WAY_FOLDER_NAME)
    if wayFolder then
        wayFolder:Destroy()
    end

    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        local existing = playerGui:FindFirstChild("FocusGoldFarmGui")
        if existing then
            existing:Destroy()
        end
    end

    local bracketScreen = STATE.bracketScreen
    if typeof(bracketScreen) == "Instance" and bracketScreen.Parent then
        bracketScreen:Destroy()
    end
    STATE.bracketScreen = nil

    if sharedEnv and typeof(sharedEnv.FocusGoldFarmBracketScreen) == "Instance" then
        local sharedScreen = sharedEnv.FocusGoldFarmBracketScreen
        if sharedScreen.Parent then
            sharedScreen:Destroy()
        end
        sharedEnv.FocusGoldFarmBracketScreen = nil
    end

    if sharedEnv and sharedEnv.FocusGoldFarmStopInstance == stopThisInstance then
        sharedEnv.FocusGoldFarmStopInstance = nil
    end
end

