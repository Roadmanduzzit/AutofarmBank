local function toolNameMatchesOreSet(toolName, oreSet)
    local normalizedName = string.lower(tostring(toolName or ""))
    for oreKey in pairs(oreSet or {}) do
        if normalizedName:find(oreKey, 1, true) then
            return true
        end
    end
    return false
end

local function forEachInventoryTool(callback)
    local seen = {}

    local function scanContainer(container)
        if not container then
            return
        end

        for _, item in ipairs(container:GetDescendants()) do
            if (item:IsA("Tool") or item:IsA("HopperBin")) and not seen[item] then
                seen[item] = true
                callback(item)
            end
        end
    end

    scanContainer(player:FindFirstChild("Backpack"))
    scanContainer(player:FindFirstChild("BackpackTwo"))
    scanContainer(player.Character)
end

local function isLikelyOreItem(tool)
    if not tool then
        return false
    end

    local lowerName = string.lower(tool.Name or "")
    if lowerName == "" then
        return false
    end

    if tool:FindFirstChild("Scripts") then
        return false
    end

    if lowerName:find("pan", 1, true)
        or lowerName:find("shovel", 1, true)
        or lowerName:find("kit", 1, true)
        or lowerName:find("collection", 1, true)
        or lowerName:find("ornament", 1, true)
        or lowerName:find("crate", 1, true)
        or lowerName:find("map", 1, true)
    then
        return false
    end

    return true
end

local function getAvailableOreOptions()
    local options = {}
    local seen = {}

    local function addOption(name)
        local display, key = rememberOreDisplay(name)
        if display and not seen[key] then
            seen[key] = true
            table.insert(options, display)
        end
    end

    for _, defaultOreName in ipairs(ORE_OPTIONS) do
        addOption(defaultOreName)
    end

    for _, oreDisplay in pairs(STATE.oreDisplayByKey) do
        addOption(oreDisplay)
    end

    forEachInventoryTool(function(tool)
        if isLikelyOreItem(tool) then
            addOption(tool.Name)
        end
    end)

    table.sort(options, function(a, b)
        return string.lower(a) < string.lower(b)
    end)

    return options
end

local function addCustomOreName(name, preferredMode)
    local display, key = rememberOreDisplay(name)
    if not key then
        return false, "Type an ore name first"
    end

    if preferredMode == "unlock" then
        STATE.autoUnlockOreSet[key] = true
    else
        STATE.autoLockOreSet[key] = true
    end
    return true, display
end

local function buildAutoLockConfigData()
    local lockOres = getSelectedAutoLockOreList()
    local unlockOres = getSelectedAutoUnlockOreList()
    return {
        enabled = STATE.autoLockEnabled,
        unlock_enabled = STATE.autoUnlockEnabled,
        ores = lockOres,
        lock_ores = lockOres,
        unlock_ores = unlockOres
    }
end

local function applyAutoLockConfigData(configData)
    if type(configData) ~= "table" then
        return false, "Invalid config data"
    end

    local lockSet = {}
    local unlockSet = {}
    local rawLockOres = configData.lock_ores
    if type(rawLockOres) ~= "table" then
        rawLockOres = configData.ores
    end
    if type(rawLockOres) == "table" then
        for _, oreName in ipairs(rawLockOres) do
            local _, oreKey = rememberOreDisplay(oreName)
            if oreKey then
                lockSet[oreKey] = true
            end
        end
    end
    if type(configData.unlock_ores) == "table" then
        for _, oreName in ipairs(configData.unlock_ores) do
            local _, oreKey = rememberOreDisplay(oreName)
            if oreKey then
                unlockSet[oreKey] = true
            end
        end
    end

    local lockEnabled = configData.enabled == true
    local unlockEnabled = configData.unlock_enabled == true
    if lockEnabled and unlockEnabled then
        unlockEnabled = false
    end

    STATE.autoLockOreSet = lockSet
    STATE.autoUnlockOreSet = unlockSet
    STATE.autoLockEnabled = lockEnabled
    STATE.autoUnlockEnabled = unlockEnabled
    STATE.autoLockRetryByTool = {}
    STATE.autoUnlockRetryByTool = {}
    return true
end

local function saveAutoLockConfig()
    if type(writefile) ~= "function" then
        return false, "File API not available"
    end

    local encoded = HttpService:JSONEncode(buildAutoLockConfigData())
    local ok, err = pcall(function()
        writefile(AUTO_LOCK_CONFIG_FILE, encoded)
    end)

    if not ok then
        return false, tostring(err)
    end

    return true, AUTO_LOCK_CONFIG_FILE
end

local function loadAutoLockConfig()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then
        return false, "File API not available"
    end

    if not isfile(AUTO_LOCK_CONFIG_FILE) then
        return false, "No saved config"
    end

    local okRead, raw = pcall(function()
        return readfile(AUTO_LOCK_CONFIG_FILE)
    end)
    if not okRead then
        return false, tostring(raw)
    end

    local okDecode, decoded = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if not okDecode then
        return false, "Config decode failed"
    end

    local applied, applyErr = applyAutoLockConfigData(decoded)
    if not applied then
        return false, applyErr or "Config apply failed"
    end

    return true, AUTO_LOCK_CONFIG_FILE
end

local function sanitizeConfigName(name)
    local cleaned = string.match(tostring(name or ""), "^%s*(.-)%s*$") or ""
    cleaned = string.gsub(cleaned, "[\\/:*?\"<>|]", "_")
    cleaned = string.gsub(cleaned, "%s+", "_")
    if cleaned == "" then
        cleaned = "default"
    end
    return cleaned
end

local function ensureFullConfigFolder()
    if type(isfolder) ~= "function" or type(makefolder) ~= "function" then
        return false, "File API not available"
    end

    local ok, err = pcall(function()
        if not isfolder(FULL_CONFIG_FOLDER) then
            makefolder(FULL_CONFIG_FOLDER)
        end
    end)
    if not ok then
        return false, tostring(err)
    end

    if type(isfile) == "function" and type(writefile) == "function" then
        pcall(function()
            if not isfile(FULL_CONFIG_DEFAULT_FILE) then
                writefile(FULL_CONFIG_DEFAULT_FILE, "")
            end
        end)
    end

    return true
end

local function getFullConfigPath(name)
    return FULL_CONFIG_FOLDER .. "\\" .. sanitizeConfigName(name) .. ".json"
end

local function vector3ToConfigTable(vector)
    if typeof(vector) ~= "Vector3" then
        return nil
    end
    return {
        x = vector.X,
        y = vector.Y,
        z = vector.Z
    }
end

local function configTableToVector3(raw)
    if type(raw) ~= "table" then
        return nil
    end
    local x = tonumber(raw.x or raw[1])
    local y = tonumber(raw.y or raw[2])
    local z = tonumber(raw.z or raw[3])
    if not x or not y or not z then
        return nil
    end
    return Vector3.new(x, y, z)
end

local function getKnownOreDisplayList()
    local names = {}
    local seen = {}
    for _, display in pairs(STATE.oreDisplayByKey) do
        local text = tostring(display or "")
        if text ~= "" then
            local lower = string.lower(text)
            if not seen[lower] then
                seen[lower] = true
                names[#names + 1] = text
            end
        end
    end
    table.sort(names, function(a, b)
        return string.lower(a) < string.lower(b)
    end)
    return names
end

local function clearMerchantWayDotsForConfig()
    for index = #STATE.merchantWayDots, 1, -1 do
        local dot = STATE.merchantWayDots[index]
        if typeof(dot) == "Instance" and dot.Parent then
            dot:Destroy()
        end
        STATE.merchantWayDots[index] = nil
    end

    local folder = workspace:FindFirstChild(MERCHANT_WAY_FOLDER_NAME)
    if folder then
        folder:Destroy()
    end
end

local function ensureMerchantWayDotsFolderForConfig()
    local folder = workspace:FindFirstChild(MERCHANT_WAY_FOLDER_NAME)
    if folder then
        return folder
    end

    folder = Instance.new("Folder")
    folder.Name = MERCHANT_WAY_FOLDER_NAME
    folder.Parent = workspace
    return folder
end

local function applyMerchantWaypointsFromConfig(rawWaypoints)
    clearMerchantWayDotsForConfig()
    STATE.merchantWaypoints = {}
    STATE.lastMerchantWaySample = nil
    STATE.merchantWayRecording = false

    if type(rawWaypoints) ~= "table" then
        return
    end

    local folder = nil
    for _, waypointRaw in ipairs(rawWaypoints) do
        if #STATE.merchantWaypoints >= MERCHANT_WAY_MAX_POINTS then
            break
        end

        local point = configTableToVector3(waypointRaw)
        if point then
            STATE.merchantWaypoints[#STATE.merchantWaypoints + 1] = point

            if not folder then
                folder = ensureMerchantWayDotsFolderForConfig()
            end

            local dot = Instance.new("Part")
            dot.Name = "MerchantWayDot"
            dot.Shape = Enum.PartType.Ball
            dot.Size = Vector3.new(MERCHANT_WAY_DOT_SIZE, MERCHANT_WAY_DOT_SIZE, MERCHANT_WAY_DOT_SIZE)
            dot.Material = Enum.Material.Neon
            dot.Color = Color3.new(1, 1, 1)
            dot.Transparency = MERCHANT_WAY_DOT_TRANSPARENCY
            dot.Anchored = true
            dot.CanCollide = false
            dot.CanTouch = false
            dot.CanQuery = false
            dot.CastShadow = false
            dot.CFrame = CFrame.new(point)
            dot.Parent = folder
            STATE.merchantWayDots[#STATE.merchantWayDots + 1] = dot
        end
    end

    if #STATE.merchantWaypoints == 0 then
        clearMerchantWayDotsForConfig()
    end
end

local function buildFullConfigData()
    local lockData = buildAutoLockConfigData()
    local merchantWaypoints = {}
    local merchantInterval = tonumber(STATE.merchantIntervalMinutes) or DEFAULT_MERCHANT_INTERVAL_MINUTES
    if merchantInterval < MIN_MERCHANT_INTERVAL_MINUTES then
        merchantInterval = MIN_MERCHANT_INTERVAL_MINUTES
    elseif merchantInterval > MAX_MERCHANT_INTERVAL_MINUTES then
        merchantInterval = MAX_MERCHANT_INTERVAL_MINUTES
    end

    local merchantSpeed = tonumber(STATE.merchantSlideSpeed) or MERCHANT_SLIDE_SPEED
    if merchantSpeed < MIN_MERCHANT_SLIDE_SPEED then
        merchantSpeed = MIN_MERCHANT_SLIDE_SPEED
    elseif merchantSpeed > MAX_MERCHANT_SLIDE_SPEED then
        merchantSpeed = MAX_MERCHANT_SLIDE_SPEED
    end

    for _, waypoint in ipairs(STATE.merchantWaypoints) do
        local encoded = vector3ToConfigTable(waypoint)
        if encoded then
            merchantWaypoints[#merchantWaypoints + 1] = encoded
        end
    end

    return {
        version = 1,
        auto_farm = STATE.running,
        auto_sell = STATE.autoSell,
        fly_enabled = STATE.flyEnabled,
        fly_speed = STATE.flySpeed,
        sand_position = vector3ToConfigTable(STATE.sandPosition),
        water_position = vector3ToConfigTable(STATE.waterPosition),
        custom_shake_time = STATE.customShakeTime,
        merchant_interval_minutes = merchantInterval,
        merchant_slide_speed = merchantSpeed,
        ore_names = getKnownOreDisplayList(),
        auto_lock = lockData,
        merchant_waypoints = merchantWaypoints
    }
end

local function applyFullConfigData(configData)
    if type(configData) ~= "table" then
        return false, "Invalid config data"
    end

    if type(configData.ore_names) == "table" then
        for _, oreName in ipairs(configData.ore_names) do
            rememberOreDisplay(oreName)
        end
    end

    local lockData = configData.auto_lock
    if type(lockData) ~= "table" then
        lockData = {
            enabled = configData.auto_lock_enabled == true or configData.enabled == true,
            unlock_enabled = configData.auto_unlock_enabled == true or configData.unlock_enabled == true,
            lock_ores = configData.lock_ores or configData.ores,
            unlock_ores = configData.unlock_ores
        }
    end
    local lockApplied, lockErr = applyAutoLockConfigData(lockData)
    if not lockApplied then
        return false, lockErr or "Failed to apply lock settings"
    end

    if type(configData.auto_sell) == "boolean" then
        STATE.autoSell = configData.auto_sell
    end

    if type(configData.auto_farm) == "boolean" then
        STATE.running = configData.auto_farm
    elseif type(configData.running) == "boolean" then
        STATE.running = configData.running
    end

    if type(configData.fly_enabled) == "boolean" then
        STATE.flyEnabled = configData.fly_enabled
        if not STATE.flyEnabled then
            STATE.flyTargetPosition = nil
        end
    end

    local flySpeed = tonumber(configData.fly_speed)
    if flySpeed then
        if flySpeed < MIN_FLY_SPEED then
            flySpeed = MIN_FLY_SPEED
        elseif flySpeed > MAX_FLY_SPEED then
            flySpeed = MAX_FLY_SPEED
        end
        STATE.flySpeed = math.floor(flySpeed + 0.5)
    end

    local sandPosition = configTableToVector3(configData.sand_position)
    if sandPosition then
        STATE.sandPosition = sandPosition
    end

    local waterPosition = configTableToVector3(configData.water_position)
    if waterPosition then
        STATE.waterPosition = waterPosition
    end

    local shakeTime = tonumber(configData.custom_shake_time)
    if shakeTime then
        if shakeTime < MIN_CUSTOM_SHAKE_TIME then
            shakeTime = MIN_CUSTOM_SHAKE_TIME
        elseif shakeTime > MAX_CUSTOM_SHAKE_TIME then
            shakeTime = MAX_CUSTOM_SHAKE_TIME
        end
        STATE.customShakeTime = shakeTime
    elseif configData.custom_shake_time == nil then
        STATE.customShakeTime = nil
    end

    local merchantInterval = tonumber(configData.merchant_interval_minutes)
    if merchantInterval then
        if merchantInterval < MIN_MERCHANT_INTERVAL_MINUTES then
            merchantInterval = MIN_MERCHANT_INTERVAL_MINUTES
        elseif merchantInterval > MAX_MERCHANT_INTERVAL_MINUTES then
            merchantInterval = MAX_MERCHANT_INTERVAL_MINUTES
        end
        STATE.merchantIntervalMinutes = merchantInterval
    end

    local merchantSpeed = tonumber(configData.merchant_slide_speed)
    if merchantSpeed then
        if merchantSpeed < MIN_MERCHANT_SLIDE_SPEED then
            merchantSpeed = MIN_MERCHANT_SLIDE_SPEED
        elseif merchantSpeed > MAX_MERCHANT_SLIDE_SPEED then
            merchantSpeed = MAX_MERCHANT_SLIDE_SPEED
        end
        STATE.merchantSlideSpeed = math.floor(merchantSpeed + 0.5)
    end

    applyMerchantWaypointsFromConfig(configData.merchant_waypoints)

    STATE.pausedForMerchant = false
    STATE.nextMerchantSellAt = 0
    STATE.lastMerchantSellAt = 0

    return true
end

local function listFullConfigNames()
    if type(listfiles) ~= "function" then
        return false, "File API not available"
    end

    local ready, readyErr = ensureFullConfigFolder()
    if not ready then
        return false, readyErr
    end

    local ok, filesOrErr = pcall(function()
        return listfiles(FULL_CONFIG_FOLDER)
    end)
    if not ok then
        return false, tostring(filesOrErr)
    end

    local names = {}
    for _, filePath in ipairs(filesOrErr or {}) do
        local normalized = string.gsub(tostring(filePath), "/", "\\")
        local fileName = string.match(normalized, "([^\\]+)$")
        local configName = fileName and string.match(fileName, "^(.-)%.json$")
        if configName and configName ~= "" then
            names[#names + 1] = configName
        end
    end

    table.sort(names, function(a, b)
        return string.lower(a) < string.lower(b)
    end)
    return true, names
end

