local function extractSandStats(panTool)
    local amount
    local capacity

    for _, obj in ipairs(panTool:GetDescendants()) do
        if obj:IsA("IntValue") or obj:IsA("NumberValue") then
            local name = string.lower(obj.Name)

            if not amount and (name:find("sand") or name:find("fill")) and not name:find("cap") and not name:find("max") then
                amount = obj.Value
            end

            if not capacity and (name:find("cap") or name:find("max")) and (name:find("sand") or name:find("pan") or name:find("fill")) then
                capacity = obj.Value
            end
        end
    end

    local attrs = panTool:GetAttributes()
    for name, value in pairs(attrs) do
        if type(value) == "number" then
            local lower = string.lower(name)

            if not amount and (lower:find("sand") or lower:find("fill")) and not lower:find("cap") and not lower:find("max") then
                amount = value
            end

            if not capacity and (lower:find("cap") or lower:find("max")) and (lower:find("sand") or lower:find("pan") or lower:find("fill")) then
                capacity = value
            end
        end
    end

    return amount, capacity
end

local function resultLooksLikeFull(...)
    local count = select("#", ...)
    if count == 0 then
        return false
    end

    for index = 1, count do
        local value = select(index, ...)
        if typeof(value) == "string" then
            local text = string.lower(value)
            if text:find("full") or text:find("max") or text:find("cannot") then
                return true
            end
        end
    end

    return false
end

local function collectUntilFull(collectRemote, panTool)
    local started = os.clock()
    local calls = 0
    local lastAmount = select(1, extractSandStats(panTool))
    local staleCount = 0

    while true do
        calls = calls + 1

        local ok, r1, r2, r3 = pcall(function()
            return collectRemote:InvokeServer(table.unpack(COLLECT_ARGS))
        end)

        local currentAmount, currentCapacity = extractSandStats(panTool)
        local elapsed = os.clock() - started
        local passedMinimum = elapsed >= COLLECT_MIN_TIME and calls >= MIN_COLLECT_CALLS

        if currentAmount ~= nil then
            if currentCapacity and currentAmount >= currentCapacity and passedMinimum then
                break
            end

            if lastAmount ~= nil then
                if currentAmount > lastAmount then
                    staleCount = 0
                else
                    staleCount = staleCount + 1
                end
            end
            lastAmount = currentAmount

            if staleCount >= COLLECT_STALE_LIMIT and passedMinimum then
                break
            end
        else
            if ok and resultLooksLikeFull(r1, r2, r3) and passedMinimum then
                break
            end
        end

        if elapsed >= COLLECT_MAX_TIME then
            break
        end

        task.wait(COLLECT_TICK)
    end
end

local function shakeUntilEmpty(shakeRemote, panTool)
    local shakeDuration = getShakeDuration()
    local initialAmount = select(1, extractSandStats(panTool))
    if initialAmount == nil then
        local startedNoStats = os.clock()
        while os.clock() - startedNoStats < shakeDuration do
            shakeRemote:FireServer()
            task.wait(0.12)
        end
        return
    end

    local started = os.clock()

    while os.clock() - started < shakeDuration do
        shakeRemote:FireServer()
        task.wait(0.12)

        local amount = select(1, extractSandStats(panTool))
        if amount and amount <= 0 then
            return
        end
    end

    task.wait(1)
end

local function getFlyDirection()
    local camera = workspace.CurrentCamera
    if not camera then
        return Vector3.new(0, 0, 0)
    end

    local look = camera.CFrame.LookVector
    local right = camera.CFrame.RightVector

    local forwardFlat = Vector3.new(look.X, 0, look.Z)
    if forwardFlat.Magnitude > 0.001 then
        forwardFlat = forwardFlat.Unit
    else
        forwardFlat = Vector3.new(0, 0, -1)
    end

    local rightFlat = Vector3.new(right.X, 0, right.Z)
    if rightFlat.Magnitude > 0.001 then
        rightFlat = rightFlat.Unit
    else
        rightFlat = Vector3.new(1, 0, 0)
    end

    local direction = Vector3.new(0, 0, 0)

    if UserInputService:IsKeyDown(Enum.KeyCode.W) or UserInputService:IsKeyDown(Enum.KeyCode.Up) then
        direction = direction + forwardFlat
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) or UserInputService:IsKeyDown(Enum.KeyCode.Down) then
        direction = direction - forwardFlat
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) or UserInputService:IsKeyDown(Enum.KeyCode.Right) then
        direction = direction + rightFlat
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) or UserInputService:IsKeyDown(Enum.KeyCode.Left) then
        direction = direction - rightFlat
    end

    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        direction = direction + Vector3.new(0, 1, 0)
    end

    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
        or UserInputService:IsKeyDown(Enum.KeyCode.RightControl)
        or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
        or UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
    then
        direction = direction - Vector3.new(0, 1, 0)
    end

    if direction.Magnitude > 0 then
        return direction.Unit
    end

    return Vector3.new(0, 0, 0)
end

local function runOneCycle()
    local character = getCharacter()
    local panTool = getPanTool(character)
    if not panTool then
        task.wait(0.5)
        return
    end

    local collectRemote, panRemote, shakeRemote = getPanRemotes(panTool)
    if not collectRemote or not panRemote or not shakeRemote then
        STATE.activePanName = "Invalid pan remotes"
        refreshUiIfReady()
        task.wait(0.5)
        return
    end

    local sellAllRemote = getSellAllRemote()

    teleportTo(STATE.sandPosition)
    task.wait(0.25)
    collectUntilFull(collectRemote, panTool)

    teleportTo(STATE.waterPosition)
    task.wait(0.25)

    pcall(function()
        panRemote:InvokeServer()
    end)

    task.wait(0.2)
    shakeUntilEmpty(shakeRemote, panTool)

    if STATE.autoSell and shouldRunMerchantSellNow() then
        local returnPosition = getCurrentPosition()
        local wasRunning = STATE.running

        STATE.pausedForMerchant = true
        STATE.running = false
        refreshUiIfReady()

        local okSellCall, sold, sellMsg = pcall(runMerchantSell, sellAllRemote, returnPosition)
        if not okSellCall then
            warn("Merchant sell failed:", sold)
        elseif not sold then
            warn("Merchant sell failed:", sellMsg)
        end

        local merchantFinishedAt = getNowTime()
        STATE.lastMerchantSellAt = merchantFinishedAt
        scheduleNextMerchantSell(merchantFinishedAt)
        STATE.pausedForMerchant = false
        if wasRunning and not STATE.closed then
            STATE.running = true
        end
        refreshUiIfReady()
    end

    refreshUiIfReady()
    task.wait(LOOP_DELAY)
end

