local function createBracketGui()
    if type(loadstring) ~= "function" then
        error("loadstring API not available")
    end

    local okFetch, source = pcall(function()
        return game:HttpGet(BRACKET_UI_URL)
    end)
    if not okFetch or type(source) ~= "string" or source == "" then
        error("Failed to fetch Bracket UI source")
    end

    local chunk, compileErr = loadstring(source)
    if type(chunk) ~= "function" then
        error("Bracket UI compile failed: " .. tostring(compileErr))
    end

    local okBracket, Bracket = pcall(chunk)
    if not okBracket or type(Bracket) ~= "table" or type(Bracket.Window) ~= "function" then
        error("Bracket UI runtime failed")
    end

    local Window = Bracket:Window({
        Name = "Focus",
        Enabled = true,
        Color = Color3.fromRGB(255, 128, 64),
        Size = UDim2.new(0, 600, 0, 560),
        Position = UDim2.new(0.5, -300, 0.5, -280)
    })

    STATE.bracketScreen = Bracket.ScreenAsset
    if sharedEnv then
        sharedEnv.FocusGoldFarmBracketScreen = Bracket.ScreenAsset
    end

    local farmTab = Window:Tab({ Name = "Farm" })
    local merchantTab = Window:Tab({ Name = "Merchant" })
    local oresTab = Window:Tab({ Name = "Ores" })
    local movementTab = Window:Tab({ Name = "Movement" })
    local configTab = Window:Tab({ Name = "Config" })
    local infoTab = Window:Tab({ Name = "Info" })

    local suppressUiCallbacks = false
    local lastMessage = "Ready"

    local autoFarmToggle
    local autoSellToggle
    local autoLockToggle
    local autoUnlockToggle
    local flyToggle
    local flySpeedSlider
    local merchantSpeedSlider
    local shakeTextbox
    local merchantIntervalTextbox
    local lockOreDropdown
    local unlockOreDropdown

    local statusLabel
