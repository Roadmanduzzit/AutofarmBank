end

local function hasRecordedMerchantWay()
    return #STATE.merchantWaypoints >= 2
end

local function travelRecordedMerchantWay(reverseDirection)
    if not hasRecordedMerchantWay() then
        return false, "No merchant way recorded"
    end

    local waypoints = STATE.merchantWaypoints
    local startIndex, endIndex, step
    if reverseDirection then
        startIndex = #waypoints
        endIndex = 1
        step = -1
    else
        startIndex = 1
        endIndex = #waypoints
        step = 1
    end

    local index = startIndex
    while true do
        local waypoint = waypoints[index]
        if typeof(waypoint) == "Vector3" then
            local character = getCharacter()
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if not hrp then
                return false, "Character not ready"
            end

            local slideSpeed = getMerchantSlideSpeed()
            local timeout = computeSlideTimeout(hrp.Position, waypoint, slideSpeed)
            local reached, moveMsg = slideToPosition(waypoint, slideSpeed, timeout, MERCHANT_WAY_SEGMENT_REACH)
            if not reached then
                return false, "Merchant way failed (" .. tostring(moveMsg) .. ")"
            end
        end

        if index == endIndex then
            break
        end
        index = index + step
    end

    return true, "Merchant way complete"
end

local function runMerchantSell(sellAllRemote, returnPosition)
    local character = getCharacter()
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not hrp then
        return false, "Character not ready"
    end

    local restoreFly = STATE.flyEnabled
    if restoreFly then
        STATE.flyEnabled = false
        STATE.flyTargetPosition = nil
    end

    local function finish(success, message)
        if restoreFly and not STATE.closed then
            STATE.flyEnabled = true
            if hrp and hrp.Parent then
                STATE.flyTargetPosition = hrp.Position
            end
        end
        return success, message
    end

    local usedRecordedWay = false
    local slideSpeed = getMerchantSlideSpeed()
    if hasRecordedMerchantWay() then
        local routed, routeMsg = travelRecordedMerchantWay(false)
        if routed then
            usedRecordedWay = true
        else
            warn("Merchant way route failed, falling back:", routeMsg)
        end
    end

    local candidates = findMerchantCandidates(hrp.Position)
    if #candidates == 0 then
        return finish(false, "No Merchant found")
    end

    local chosenCandidate, chosenPosition = chooseBestMerchantCandidate(candidates, hrp.Position)
    if not chosenCandidate or not chosenPosition then
        return finish(false, "No reachable merchant")
    end

    if not usedRecordedWay then
        local walked, walkMsg = slideToPositionWithLift(chosenPosition, slideSpeed, MERCHANT_SLIDE_REACH_DISTANCE, MERCHANT_SLIDE_LIFT_HEIGHT)
        if not walked then
            return finish(false, walkMsg or "Failed to reach merchant")
        end
    end

    local chosenMerchant = chosenCandidate.object
    local latestPos = getInteractionPositionFromContainer(chosenMerchant) or getObjectPosition(chosenMerchant) or chosenPosition
    if (hrp.Position - latestPos).Magnitude > MERCHANT_REACH_DISTANCE then
        local adjusted, adjustMsg = slideToPositionWithLift(latestPos, slideSpeed, MERCHANT_SLIDE_REACH_DISTANCE, MERCHANT_SLIDE_LIFT_HEIGHT)
        if not adjusted then
            return finish(false, adjustMsg)
        end
    end

    if (hrp.Position - latestPos).Magnitude > MERCHANT_REACH_DISTANCE then
        return finish(false, "Not close enough to merchant")
    end

    if humanoid and humanoid.Sit then
        humanoid.Sit = false
    end
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

    pressEOnce()
    task.wait(MERCHANT_SELL_DELAY_SECONDS)

    local sold = pcall(function()
        sellAllRemote:InvokeServer()
    end)

    if not sold then
        return finish(false, "SellAll invoke failed")
    end

    if typeof(returnPosition) == "Vector3" then
        local returnedByWay = false
        if usedRecordedWay then
            local routedBack, routeBackMsg = travelRecordedMerchantWay(true)
            if routedBack then
                returnedByWay = true
            else
                warn("Merchant way return failed, using direct return:", routeBackMsg)
            end
        end

        if not returnedByWay and (hrp.Position - returnPosition).Magnitude > MERCHANT_REACH_DISTANCE then
            local returned, returnMsg = slideToPositionWithLift(returnPosition, slideSpeed, MERCHANT_SLIDE_REACH_DISTANCE, MERCHANT_SLIDE_LIFT_HEIGHT)
            if not returned then
                return finish(false, "Return slide failed (" .. tostring(returnMsg) .. ")")
            end
        end
    end

    return finish(true, typeof(returnPosition) == "Vector3" and "Sold and returned" or "Sold")
end

