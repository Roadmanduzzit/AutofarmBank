local function addMerchantWayPoint(position, makeDot)
    if typeof(position) ~= "Vector3" then
        return false
    end

    local waypoints = STATE.merchantWaypoints
    local lastWaypoint = waypoints[#waypoints]
    if lastWaypoint and (position - lastWaypoint).Magnitude < MERCHANT_WAY_SAMPLE_DISTANCE then
        return false
    end

    if #waypoints >= MERCHANT_WAY_MAX_POINTS then
        return false
    end

    table.insert(waypoints, position)
    STATE.lastMerchantWaySample = position

    if makeDot then
        local dot = Instance.new("Part")
        dot.Name = "MerchantWayDot"
        dot.Shape = Enum.PartType.Ball
        dot.Size = Vector3.new(MERCHANT_WAY_DOT_SIZE, MERCHANT_WAY_DOT_SIZE, MERCHANT_WAY_DOT_SIZE)
        dot.Material = Enum.Material.Neon
        dot.Color = Color3.new(1, 1, 1)
        dot.Transparency = MERCHANT_WAY_DOT_TRANSPARENCY
        dot.Anchored = true
        dot.CanCollide = false
        dot.CanTouch = false
        dot.CanQuery = false
        dot.CastShadow = false
        dot.CFrame = CFrame.new(position)
        dot.Parent = ensureMerchantWayDotsFolder()
        table.insert(STATE.merchantWayDots, dot)
    end

    return true
end

local function startMerchantWayRecording()
    STATE.merchantWayRecording = false
    STATE.lastMerchantWaySample = nil
    STATE.merchantWaypoints = {}
    clearMerchantWayDots()

    local character = player.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    local startPos = hrp and hrp.Position or nil
    if typeof(startPos) ~= "Vector3" then
        return false, "Spawn first to record merchant way"
    end

