    local sandLabel
    local waterLabel
    local shakeLabel
    local merchantLabel
    local flyLabel
    local panLabel
    local lockSummaryLabel
    local unlockSummaryLabel
    local wayLabel
    local configNameTextbox
    local configDropdown
    local defaultConfigLabel
    local selectedConfigName = nil
    local pendingConfigName = ""
    local cachedDefaultConfigName = nil

    local function setLabelText(labelObj, text)
        if labelObj and type(labelObj.SetText) == "function" then
            pcall(function()
                labelObj:SetText(text)
            end)
        end
    end

    local function withSuppressedCallbacks(callback)
        suppressUiCallbacks = true
        local ok, err = pcall(callback)
        suppressUiCallbacks = false
        if not ok then
            warn("Bracket UI sync failed:", err)
        end
    end

    local function closeBracketDropdownOverlays()
        local screen = STATE.bracketScreen
        if typeof(screen) ~= "Instance" or not screen.Parent then
            return
        end

        for _, child in ipairs(screen:GetChildren()) do
            if child.Name == "OptionContainer" and (child:IsA("Frame") or child:IsA("ScrollingFrame")) then
                child.Visible = false
            end
        end
    end

    local function isInsideBracketDropdownGui(guiObject)
        local screen = STATE.bracketScreen
        if typeof(screen) ~= "Instance" then
            return false
        end

        local cursor = guiObject
        while typeof(cursor) == "Instance" do
            if cursor == screen then
                break
            end
            if cursor.Name == "Dropdown" or cursor.Name == "OptionContainer" then
                return true
            end
            cursor = cursor.Parent
        end

        return false
    end

    local function getTargetOreSetForMode(mode)
        if mode == "unlock" then
            return STATE.autoUnlockOreSet
        end
        return STATE.autoLockOreSet
    end

    local function buildOreDropdownList(mode)
        local list = {}
        local targetSet = getTargetOreSetForMode(mode)

        for _, oreName in ipairs(getAvailableOreOptions()) do
            local display, oreKey = rememberOreDisplay(oreName)
            if oreKey then
                list[#list + 1] = {
                    Name = display,
                    Mode = "Toggle",
                    Value = targetSet[oreKey] == true,
                    Callback = function(_, option)
                        if suppressUiCallbacks then
                            return
                        end

                        if option and option.Value then
                            targetSet[oreKey] = true
                        else
                            targetSet[oreKey] = nil
                        end
                        closeBracketDropdownOverlays()
                        refreshUiIfReady()
                    end
                }
            end
        end

        return list
    end

    local function rebuildOreDropdowns()
        if lockOreDropdown and type(lockOreDropdown.Clear) == "function" and type(lockOreDropdown.BulkAdd) == "function" then
            lockOreDropdown:Clear()
            lockOreDropdown:BulkAdd(buildOreDropdownList("lock"))
        end

        if unlockOreDropdown and type(unlockOreDropdown.Clear) == "function" and type(unlockOreDropdown.BulkAdd) == "function" then
            unlockOreDropdown:Clear()
            unlockOreDropdown:BulkAdd(buildOreDropdownList("unlock"))
        end
    end

    local function pushMessage(message)
        lastMessage = tostring(message or "Ready")
        refreshUiIfReady()
    end

    local function resolveConfigName()
        local candidate = string.match(tostring(pendingConfigName or ""), "^%s*(.-)%s*$")
        if not candidate or candidate == "" then
            candidate = selectedConfigName
        end
        if not candidate or candidate == "" then
            local okDefault, defaultName = getDefaultFullConfigName()
            if okDefault and defaultName and defaultName ~= "" then
                cachedDefaultConfigName = defaultName
                candidate = defaultName
            end
        end
        return sanitizeConfigName(candidate or "default")
    end

    local function buildConfigDropdownList()
        local okList, namesOrErr = listFullConfigNames()
        if not okList then
            return nil, tostring(namesOrErr)
        end

        local names = namesOrErr or {}
        local list = {}
        for _, configName in ipairs(names) do
            local thisName = tostring(configName)
            list[#list + 1] = {
                Name = thisName,
                Mode = "Button",
                Value = selectedConfigName == thisName,
                Callback = function(_, option)
                    if suppressUiCallbacks then
                        return
                    end
                    selectedConfigName = (type(option) == "table" and option.Name) or thisName
                    pendingConfigName = selectedConfigName or ""
                    closeBracketDropdownOverlays()
                    refreshUiIfReady()
                end
            }
        end
        return list, nil
    end

    local function rebuildConfigDropdown()
        if not configDropdown then
            return false, "Config dropdown not ready"
        end

        local list, listErr = buildConfigDropdownList()
        if not list then
            return false, listErr
        end

        withSuppressedCallbacks(function()
            configDropdown:Clear()
            configDropdown:BulkAdd(list)
        end)

        local hasSelected = false
        for _, option in ipairs(list) do
            if option.Name == selectedConfigName then
                hasSelected = true
                break
            end
        end

        if not hasSelected then
            if #list > 0 then
                selectedConfigName = list[1].Name
            else
                selectedConfigName = nil
            end
        end

        withSuppressedCallbacks(function()
            if selectedConfigName and selectedConfigName ~= "" then
                configDropdown:SetValue({ selectedConfigName })
            else
                configDropdown:SetValue({})
            end
        end)

        return true
    end

