local NOW_TIME_SOURCE = "os.clock"
local NOW_TIME_READER = os.clock
do
    local okServer, serverNow = pcall(function()
        return workspace:GetServerTimeNow()
    end)
    if okServer and type(serverNow) == "number" then
        NOW_TIME_SOURCE = "workspace:GetServerTimeNow"
        NOW_TIME_READER = function()
            return workspace:GetServerTimeNow()
        end
    elseif type(time) == "function" then
        local okTime, timeNow = pcall(function()
            return time()
        end)
        if okTime and type(timeNow) == "number" then
            NOW_TIME_SOURCE = "time"
            NOW_TIME_READER = function()
                return time()
            end
        end
    end
end

local LAST_VALID_TIME = nil
local LAST_VALID_TIME_MONO = os.clock()
do
    local okInitial, initialNow = pcall(function()
        return NOW_TIME_READER()
    end)
    if okInitial and type(initialNow) == "number" then
        LAST_VALID_TIME = initialNow
        LAST_VALID_TIME_MONO = os.clock()
    else
        LAST_VALID_TIME = LAST_VALID_TIME_MONO
    end
end

local function getNowTime()
    local monoNow = os.clock()
    local ok, current = pcall(function()
        return NOW_TIME_READER()
    end)
    if ok and type(current) == "number" then
        LAST_VALID_TIME = current
        LAST_VALID_TIME_MONO = monoNow
        return current
    end

    if type(LAST_VALID_TIME) == "number" then
        local drift = monoNow - LAST_VALID_TIME_MONO
        if drift < 0 then
            drift = 0
        end
        return LAST_VALID_TIME + drift
    end

    return monoNow
end

local function scheduleNextMerchantSell(anchorTime)
    local baseTime = anchorTime
    if type(baseTime) ~= "number" then
        baseTime = getNowTime()
    end
    STATE.nextMerchantSellAt = baseTime + getMerchantIntervalSeconds()
end

local function getMerchantSafetyCooldownSeconds()
    local cooldown = getMerchantIntervalSeconds() * 0.9
    if cooldown < 2 then
        cooldown = 2
    end
    return cooldown
end

local function shouldRunMerchantSellNow()
    local now = getNowTime()

    if type(STATE.nextMerchantSellAt) ~= "number" or STATE.nextMerchantSellAt <= 0 then
        scheduleNextMerchantSell(now)
        return false
    end

    if type(STATE.lastMerchantSellAt) == "number" and STATE.lastMerchantSellAt > 0 then
        local minAllowedAt = STATE.lastMerchantSellAt + getMerchantSafetyCooldownSeconds()
        if now < minAllowedAt then
            if STATE.nextMerchantSellAt < minAllowedAt then
                STATE.nextMerchantSellAt = minAllowedAt
            end
            return false
        end
    end

    return now >= STATE.nextMerchantSellAt
end

local function getInteractionPositionFromContainer(container)
    if not container then
        return nil
    end

    local prompt = container:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt and prompt.Parent and prompt.Parent:IsA("BasePart") then
        return prompt.Parent.Position
    end

    local part = container:FindFirstChildWhichIsA("BasePart", true)
    if part then
        return part.Position
    end

    return nil
end

local function getObjectPosition(obj)
    if not obj then
        return nil
    end

    if obj:IsA("BasePart") then
        return obj.Position
    end

    if obj:IsA("Attachment") then
        return obj.WorldPosition
    end

    if obj:IsA("Model") then
        if obj.PrimaryPart then
            return obj.PrimaryPart.Position
        end
        return getInteractionPositionFromContainer(obj)
    end

    if obj:IsA("ProximityPrompt") and obj.Parent and obj.Parent:IsA("BasePart") then
        return obj.Parent.Position
    end

    if obj:IsA("Folder") or obj:IsA("Configuration") then
        return getInteractionPositionFromContainer(obj)
    end

    return nil
end

local function getMerchantRoot(obj)
    local current = obj

    while current and current ~= workspace do
        if string.find(string.lower(current.Name), "merchant", 1, true) then
            return current
        end
        current = current.Parent
    end

    return nil
end

local function addMerchantCandidate(candidateMap, key, candidateObject, pos, hasPrompt, fromPosition)
    if not key or not candidateObject or not pos then
        return
    end

    local distance = (fromPosition - pos).Magnitude
    local existing = candidateMap[key]
    if existing then
        if distance < existing.distance then
            existing.position = pos
            existing.distance = distance
            existing.object = candidateObject
        end
        existing.hasPrompt = existing.hasPrompt or hasPrompt == true
        return
    end

    candidateMap[key] = {
        object = candidateObject,
        position = pos,
        distance = distance,
        hasPrompt = hasPrompt == true
    }
end

local function resolveMerchantCandidateFromPrompt(prompt)
    if not prompt or not prompt.Parent or not prompt.Parent:IsA("BasePart") then
        return nil, nil, nil
    end

    local root = getMerchantRoot(prompt)
    if not root then
        return nil, nil, nil
    end

    local candidateKey = root
    local candidateObject = root

    if root:IsA("Folder") or root:IsA("Configuration") then
        local ownerModel = prompt:FindFirstAncestorOfClass("Model")
        if ownerModel and ownerModel ~= root then
            candidateKey = ownerModel
            candidateObject = ownerModel
        else
            candidateKey = prompt.Parent
            candidateObject = prompt.Parent
        end
    end

    return candidateKey, candidateObject, prompt.Parent.Position
end

local function findMerchantCandidates(fromPosition)
    local candidateMap = {}

    for _, prompt in ipairs(workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            local candidateKey, candidateObject, promptPos = resolveMerchantCandidateFromPrompt(prompt)
            if candidateKey and candidateObject and promptPos then
                addMerchantCandidate(candidateMap, candidateKey, candidateObject, promptPos, true, fromPosition)
            end
        end
    end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if string.find(string.lower(obj.Name), "merchant", 1, true) then
            local root = getMerchantRoot(obj) or obj
            local pos = getObjectPosition(root) or getObjectPosition(obj)
            if pos then
                local hasPrompt = root:FindFirstChildWhichIsA("ProximityPrompt", true) ~= nil
                addMerchantCandidate(candidateMap, root, root, pos, hasPrompt, fromPosition)
            end
        end
    end

    local candidates = {}
    for _, candidate in pairs(candidateMap) do
        table.insert(candidates, candidate)
    end

    table.sort(candidates, function(a, b)
        if a.distance ~= b.distance then
            return a.distance < b.distance
        end
        if a.hasPrompt ~= b.hasPrompt then
            return a.hasPrompt
        end
        return false
    end)

    return candidates
end

local function createMerchantPath()
    return PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
        AgentCanClimb = true,
        WaypointSpacing = 3
    })
end

local function getPathLengthFromWaypoints(startPosition, waypoints, fallbackGoal)
    local totalLength = 0
    local previous = startPosition

    for _, waypoint in ipairs(waypoints) do
        totalLength = totalLength + (waypoint.Position - previous).Magnitude
        previous = waypoint.Position
    end

    if totalLength <= 0 and fallbackGoal then
        totalLength = (fallbackGoal - startPosition).Magnitude
    end

    return totalLength
end

local function estimateMerchantPathCost(fromPosition, targetPosition)
    local path = createMerchantPath()

    local okCompute = pcall(function()
        path:ComputeAsync(fromPosition, targetPosition)
    end)

    if not okCompute or path.Status ~= Enum.PathStatus.Success then
        return (fromPosition - targetPosition).Magnitude + 100000, false
    end

    local waypoints = path:GetWaypoints()
    local totalLength = getPathLengthFromWaypoints(fromPosition, waypoints, targetPosition)

    return totalLength, true
end

local function chooseBestMerchantCandidate(candidates, fromPosition)
    local bestCandidate = nil
    local bestPosition = nil
    local bestScore = math.huge

    local maxCandidates = math.min(#candidates, MERCHANT_MAX_CANDIDATES)
    for index = 1, maxCandidates do
        local candidate = candidates[index]
        local targetPos = getInteractionPositionFromContainer(candidate.object) or getObjectPosition(candidate.object) or candidate.position
        if targetPos then
            local score = (fromPosition - targetPos).Magnitude
            if candidate.hasPrompt then
                score = score - 1.5
            end

            if score < bestScore then
                bestScore = score
                bestCandidate = candidate
                bestPosition = targetPos
            end
        end
    end

    return bestCandidate, bestPosition
end

local function slideToPosition(targetPosition, speed, timeoutSeconds, reachDistance)
    local character = getCharacter()
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not hrp then
        return false, "Character not ready"
    end

    local moveSpeed = speed or MERCHANT_SLIDE_SPEED
    if moveSpeed <= 0 then
        moveSpeed = MERCHANT_SLIDE_SPEED
    end

    local timeoutAt = os.clock() + (timeoutSeconds or MERCHANT_SLIDE_TIMEOUT)
    local reach = reachDistance or MERCHANT_SLIDE_REACH_DISTANCE

    while os.clock() < timeoutAt do
        local currentPos = hrp.Position
        local toTarget = targetPosition - currentPos
        local distance = toTarget.Magnitude

        if distance <= reach then
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            return true, "Reached merchant"
        end

        if humanoid and humanoid.Sit then
            humanoid.Sit = false
        end

        local dt = RunService.Heartbeat:Wait()
        local step = moveSpeed * dt
        if step > distance then
            step = distance
        end

        local nextPos = currentPos
        if distance > 0.0001 then
            nextPos = currentPos + (toTarget.Unit * step)
        end

        hrp.CFrame = CFrame.new(nextPos)
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end

    if (hrp.Position - targetPosition).Magnitude <= reach then
        return true, "Reached merchant"
    end

    return false, "Slide timeout"
end

local function computeSlideTimeout(fromPosition, toPosition, speed)
    local travelSpeed = speed or MERCHANT_SLIDE_SPEED
    if travelSpeed <= 0 then
        travelSpeed = MERCHANT_SLIDE_SPEED
    end

    local distance = (toPosition - fromPosition).Magnitude
    local timeout = (distance / travelSpeed) + 2.5
    if timeout < MERCHANT_SLIDE_TIMEOUT then
        timeout = MERCHANT_SLIDE_TIMEOUT
    end
    return timeout
end

local function slideToPositionWithLift(targetPosition, speed, reachDistance, liftHeight)
    local character = getCharacter()
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then
        return false, "Character not ready"
    end

    local travelSpeed = speed or MERCHANT_SLIDE_SPEED
    if travelSpeed <= 0 then
        travelSpeed = MERCHANT_SLIDE_SPEED
    end

    local reach = reachDistance or MERCHANT_SLIDE_REACH_DISTANCE
    local lift = liftHeight or MERCHANT_SLIDE_LIFT_HEIGHT
    if lift < 0 then
        lift = 0
    end

    local function runSegment(segmentTarget, segmentReach)
        local timeout = computeSlideTimeout(hrp.Position, segmentTarget, travelSpeed)
        return slideToPosition(segmentTarget, travelSpeed, timeout, segmentReach or reach)
    end

    local startPosition = hrp.Position
    local horizontalDistance = (Vector3.new(targetPosition.X, 0, targetPosition.Z) - Vector3.new(startPosition.X, 0, startPosition.Z)).Magnitude
    if horizontalDistance <= reach then
        local directTimeout = computeSlideTimeout(startPosition, targetPosition, travelSpeed)
        return slideToPosition(targetPosition, travelSpeed, directTimeout, reach)
    end

    local cruiseY = math.max(startPosition.Y, targetPosition.Y) + lift

    local liftPosition = Vector3.new(startPosition.X, cruiseY, startPosition.Z)
    if math.abs(cruiseY - startPosition.Y) > MERCHANT_SLIDE_VERTICAL_REACH then
        local lifted, liftMsg = runSegment(liftPosition, MERCHANT_SLIDE_VERTICAL_REACH)
        if not lifted then
            return false, "Lift failed (" .. tostring(liftMsg) .. ")"
        end
    end

    local cruisePosition = Vector3.new(targetPosition.X, cruiseY, targetPosition.Z)
    local cruised, cruiseMsg = runSegment(cruisePosition, math.max(reach, 2.2))
    if not cruised then
        return false, "Cruise failed (" .. tostring(cruiseMsg) .. ")"
    end

    local descended, descendMsg = runSegment(targetPosition, reach)
    if not descended then
        return false, "Descend failed (" .. tostring(descendMsg) .. ")"
    end

    return true, "Reached merchant"
end

local function moveToWithProgress(humanoid, hrp, destination, timeoutSeconds, reachDistance)
    local timeout = timeoutSeconds or MERCHANT_MOVE_TIMEOUT
    local arriveDistance = reachDistance or MERCHANT_REACH_DISTANCE

    humanoid:MoveTo(destination)

    local startTime = os.clock()
    local lastProgressAt = startTime
    local lastPosition = hrp.Position
    local refreshSent = false

    while (os.clock() - startTime) < timeout do
        local currentPos = hrp.Position
        if (currentPos - destination).Magnitude <= arriveDistance then
            return true, "Reached"
        end

        local moved = (currentPos - lastPosition).Magnitude
        if moved >= MERCHANT_PROGRESS_EPSILON then
            lastPosition = currentPos
            lastProgressAt = os.clock()
        else
            local stalledFor = os.clock() - lastProgressAt
            if stalledFor >= MERCHANT_STUCK_SECONDS then
                if not refreshSent then
                    refreshSent = true
                    lastProgressAt = os.clock()
                    humanoid.Jump = true
                    humanoid:MoveTo(destination)
                else
                    return false, "Movement stuck"
                end
            end
        end

        task.wait(MERCHANT_PROGRESS_CHECK_INTERVAL)
    end

    if (hrp.Position - destination).Magnitude <= arriveDistance then
        return true, "Reached"
    end

    return false, "Move timeout"
end

local function getMerchantApproachTargets(targetPosition)
    local targets = { targetPosition }

    for ring = 1, MERCHANT_APPROACH_RING_COUNT do
        local radius = ring * MERCHANT_APPROACH_RING_STEP
        local diagonal = radius * 0.7071

        table.insert(targets, targetPosition + Vector3.new(radius, 0, 0))
        table.insert(targets, targetPosition + Vector3.new(-radius, 0, 0))
        table.insert(targets, targetPosition + Vector3.new(0, 0, radius))
        table.insert(targets, targetPosition + Vector3.new(0, 0, -radius))

        table.insert(targets, targetPosition + Vector3.new(diagonal, 0, diagonal))
        table.insert(targets, targetPosition + Vector3.new(-diagonal, 0, diagonal))
        table.insert(targets, targetPosition + Vector3.new(diagonal, 0, -diagonal))
        table.insert(targets, targetPosition + Vector3.new(-diagonal, 0, -diagonal))
    end

    return targets
end

local function walkToPosition(targetPosition)
    local character = getCharacter()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")

    if not humanoid or not hrp then
        return false, "Character not ready"
    end

    local function closeEnough(goalPosition, distance)
        local goal = goalPosition or targetPosition
        local maxDistance = distance or MERCHANT_REACH_DISTANCE
        return (hrp.Position - goal).Magnitude <= maxDistance
    end

    if closeEnough(targetPosition, MERCHANT_REACH_DISTANCE) then
        return true, "Already near merchant"
    end

    local function nudgeAroundObstacle(attempt)
        local toTarget = targetPosition - hrp.Position
        local flat = Vector3.new(toTarget.X, 0, toTarget.Z)
        if flat.Magnitude < 0.001 then
            humanoid.Jump = true
            task.wait(0.1)
            return
        end

        local forward = flat.Unit
        local side = Vector3.new(-forward.Z, 0, forward.X)
        if attempt % 2 == 0 then
            side = -side
        end
        local nudgeDistance = MERCHANT_NUDGE_DISTANCE + ((attempt - 1) * 1.4)
        local nudgeTarget = hrp.Position + (side * nudgeDistance)
        humanoid.Jump = true
        moveToWithProgress(humanoid, hrp, nudgeTarget, 1.0, 2.8)
    end

    local function chooseBestPathFromCurrentPosition()
        local startPosition = hrp.Position
        local approachTargets = getMerchantApproachTargets(targetPosition)

        local bestPath = nil
        local bestTarget = nil
        local bestCost = math.huge

        for _, approachTarget in ipairs(approachTargets) do
            local path = createMerchantPath()
            local okCompute = pcall(function()
                path:ComputeAsync(startPosition, approachTarget)
            end)

            if okCompute and path.Status == Enum.PathStatus.Success then
                local cost = getPathLengthFromWaypoints(startPosition, path:GetWaypoints(), approachTarget)
                if cost < bestCost then
                    bestCost = cost
                    bestPath = path
                    bestTarget = approachTarget
                end
            end
        end

        return bestPath, bestTarget
    end

    local function followPath(path, approachTarget)
        local blockedIndex = math.huge
        local blockedConnection = path.Blocked:Connect(function(index)
            if index < blockedIndex then
                blockedIndex = index
            end
        end)

        local waypoints = path:GetWaypoints()
        local failReason = nil

        for index, waypoint in ipairs(waypoints) do
            if blockedIndex <= (index + 1) then
                failReason = "Path blocked"
                break
            end

            local verticalDelta = waypoint.Position.Y - hrp.Position.Y
            if waypoint.Action == Enum.PathWaypointAction.Jump or verticalDelta > 1.75 then
                humanoid.Jump = true
                task.wait(0.03)
            end

            local reachedStep, stepReason = moveToWithProgress(
                humanoid,
                hrp,
                waypoint.Position,
                MERCHANT_WAYPOINT_TIMEOUT,
                MERCHANT_WAYPOINT_REACH_DISTANCE
            )
            if not reachedStep then
                failReason = stepReason or "Failed waypoint move"
                break
            end

            if closeEnough(targetPosition, MERCHANT_REACH_DISTANCE) then
                blockedConnection:Disconnect()
                return true, "Reached merchant"
            end
        end

        blockedConnection:Disconnect()

        if failReason then
            return false, failReason
        end

        if not closeEnough(approachTarget, MERCHANT_WAYPOINT_REACH_DISTANCE) then
            local reachedApproach, approachReason = moveToWithProgress(
                humanoid,
                hrp,
                approachTarget,
                MERCHANT_MOVE_TIMEOUT,
                MERCHANT_WAYPOINT_REACH_DISTANCE
            )
            if not reachedApproach then
                return false, approachReason or "Failed approach target"
            end
        end

        if not closeEnough(targetPosition, MERCHANT_REACH_DISTANCE) then
            local reachedFinal, finalReason = moveToWithProgress(
                humanoid,
                hrp,
                targetPosition,
                MERCHANT_MOVE_TIMEOUT,
                MERCHANT_REACH_DISTANCE
            )
            if not reachedFinal then
                return false, finalReason or "Final approach failed"
            end
        end

        return true, "Reached merchant"
    end

    local lastReason = "No path found"

    for attempt = 1, MERCHANT_PATH_RETRIES do
        if closeEnough(targetPosition, MERCHANT_REACH_DISTANCE) then
            return true, "Reached merchant"
        end

        local bestPath, bestTarget = chooseBestPathFromCurrentPosition()
        if bestPath and bestTarget then
            local reachedPath, pathReason = followPath(bestPath, bestTarget)
            if reachedPath then
                return true, "Reached merchant"
            end
            lastReason = pathReason or "Path follow failed"
        else
            local reachedDirect, directReason = moveToWithProgress(
                humanoid,
                hrp,
                targetPosition,
                MERCHANT_MOVE_TIMEOUT,
                MERCHANT_REACH_DISTANCE
            )
            if reachedDirect then
                return true, "Reached with direct move"
            end
            lastReason = directReason or "No valid path"
        end

        if attempt < MERCHANT_PATH_RETRIES then
            nudgeAroundObstacle(attempt)
        end
    end

    if closeEnough(targetPosition, MERCHANT_REACH_DISTANCE) then
        return true, "Reached merchant"
    end

    return false, "Could not reach target (" .. tostring(lastReason) .. ")"
end

