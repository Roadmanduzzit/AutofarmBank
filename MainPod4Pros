local function hasPanRemotes(tool)
    if not tool or not tool:IsA("Tool") then
        return false
    end

    local scriptsFolder = tool:FindFirstChild("Scripts")
    if not scriptsFolder then
        return false
    end

    local collectRemote = scriptsFolder:FindFirstChild("Collect")
    local panRemote = scriptsFolder:FindFirstChild("Pan")
    local shakeRemote = scriptsFolder:FindFirstChild("Shake")

    return collectRemote ~= nil and panRemote ~= nil and shakeRemote ~= nil
end

local function findPanToolIn(container)
    if not container then
        return nil
    end

    local fallback
    for _, child in ipairs(container:GetChildren()) do
        if hasPanRemotes(child) then
            if string.find(string.lower(child.Name), "pan", 1, true) then
                return child
            end
            fallback = fallback or child
        end
    end

    return fallback
end

local function getPanTool(character)
    local timeoutAt = os.clock() + 8
    local backpack = player:WaitForChild("Backpack")

    while os.clock() < timeoutAt do
        local characterPan = findPanToolIn(character)
        if characterPan then
            STATE.activePanName = characterPan.Name
            refreshUiIfReady()
            return characterPan
        end

        local backpackPan = findPanToolIn(backpack)
        if backpackPan then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:EquipTool(backpackPan)
                task.wait(0.15)
            end

            local equippedPan = findPanToolIn(character)
            if equippedPan then
                STATE.activePanName = equippedPan.Name
                refreshUiIfReady()
                return equippedPan
            end

            STATE.activePanName = backpackPan.Name
            refreshUiIfReady()
            return backpackPan
        end

        task.wait(0.25)
        character = getCharacter()
    end

    STATE.activePanName = "No pan found"
    refreshUiIfReady()
    return nil
end

local function getPanRemotes(panTool)
    local scriptsFolder = panTool and panTool:FindFirstChild("Scripts")
    if not scriptsFolder then
        return nil, nil, nil
    end

    local collectRemote = scriptsFolder:FindFirstChild("Collect")
    local panRemote = scriptsFolder:FindFirstChild("Pan")
    local shakeRemote = scriptsFolder:FindFirstChild("Shake")
    return collectRemote, panRemote, shakeRemote
end

