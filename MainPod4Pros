        end

        local inputType = input.UserInputType
        if inputType ~= Enum.UserInputType.MouseButton1 and inputType ~= Enum.UserInputType.Touch then
            return
        end

        task.defer(function()
            if STATE.closed then
                return
            end

            local screen = STATE.bracketScreen
            if typeof(screen) ~= "Instance" or not screen.Parent then
                return
            end

            local pos = input.Position
            local hitObjects = GuiService:GetGuiObjectsAtPosition(pos.X, pos.Y)
            for _, guiObject in ipairs(hitObjects) do
                if isInsideBracketDropdownGui(guiObject) then
                    return
                end
            end

            closeBracketDropdownOverlays()
        end)
    end)

