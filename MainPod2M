local function EquipBestGun()
    local char = GetCharacter()
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not hum then
        return nil
    end

    local equipped = char:FindFirstChildWhichIsA("Tool")
    if equipped and equipped:FindFirstChild("Stats") then
        return equipped
    end

    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Stats") then
                pcall(function()
                    hum:EquipTool(tool)
                end)
                task.wait()
                local afterEquip = char:FindFirstChildWhichIsA("Tool")
                if afterEquip and afterEquip:FindFirstChild("Stats") then
                    return afterEquip
                end
            end
        end
    end

    return nil
end

local function InstaKillMagDumpTarget(targetPlayer)
    local gunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes")
    local fireRemote = gunRemotes and gunRemotes:FindFirstChild("Fire")
    local impactRemote = gunRemotes and gunRemotes:FindFirstChild("Impact")
    if not fireRemote or not impactRemote then
        return
    end

    local weapon = EquipBestGun()
    if not weapon then
        return
    end

    local targetChar = targetPlayer.Character
    local targetHum, targetRoot = GetHumanoidAndRoot(targetChar)
    local targetHead = targetChar and targetChar:FindFirstChild("Head")
    if not targetHum or targetHum.Health <= 0 or not targetHead or not targetRoot then
        return
    end

    local _, myRoot = GetHumanoidAndRoot(GetCharacter())
    if not myRoot then
        return
    end

    local attachOffset = CFrame.new(0, 0, 3)
    for _ = 1, 10 do
        if not Config.Autofarm.AirdropEnabled then
            return
        end

        _, myRoot = GetHumanoidAndRoot(GetCharacter())
        if not myRoot then
            return
        end

        targetChar = targetPlayer.Character
        targetHum, targetRoot = GetHumanoidAndRoot(targetChar)
        targetHead = targetChar and targetChar:FindFirstChild("Head")
        if not targetHum or targetHum.Health <= 0 or not targetHead or not targetRoot then
            return
        end

        local lockPos = targetRoot.CFrame * attachOffset
        myRoot.CFrame = CFrame.lookAt(lockPos.Position, targetRoot.Position)
        myRoot.AssemblyLinearVelocity = Vector3.zero
        myRoot.AssemblyAngularVelocity = Vector3.zero

        local dir = targetHead.Position - myRoot.Position
        if dir.Magnitude <= 0 then
            dir = Vector3.new(0, 1, 0)
        end

        pcall(function()
            fireRemote:FireServer()
        end)
        pcall(function()
            impactRemote:FireServer(targetHead, targetHead.Position, dir.Unit, Vector3.new(0, 1, 0), false, nil, nil)
        end)
        task.wait(0.05)
    end
end

local function QueueAirdropKill(targetPlayer)
    if AirdropKillTasks[targetPlayer] then
        return
    end

    AirdropKillTasks[targetPlayer] = true
    task.spawn(function()
        AirdropKillActiveCount += 1
        pcall(function()
            InstaKillMagDumpTarget(targetPlayer)
        end)
        AirdropKillActiveCount = math.max(0, AirdropKillActiveCount - 1)
        task.wait(0.05)
        AirdropKillTasks[targetPlayer] = nil
    end)
end

local function HandleAirdropAutofarmStep()
    local airdropObj, airdropPart, lootPrompt = GetAirdropData()
    if not airdropPart then
        DisconnectAirdropLock()
        return
    end

    SetAirdropLockPart(airdropPart)
    local airdropPosition = airdropPart.Position
    local now = tick()
    local lootSessionActive = IsLootSessionActive()

    if not lootSessionActive and now - LastAirdropPromptTick >= 0.85 then
        LastAirdropPromptTick = now
        local opened = false

        if lootPrompt and lootPrompt.Enabled then
            opened = TriggerPromptAtPosition(lootPrompt, airdropPosition)
        end

        if not opened then
            TriggerPromptsInContainerNear(airdropObj, airdropPosition, 25)
        end
    end

    if now - LastAirdropLootSweepTick >= (lootSessionActive and 0.18 or 0.30) then
        LastAirdropLootSweepTick = now
        local lootRadius = math.max(Config.Misc.LootRange, 35)
        TriggerPromptsInContainerNear(Workspace:FindFirstChild("EventDebris"), airdropPosition, lootRadius, airdropObj)
        TriggerPromptsInContainerNear(Workspace:FindFirstChild("Lootables"), airdropPosition, lootRadius)
        TriggerPromptsInContainerNear(Workspace:FindFirstChild("OBJECTS"), airdropPosition, lootRadius)
    end

    local radius = Config.Autofarm.AirdropKillRadius
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local hum, root = GetHumanoidAndRoot(player.Character)
            if hum and hum.Health > 0 and root and (root.Position - airdropPosition).Magnitude <= radius then
                QueueAirdropKill(player)
            end
        end
    end
end

local function StartAirdropAutofarm()
    AirdropAutofarmTicket += 1
    local ticket = AirdropAutofarmTicket
    task.spawn(function()
        while Config.Autofarm.AirdropEnabled and AirdropAutofarmTicket == ticket do
            HandleAirdropAutofarmStep()
            task.wait(0.05)
        end
        DisconnectAirdropLock()
    end)
end

local function SetAirdropAutofarmEnabled(state)
    Config.Autofarm.AirdropEnabled = state
    if state then
        LootClientSessionActive = false
        LastAirdropPromptTick = 0
        LastAirdropLootSweepTick = 0
        StartAirdropAutofarm()
    else
        LootClientSessionActive = false
        AirdropAutofarmTicket += 1
        DisconnectAirdropLock()
    end
end

local function HandleLootMagnet()
    local _, root = GetHumanoidAndRoot(GetCharacter())
    if not root then
        return
    end

    local range = Config.Misc.LootRange
    local function Scan(container)
        if not container then
            return
        end

        for _, item in ipairs(container:GetChildren()) do
            local part = item:IsA("BasePart") and item or (item:IsA("Model") and (item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart", true)) or nil)
            if part and (part.Position - root.Position).Magnitude <= range then
                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    TriggerPrompt(prompt)
                end
            end
        end
    end

    Scan(Workspace:FindFirstChild("Lootables"))
    Scan(Workspace:FindFirstChild("OBJECTS"))
end

