local function IsVehicleDriverSeat(seat)
    if not seat or not seat:IsA("BasePart") then
        return false
    end
    return seat.Name == "DriveSeat" or seat.Name == "BikeDriveSeat" or seat.Name == "ScooterSeat"
end

local function GetVehicleModelFromSeat(seat)
    if not seat then
        return nil
    end

    local node = seat
    while node and node ~= Workspace do
        if node:IsA("Model") and (node:FindFirstChild("DriveSeat", true) or node:FindFirstChild("BikeDriveSeat", true) or node:FindFirstChild("Wheels", true) or node:FindFirstChild("CarType", true)) then
            return node
        end
        node = node.Parent
    end

    return seat.Parent and seat.Parent:IsA("Model") and seat.Parent or nil
end

local function GetVehicleMotionRootPart(seat, vehicleModel)
    local rootPart = seat
    local body = vehicleModel and vehicleModel:FindFirstChild("Body")
    local collisionPart = body and body:FindFirstChild("CollisionPart")
    if collisionPart and collisionPart:IsA("BasePart") then
        rootPart = collisionPart
    end

    if rootPart and rootPart:IsA("BasePart") then
        return rootPart
    end

    return nil
end

local function ResetVehicleCrashState()
    if VehicleCrashConnection then
        VehicleCrashConnection:Disconnect()
        VehicleCrashConnection = nil
    end
    if VehicleCrashDeathConnection then
        VehicleCrashDeathConnection:Disconnect()
        VehicleCrashDeathConnection = nil
    end
    if VehicleCrashState.Humanoid and VehicleCrashState.OriginalBreakJointsOnDeath ~= nil then
        pcall(function()
            VehicleCrashState.Humanoid.BreakJointsOnDeath = VehicleCrashState.OriginalBreakJointsOnDeath
        end)
    end
    VehicleCrashState.Seat = nil
    VehicleCrashState.Humanoid = nil
    VehicleCrashState.OriginalBreakJointsOnDeath = nil
    VehicleCrashState.LastTick = 0
    VehicleCrashState.LastSpeed = 0
    VehicleCrashState.LastHealth = 0
end

local function GetVehicleMultiplierFromName(name)
    local key = string.lower(tostring(name or ""))
    if key == "" then
        return nil
    end

    if string.find(key, "steer", 1, true) or string.find(key, "turn", 1, true) or string.find(key, "yaw", 1, true) then
        return Config.Vehicle.SteerMult
    end
    if string.find(key, "brake", 1, true) then
        return Config.Vehicle.BrakeMult
    end
    if string.find(key, "torque", 1, true) or string.find(key, "horse", 1, true) or string.find(key, "accel", 1, true) or string.find(key, "engine", 1, true) or string.find(key, "power", 1, true) or string.find(key, "boost", 1, true) then
        return Config.Vehicle.AccelMult
    end
    if string.find(key, "speed", 1, true) or string.find(key, "topspeed", 1, true) or string.find(key, "maxvel", 1, true) or string.find(key, "velocity", 1, true) then
        return Config.Vehicle.SpeedMult
    end

    return nil
end

local function RestoreVehicleModdedState()
    for inst, original in pairs(VehicleOriginalValueObjects) do
        if inst and inst.Parent then
            pcall(function()
                inst.Value = original
            end)
        end
    end
    VehicleOriginalValueObjects = {}

    for obj, attrs in pairs(VehicleOriginalAttributes) do
        if obj and obj.Parent then
            for attrName, original in pairs(attrs) do
                pcall(function()
                    obj:SetAttribute(attrName, original)
                end)
            end
        end
    end
    VehicleOriginalAttributes = {}

    for seat, props in pairs(VehicleOriginalSeatProperties) do
        if seat and seat.Parent then
            for propName, original in pairs(props) do
                pcall(function()
                    seat[propName] = original
                end)
            end
        end
    end
    VehicleOriginalSeatProperties = {}
end

local function ApplyVehicleModsForSeat(seat, vehicleModel)
    if not seat or not vehicleModel then
        return
    end

    local descendants = vehicleModel:GetDescendants()
    for _, inst in ipairs(descendants) do
        if (inst:IsA("NumberValue") or inst:IsA("IntValue")) and not inst:FindFirstAncestorWhichIsA("Sound") then
            local mult = GetVehicleMultiplierFromName(inst.Name)
            if mult then
                local current = tonumber(inst.Value)
                if current ~= nil then
                    if VehicleOriginalValueObjects[inst] == nil then
                        VehicleOriginalValueObjects[inst] = current
                    end
                    local target = VehicleOriginalValueObjects[inst] * mult
                    if inst:IsA("IntValue") then
                        target = math.floor(target + 0.5)
                    end
                    pcall(function()
                        inst.Value = target
                    end)
                end
            end
        end

        local attrs = inst:GetAttributes()
        for attrName, attrValue in pairs(attrs) do
            if typeof(attrValue) == "number" then
                local mult = GetVehicleMultiplierFromName(attrName)
                if mult then
                    local store = VehicleOriginalAttributes[inst]
                    if not store then
                        store = {}
                        VehicleOriginalAttributes[inst] = store
                    end
                    if store[attrName] == nil then
                        store[attrName] = attrValue
                    end
                    pcall(function()
                        inst:SetAttribute(attrName, store[attrName] * mult)
                    end)
                end
            end
        end
    end

    if seat:IsA("VehicleSeat") then
        local seatProps = VehicleOriginalSeatProperties[seat]
        if not seatProps then
            seatProps = {}
            VehicleOriginalSeatProperties[seat] = seatProps
        end

        local seatMultipliers = {
            MaxSpeed = Config.Vehicle.SpeedMult,
            Torque = Config.Vehicle.AccelMult,
            TurnSpeed = Config.Vehicle.SteerMult
        }

        for propName, mult in pairs(seatMultipliers) do
            local ok, current = pcall(function()
                return seat[propName]
            end)
            if ok and typeof(current) == "number" then
                if seatProps[propName] == nil then
                    seatProps[propName] = current
                end
                pcall(function()
                    seat[propName] = seatProps[propName] * mult
                end)
            end
        end
    end
end

local function ApplyVehicleForwardBoost(seat, vehicleModel)
    if Config.Vehicle.SpeedMult <= 1 or not seat then
        return
    end

    local rootPart = GetVehicleMotionRootPart(seat, vehicleModel)
    if not rootPart then
        return
    end

    local boost = (Config.Vehicle.SpeedMult - 1) * 6
    local baseVelocity = rootPart.AssemblyLinearVelocity
    local velocity = baseVelocity
    local look = seat.CFrame.LookVector

    if MoveKeys[Enum.KeyCode.W] then
        velocity = velocity + look * boost
    end
    if MoveKeys[Enum.KeyCode.S] then
        local reverseScale = Config.Vehicle.NoCrashDamage and 0.25 or 0.75
        velocity = velocity - look * (boost * reverseScale)
    end
    if Config.Vehicle.BrakeMult > 1 and not MoveKeys[Enum.KeyCode.W] and not MoveKeys[Enum.KeyCode.S] then
        local brakeFactor
        if Config.Vehicle.NoCrashDamage then
            brakeFactor = math.max(0.96, 1 - ((Config.Vehicle.BrakeMult - 1) * 0.012))
        else
            brakeFactor = math.max(0.85, 1 - ((Config.Vehicle.BrakeMult - 1) * 0.04))
        end
        velocity = velocity * brakeFactor
    end

    local delta = velocity - baseVelocity
    local maxDelta
    if Config.Vehicle.NoCrashDamage then
        maxDelta = 4 + (Config.Vehicle.AccelMult * 1.5)
    else
        maxDelta = 9 + (Config.Vehicle.AccelMult * 2.5)
    end
    if delta.Magnitude > maxDelta then
        delta = delta.Unit * maxDelta
    end

    rootPart.AssemblyLinearVelocity = baseVelocity + delta
end

local function HandleVehicleCrashProtection(now, hum, seat, vehicleModel)
    if not Config.Vehicle.NoCrashDamage or not hum or hum.Health <= 0 then
        ResetVehicleCrashState()
        return
    end

    local rootPart = GetVehicleMotionRootPart(seat, vehicleModel)
    if not rootPart then
        return
    end

    local speed = rootPart.AssemblyLinearVelocity.Magnitude
    local health = hum.Health

    if VehicleCrashState.Seat ~= seat or VehicleCrashState.Humanoid ~= hum then
        VehicleCrashState.Seat = seat
        VehicleCrashState.Humanoid = hum
        VehicleCrashState.LastTick = now
        VehicleCrashState.LastSpeed = speed
        VehicleCrashState.LastHealth = health
        local okBreakJoints, breakJointsOnDeath = pcall(function()
            return hum.BreakJointsOnDeath
        end)
        if okBreakJoints then
            VehicleCrashState.OriginalBreakJointsOnDeath = breakJointsOnDeath
            pcall(function()
                hum.BreakJointsOnDeath = false
            end)
        end
        if VehicleCrashConnection then
            VehicleCrashConnection:Disconnect()
        end
        if VehicleCrashDeathConnection then
            VehicleCrashDeathConnection:Disconnect()
        end
        VehicleCrashConnection = hum.HealthChanged:Connect(function(newHealth)
            if not Config.Vehicle.NoCrashDamage then
                return
            end

            local activeSeat = hum.SeatPart
            if not IsVehicleDriverSeat(activeSeat) then
                return
            end

            local floorHealth = math.max(VehicleCrashState.LastHealth, math.min(hum.MaxHealth, 25))
            if newHealth < floorHealth then
                pcall(function()
                    hum.Health = floorHealth
                    if newHealth <= 0 then
                        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                    end
                end)
            else
                VehicleCrashState.LastHealth = newHealth
            end
        end)
        VehicleCrashDeathConnection = hum.StateChanged:Connect(function(_, newState)
            if not Config.Vehicle.NoCrashDamage then
                return
            end
            if newState ~= Enum.HumanoidStateType.Dead then
                return
            end
            if not IsVehicleDriverSeat(hum.SeatPart) then
                return
            end

            local recoverHealth = math.max(VehicleCrashState.LastHealth, math.min(hum.MaxHealth, 25))
            pcall(function()
                hum.Health = recoverHealth
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end)
        end)
        return
    end

    local floorHealth = math.max(VehicleCrashState.LastHealth, math.min(hum.MaxHealth, 25))
    if health < floorHealth then
        local restoredHealth = math.min(hum.MaxHealth, floorHealth)
        pcall(function()
            hum.Health = restoredHealth
        end)
        health = hum.Health
    end

    VehicleCrashState.LastTick = now
    VehicleCrashState.LastSpeed = speed
    VehicleCrashState.LastHealth = health
end

local function HandleVehicleMods(now)
    local hum = GetCharacter() and GetCharacter():FindFirstChildOfClass("Humanoid")
    local seat = hum and hum.SeatPart
    if not IsVehicleDriverSeat(seat) then
        if VehicleModsActive then
            RestoreVehicleModdedState()
            VehicleModsActive = false
        end
        ResetVehicleCrashState()
        return
    end

    local vehicleModel = GetVehicleModelFromSeat(seat)
    if Config.Vehicle.Enabled then
        if vehicleModel and now - FeatureCooldowns.Vehicle >= 0.2 then
            FeatureCooldowns.Vehicle = now
            ApplyVehicleModsForSeat(seat, vehicleModel)
            VehicleModsActive = true
        elseif not vehicleModel and VehicleModsActive then
            RestoreVehicleModdedState()
            VehicleModsActive = false
        end

        ApplyVehicleForwardBoost(seat, vehicleModel)
    elseif VehicleModsActive then
        RestoreVehicleModdedState()
        VehicleModsActive = false
    end

    HandleVehicleCrashProtection(now, hum, seat, vehicleModel)
end

local function SetVehicleModsEnabled(state)
    Config.Vehicle.Enabled = state
    if not state then
        RestoreVehicleModdedState()
        VehicleModsActive = false
        ResetVehicleCrashState()
    end
end

