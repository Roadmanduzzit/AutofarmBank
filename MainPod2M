local function StartSpillAutofarm()
    AutofarmTicket += 1
    local ticket = AutofarmTicket
    task.spawn(function()
        local spillSys = Workspace:FindFirstChild("SpillSystem")
        while Config.Autofarm.Enabled and AutofarmTicket == ticket do
            if not spillSys or not spillSys.Parent then
                spillSys = Workspace:FindFirstChild("SpillSystem")
                task.wait(1)
                continue
            end

            for _, spill in pairs(spillSys:GetChildren()) do
                if not Config.Autofarm.Enabled or AutofarmTicket ~= ticket then
                    return
                end

                local target = (spill:IsA("Model") and spill.PrimaryPart) or (spill:IsA("BasePart") and spill)
                local decal = spill:FindFirstChildWhichIsA("Decal", true)
                if target and decal and decal.Transparency < 0.1 then
                    local _, root = GetHumanoidAndRoot(GetCharacter())
                    if root then
                        local dist = (root.Position - target.Position).Magnitude
                        local time = dist / math.max(Config.Autofarm.Speed, 1)
                        local tween = TweenService:Create(root, TweenInfo.new(time, Enum.EasingStyle.Linear), {CFrame = CFrame.new(target.Position + Vector3.new(0,3,0))})
                        tween:Play()

                        local elapsed = 0
                        while elapsed < time do
                            if not Config.Autofarm.Enabled or AutofarmTicket ~= ticket then
                                tween:Cancel()
                                return
                            end
                            task.wait(0.1)
                            elapsed += 0.1
                        end

                        if Config.Autofarm.Enabled and AutofarmTicket == ticket then
                            local prompt = spill:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if prompt then
                                fireproximityprompt(prompt)
                            end
                        end
                        task.wait(2)
                    end
                end
            end
            task.wait(1)
        end
    end)
end

local function SetAutofarmEnabled(state)
    Config.Autofarm.Enabled = state
    if state then
        StartSpillAutofarm()
    else
        AutofarmTicket += 1
    end
end

local function TriggerPrompt(prompt)
    if not prompt or not prompt:IsA("ProximityPrompt") or not prompt.Enabled then
        return false
    end

    local oldHold = prompt.HoldDuration
    local oldLineOfSight = prompt.RequiresLineOfSight
    local fired = false
    pcall(function()
        prompt.HoldDuration = 0
        prompt.RequiresLineOfSight = false
    end)
    local ok = pcall(function()
        fireproximityprompt(prompt, 1, true)
    end)
    if ok then
        fired = true
    end
    if not fired then
        ok = pcall(function()
            fireproximityprompt(prompt, 0, true)
        end)
        if ok then
            fired = true
        end
    end
    if not fired then
        ok = pcall(function()
            fireproximityprompt(prompt)
        end)
        if ok then
            fired = true
        end
    end
    pcall(function()
        prompt.HoldDuration = oldHold
        prompt.RequiresLineOfSight = oldLineOfSight
    end)
    return fired
end

local function GetInstanceBasePart(obj)
    if not obj then
        return nil
    end
    if obj:IsA("BasePart") then
        return obj
    end
    if obj:IsA("Model") then
        return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart", true)
    end
    return obj:FindFirstChildWhichIsA("BasePart", true)
end

local function GetPromptActivationPosition(prompt)
    if not prompt then
        return nil
    end

    local parent = prompt.Parent
    if parent and parent:IsA("BasePart") then
        return parent.Position
    end

    local ancestorPart = prompt:FindFirstAncestorWhichIsA("BasePart")
    if ancestorPart then
        return ancestorPart.Position
    end

    if parent and parent:IsA("Model") then
        local part = parent.PrimaryPart or parent:FindFirstChildWhichIsA("BasePart", true)
        if part then
            return part.Position
        end
    end

    return nil
end

local function SnapRootToPosition(position, lookAtPosition)
    local hum, root = GetHumanoidAndRoot(GetCharacter())
    if not hum or hum.Health <= 0 or not root then
        return
    end

    local standPos = position + Vector3.new(0, 2.5, 0)
    root.CFrame = CFrame.lookAt(standPos, lookAtPosition or position)
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
end

local function TriggerPromptAtPosition(prompt, position)
    if not prompt or not prompt:IsA("ProximityPrompt") or not prompt.Enabled then
        return false
    end

    if position then
        SnapRootToPosition(position, position)
    end
    return TriggerPrompt(prompt)
end

local function TriggerPromptsInContainerNear(container, centerPosition, radius, excludedRoot)
    if not container then
        return 0
    end

    local triggered = 0
    for _, desc in ipairs(container:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled and (not excludedRoot or not desc:IsDescendantOf(excludedRoot)) then
            local pos = GetPromptActivationPosition(desc)
            if pos and (pos - centerPosition).Magnitude <= radius then
                if TriggerPromptAtPosition(desc, pos) then
                    triggered += 1
                end
            end
        end
    end
    return triggered
end

