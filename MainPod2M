local function DisconnectAirdropLock()
    if AirdropLockConnection then
        AirdropLockConnection:Disconnect()
        AirdropLockConnection = nil
    end
    LockedAirdropPart = nil
end

local function SetAirdropLockPart(part)
    if LockedAirdropPart == part and AirdropLockConnection then
        return
    end

    DisconnectAirdropLock()
    LockedAirdropPart = part
    if not part then
        return
    end

    AirdropLockConnection = RunService.RenderStepped:Connect(function()
        if not Config.Autofarm.AirdropEnabled then
            DisconnectAirdropLock()
            return
        end
        if not LockedAirdropPart or not LockedAirdropPart.Parent then
            DisconnectAirdropLock()
            return
        end
        if AirdropKillActiveCount > 0 then
            return
        end

        local hum, root = GetHumanoidAndRoot(GetCharacter())
        if not hum or not root or hum.Health <= 0 then
            return
        end

        local holdPosition = LockedAirdropPart.Position + Vector3.new(0, 3, 0)
        root.CFrame = CFrame.lookAt(holdPosition, LockedAirdropPart.Position)
        root.AssemblyLinearVelocity = Vector3.zero
