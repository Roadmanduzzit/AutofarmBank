local function MobileCameraNudge()
    if not Camera then return end
    local originalCFrame = Camera.CFrame
    local targetCFrame = originalCFrame * CFrame.Angles(0, math.rad(math.random(-2, 2)), 0)
    local tweenIn = TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {CFrame = targetCFrame})
    local tweenOut = TweenService:Create(Camera, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {CFrame = originalCFrame})
    tweenIn:Play(); tweenIn.Completed:Wait()
    task.wait(0.1); tweenOut:Play()
end

