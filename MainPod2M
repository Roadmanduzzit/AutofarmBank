local function TextHasKeyword(text, keywords)
    local lower = string.lower(tostring(text or ""))
    if lower == "" then
        return nil
    end

    local normalized = " " .. string.gsub(lower, "[^%w]+", " ") .. " "

    for _, keyword in ipairs(keywords) do
        local hit = false
        if #keyword <= 3 then
            hit = lower == keyword or string.find(normalized, " " .. keyword .. " ", 1, true) ~= nil
        else
            hit = string.find(lower, keyword, 1, true) ~= nil
        end
        if hit then
            return keyword
        end
    end
    return nil
end

local function AddReasonUnique(reasons, reason)
    if not reason or reason == "" then
        return
    end
    for _, existing in ipairs(reasons) do
        if existing == reason then
            return
        end
    end
    table.insert(reasons, reason)
end

