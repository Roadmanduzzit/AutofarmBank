end

local function AddToggle(page, text, default, cb)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 54)
    f.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    f.BorderSizePixel = 0
    f.Parent = page
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)

    local l = Instance.new("TextLabel")
    l.Text = text
    l.Size = UDim2.new(0.62, 0, 1, 0)
    l.Position = UDim2.new(0.05, 0, 0, 0)
    l.BackgroundTransparency = 1
    l.TextColor3 = Color3.fromRGB(255, 255, 255)
    l.Font = Enum.Font.Gotham
    l.TextSize = 16
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = f

    local b = Instance.new("TextButton")
    b.Text = ""
    b.Size = UDim2.new(0, 74, 0, 36)
    b.Position = UDim2.new(1, -87, 0.5, -18)
    b.BorderSizePixel = 0
    b.Parent = f
    Instance.new("UICorner", b).CornerRadius = UDim.new(1, 0)

    local on = default == true
    local function ApplyState(state, fireCallback)
        on = state == true
        b.BackgroundColor3 = on and Color3.fromRGB(0, 235, 120) or Color3.fromRGB(65, 65, 70)
        if fireCallback ~= false then
            cb(on)
        end
    end

    b.Activated:Connect(function()
        ApplyState(not on, true)
    end)

    ApplyState(on, false)

    local control = {}
    function control:getState()
        return on
    end
    function control:enable()
        ApplyState(true, true)
    end
    function control:disable()
        ApplyState(false, true)
    end
    return control
end

local function AddSlider(page, text, min, max, default, cb)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 0, 70)
    f.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    f.BorderSizePixel = 0
    f.Parent = page
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)

    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(1, -14, 0, 24)
    l.Position = UDim2.new(0, 10, 0, 6)
    l.BackgroundTransparency = 1
    l.TextColor3 = Color3.fromRGB(255, 255, 255)
    l.Font = Enum.Font.Gotham
    l.TextSize = 16
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Parent = f

    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(0.9, 0, 0, 14)
    bg.Position = UDim2.new(0.05, 0, 0, 42)
    bg.BackgroundColor3 = Color3.fromRGB(62, 62, 66)
    bg.BorderSizePixel = 0
    bg.Parent = f
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
    fill.BorderSizePixel = 0
    fill.Parent = bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local value = default
    local dragging = false

    local function SetValue(raw, fireCallback)
        local clamped = math.clamp(math.floor(raw + 0.5), min, max)
        value = clamped
        local alpha = (clamped - min) / math.max((max - min), 1)
        fill.Size = UDim2.new(alpha, 0, 1, 0)
        l.Text = string.format("%s: %d", text, clamped)
        if fireCallback ~= false then
            cb(clamped)
        end
    end

    local function UpdateFromInput(input)
        local alpha = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local scaled = min + ((max - min) * alpha)
        SetValue(scaled, true)
    end

    bg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            UpdateFromInput(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateFromInput(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    SetValue(default, false)

    local control = {}
    function control:setValue(v)
        SetValue(v, true)
    end
    return control
end

