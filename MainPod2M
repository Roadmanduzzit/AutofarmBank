    local uid = tonumber(plr.UserId) or 0
    if uid > 0 then
        return tostring(uid)
    end
    return string.lower(plr.Name)
end

local function LoadModDetectionScriptAccessUsers()
    if ModDetectionScriptAccessLoaded then
        return
    end
    ModDetectionScriptAccessLoaded = true

    local moduleScript = ReplicatedStorage:FindFirstChild("CreatorsWithToolGiveAccessAndScriptAccess", true)
    if not moduleScript or not moduleScript:IsA("ModuleScript") then
        return
    end

    local ok, entries = pcall(function()
        return require(moduleScript)
    end)
    if not ok or typeof(entries) ~= "table" then
        return
    end

    for name, data in pairs(entries) do
        if typeof(name) == "string" then
            local hasAccess = false
            if typeof(data) == "table" then
                hasAccess = data.ScriptAccess == true
            elseif data == true then
                hasAccess = true
            end
            if hasAccess then
                ModDetectionKnownPrivilegedNames[string.lower(name)] = true
            end
        end
    end
end

local function GetCachedGroupRoleInfo(plr)
    local key = BuildModDetectionUserKey(plr)
    local cached = ModDetectionRoleCache[key]
    if cached then
        return cached
    end

    local info = { Role = "", Rank = 0 }
    local okRole, role = pcall(function()
        return plr:GetRoleInGroup(MOD_DETECTION_GROUP_ID)
    end)
    if okRole and type(role) == "string" then
        info.Role = role
    end

    local okRank, rank = pcall(function()
        return plr:GetRankInGroup(MOD_DETECTION_GROUP_ID)
    end)
    if okRank and type(rank) == "number" then
        info.Rank = rank
    end

    ModDetectionRoleCache[key] = info
    return info
end

local function CollectPrivilegeReasonsFromAttributes(target, reasons, label)
    if not target then
        return
    end

    for attrName, attrValue in pairs(target:GetAttributes()) do
        if TextHasKeyword(attrName, ModDetectionValueKeywords) then
            local flagged = false
            if typeof(attrValue) == "boolean" then
                flagged = attrValue
            elseif typeof(attrValue) == "number" then
                flagged = attrValue > 0
            elseif typeof(attrValue) == "string" then
                flagged = TextHasKeyword(attrValue, ModDetectionRoleKeywords) ~= nil
            end
            if flagged then
                AddReasonUnique(reasons, string.format("%s attribute %s=%s", label, tostring(attrName), tostring(attrValue)))
            end
        end
    end
end

local function CollectPrivilegeReasonsFromContainer(container, reasons, label)
    if not container then
        return
    end

    local function evaluateValueObject(obj, scope)
        if not (obj:IsA("BoolValue") or obj:IsA("IntValue") or obj:IsA("NumberValue") or obj:IsA("StringValue")) then
            return
        end
        if not TextHasKeyword(obj.Name, ModDetectionValueKeywords) then
            return
        end

        local value = obj.Value
        local flagged = false
        if obj:IsA("BoolValue") then
            flagged = value == true
        elseif obj:IsA("IntValue") or obj:IsA("NumberValue") then
            flagged = tonumber(value) and tonumber(value) > 0
        elseif obj:IsA("StringValue") then
            local lower = string.lower(tostring(value or ""))
            if lower ~= "" and lower ~= "none" and lower ~= "nonadmin" and lower ~= "member" then
                flagged = TextHasKeyword(lower, ModDetectionRoleKeywords) ~= nil
            end
        end

        if flagged then
            AddReasonUnique(reasons, string.format("%s %s=%s", scope, obj.Name, tostring(value)))
        end
    end

    for _, child in ipairs(container:GetChildren()) do
        evaluateValueObject(child, label)
        if child:IsA("Folder") or child:IsA("Configuration") then
            for _, grand in ipairs(child:GetChildren()) do
                evaluateValueObject(grand, label .. "/" .. child.Name)
            end
        end
    end
end

local function GetModDetectionReasons(plr)
    if not plr or plr == LocalPlayer then
        return {}
    end

    LoadModDetectionScriptAccessUsers()
    local reasons = {}
    local lowerName = string.lower(plr.Name)
    local lowerDisplay = string.lower(tostring(plr.DisplayName or ""))
    if ModDetectionKnownPrivilegedNames[lowerName] or (lowerDisplay ~= "" and ModDetectionKnownPrivilegedNames[lowerDisplay]) then
        AddReasonUnique(reasons, "known script access account")
    end

    local groupInfo = GetCachedGroupRoleInfo(plr)
    local roleKeyword = TextHasKeyword(groupInfo.Role, ModDetectionRoleKeywords)
    if roleKeyword and groupInfo.Rank > 0 then
        AddReasonUnique(reasons, string.format("group role %s (rank %d)", tostring(groupInfo.Role), groupInfo.Rank))
    elseif groupInfo.Rank >= 240 then
        AddReasonUnique(reasons, string.format("high group rank %d", groupInfo.Rank))
    end

    CollectPrivilegeReasonsFromAttributes(plr, reasons, "player")
    CollectPrivilegeReasonsFromAttributes(plr.Character, reasons, "character")
    CollectPrivilegeReasonsFromContainer(plr, reasons, "player value")

    local valueStats = plr:FindFirstChild("Valuestats")
    if valueStats then
        CollectPrivilegeReasonsFromContainer(valueStats, reasons, "valuestats")
    end

    return reasons
end

local function WarnIfPrivilegedPlayerPresent(plr)
    if not plr or plr == LocalPlayer then
        return
    end

    local key = BuildModDetectionUserKey(plr)
    if ModDetectionFlaggedUsers[key] then
        return
    end

    local reasons = GetModDetectionReasons(plr)
    if #reasons == 0 then
        return
    end

    ModDetectionFlaggedUsers[key] = table.concat(reasons, "; ")
    local detail = reasons[1]
    if #reasons > 1 then
        detail = detail .. string.format(" (+%d more)", #reasons - 1)
    end
    Notify("Mod Detection", string.format("%s flagged: %s", plr.Name, detail), 7)
end

