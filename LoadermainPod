    [142823291]       = "https://raw.githubusercontent.com/Roadmanduzzit/AutofarmBank/refs/heads/main/MainPodMM3",
}

local url = scriptByPlace[placeId]

if url then
    local ok, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)

    if not ok then
        warn("Loader failed: " .. tostring(err))
    end
else
    warn("You sure this game is supported by focus?: " .. tostring(placeId))
end
