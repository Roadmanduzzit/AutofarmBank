local function addKeybindEditor(section, bindId)
    local cfg = KeybindConfig[bindId]
    if not cfg then
        return
    end

    local editor = section:addTextbox({ text = cfg.Label .. " Key" })
    local function updateTooltip()
        editor:setTooltip("Current: " .. keyCodeToName(KeybindValues[bindId]) .. " | Type key name or NONE")
    end
    updateTooltip()

    editor:bindToEvent("onFocusLost", function(text)
        local parsed, err = parseKeyCodeFromText(text)
        if err == "empty" then
            return
        end
        if err == "invalid" then
            notifyKeybind("Invalid key for " .. cfg.Label)
            return
        end

        if parsed == false then
            KeybindValues[bindId] = nil
            notifyKeybind(cfg.Label .. " key: NONE")
        else
            KeybindValues[bindId] = parsed
            notifyKeybind(cfg.Label .. " key: " .. parsed.Name)
        end
        updateTooltip()
    end)
end

