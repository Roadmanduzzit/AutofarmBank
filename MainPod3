local function getFlyMoveDirection()
    local currentCamera = Workspace.CurrentCamera
    if not currentCamera then
        return Vector3.new(0, 0, 0)
    end

    local dir = Vector3.new(0, 0, 0)
    local look = currentCamera.CFrame.LookVector
    local right = currentCamera.CFrame.RightVector

    if FlyInput.W then
        dir = dir + look
    end
    if FlyInput.S then
        dir = dir - look
    end
    if FlyInput.D then
        dir = dir + right
    end
    if FlyInput.A then
        dir = dir - right
    end
    if FlyInput.Up then
        dir = dir + Vector3.new(0, 1, 0)
    end
    if FlyInput.Down then
        dir = dir - Vector3.new(0, 1, 0)
    end

    if dir.Magnitude > 1 then
        dir = dir.Unit
    end
    return dir
end

-- =============================================================================
-- Tool discovery
-- =============================================================================
local ToolCache = {
    LastRefresh = 0,
    Tools = {}
}

local function collectToolCandidates(container, out, seen, depth)
    if not container or depth > 2 then
        return
    end

    for _, child in ipairs(container:GetChildren()) do
        if (child:IsA("Model") or child:IsA("Tool")) and not seen[child] then
            local toolName = child:GetAttribute("ToolName")
            local nameLower = lower(child.Name)
            if toolName
                or string.find(nameLower, "axe")
                or string.find(nameLower, "chainsaw")
                or string.find(nameLower, "flute")
                or string.find(nameLower, "bag")
            then
                seen[child] = true
                table.insert(out, child)
            end
        end

        if child:IsA("Folder") then
            collectToolCandidates(child, out, seen, depth + 1)
        end
    end
end

local function refreshToolCache(force)
    local now = os.clock()
    if not force and (now - ToolCache.LastRefresh) < 1 then
        return
    end

    ToolCache.LastRefresh = now

    local tools = {}
    local seen = {}

    collectToolCandidates(LocalPlayer:FindFirstChild("Inventory"), tools, seen, 0)
    collectToolCandidates(LocalPlayer:FindFirstChildOfClass("Backpack"), tools, seen, 0)
    collectToolCandidates(LocalPlayer.Character, tools, seen, 0)

    ToolCache.Tools = tools
end

local function getToolName(tool)
    local fromAttr = tool:GetAttribute("ToolName")
    if typeof(fromAttr) == "string" and #fromAttr > 0 then
        return fromAttr
    end
    return tool.Name
end

local function getToolScore(tool)
    local tier = tonumber(tool:GetAttribute("ToolTier")) or 1
    local resourceDamage = tonumber(tool:GetAttribute("WeaponResourceDamage"))
    local damage = tonumber(tool:GetAttribute("WeaponDamage")) or 0
    return tier * 1000 + (resourceDamage or damage)
end

local function findBestTool(predicate)
    refreshToolCache(false)

    local best = nil
    local bestScore = -math.huge

    for _, tool in ipairs(ToolCache.Tools) do
        local toolName = getToolName(tool)
        local nameLower = lower(toolName)
        if predicate(tool, nameLower) then
            local score = getToolScore(tool)
            if score > bestScore then
                best = tool
                bestScore = score
            end
        end
    end

    return best
end

local function getBestDamageTool()
    return findBestTool(function(_, nameLower)
        return nameLower == "genericaxe"
            or nameLower == "chainsaw"
            or nameLower == "flamethrower"
            or string.find(nameLower, "axe")
            or string.find(nameLower, "chainsaw")
    end)
end

local function getBestItemBagTool()
    return findBestTool(function(_, nameLower)
        return nameLower == "item bag" or string.find(nameLower, "bag")
    end)
end

local function getBestFluteTool()
    return findBestTool(function(_, nameLower)
        return nameLower == "taming flute"
            or nameLower == "admin taming flute"
            or string.find(nameLower, "flute")
    end)
end

