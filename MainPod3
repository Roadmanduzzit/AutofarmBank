-- =============================================================================
-- Client / remote helpers
-- =============================================================================
local ClientModule = nil
local function getClient()
    if ClientModule then
        return ClientModule
    end

    local playerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    if not playerScripts then
        return nil
    end

    local clientScript = playerScripts:FindFirstChild("Client")
    if not clientScript then
        return nil
    end

    local ok, result = pcall(require, clientScript)
    if ok then
        ClientModule = result
    end
    return ClientModule
end

local function getRemote(name)
    local client = getClient()
    if client and client.Events and client.Events[name] then
        return client.Events[name]
    end

    local remoteFolder = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if remoteFolder then
        return remoteFolder:FindFirstChild(name)
    end

    return nil
end

local function callRemote(name, ...)
    local remote = getRemote(name)
    if not remote then
        return false, nil
    end

    local ok, result = pcall(function(...)
        if typeof(remote) == "Instance" then
            if remote:IsA("RemoteFunction") then
                return remote:InvokeServer(...)
            end
            if remote:IsA("RemoteEvent") then
                remote:FireServer(...)
                return true
            end
        end

        if type(remote) == "table" then
            if remote.InvokeServer then
                return remote:InvokeServer(...)
            end
            if remote.FireServer then
                remote:FireServer(...)
                return true
            end
        end

        if remote.InvokeServer then
            return remote:InvokeServer(...)
        end
        if remote.FireServer then
            remote:FireServer(...)
            return true
        end
    end, ...)

    return ok, result
end

