local ESP = {
    Tracked = {},
    FrameCounter = 0
}

local function createEspNode(instance, category)
    local adornee = getModelAdornee(instance)
    if not adornee then
        return nil
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "Focus_ESP_Node"
    billboard.Adornee = adornee
    billboard.Size = UDim2.new(0, 180, 0, 72)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled = false

    pcall(function()
        billboard.Parent = CoreGui
    end)
    if not billboard.Parent then
        billboard.Parent = LocalPlayer:WaitForChild("PlayerGui")
    end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Config.ESPColors.Background
    frame.BackgroundTransparency = 0.35
    frame.BorderSizePixel = 0
    frame.Parent = billboard

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = frame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 1, -10)
    label.Position = UDim2.new(0, 5, 0, 5)
    label.BackgroundTransparency = 1
    label.TextWrapped = true
    label.RichText = true
    label.Font = Enum.Font.Code
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.TextColor3 = Config.ESPColors[category] or Color3.new(1, 1, 1)
    label.Parent = frame

    return {
        Instance = instance,
        Category = category,
        Billboard = billboard,
        Label = label
    }
end

local function removeEspNode(instance)
    local data = ESP.Tracked[instance]
    if not data then
        return
    end

    if data.Billboard then
        data.Billboard:Destroy()
    end
    ESP.Tracked[instance] = nil
end

local function updateEspText(data, distance)
    local model = data.Instance
    local categoryText = Config.ESPLabels[data.Category] or data.Category
    local title = tostring(model.Name)

    local extras = {}
    local resourceType = model:GetAttribute("Resource")
    if resourceType then
        table.insert(extras, tostring(resourceType))
    end

    local hp = model:GetAttribute("Health")
    if typeof(hp) == "number" then
        table.insert(extras, "HP " .. math.floor(hp))
    end

    if model:GetAttribute("CanBeTamed") and not model:GetAttribute("Tamed") then
        table.insert(extras, "Can tame")
    end

    local info = categoryText .. " | " .. math.floor(distance) .. "m"
    if #extras > 0 then
        info = info .. "\n" .. table.concat(extras, " | ")
    end

    data.Label.TextColor3 = Config.ESPColors[data.Category] or Color3.new(1, 1, 1)
    data.Label.Text = string.format("<b>%s</b>\n%s", title, info)
end

local function addEspTarget(targets, instance, category, origin)
    if not instance or not instance.Parent then
        return
    end

    local pos = getInstancePosition(instance)
    if not pos then
        return
    end

    if (pos - origin).Magnitude <= State.ESPDistance then
        targets[instance] = category
    end
end

local function refreshEspTargets()
    if not State.ESP then
        for instance in pairs(ESP.Tracked) do
            removeEspNode(instance)
        end
        return
    end

    local root = getRootPart()
    if not root then
        return
    end
    local origin = root.Position

    local targets = {}

    if State.ESPTreesResources then
        local characters = Workspace:FindFirstChild("Characters")
        if characters then
            for _, model in ipairs(characters:GetChildren()) do
                if model:IsA("Model") and (isTreeTarget(model) or isSpecialResourceTarget(model)) then
                    addEspTarget(targets, model, "TreeResource", origin)
                end
            end
        end

        local nearby = getNearbyModels(State.ESPDistance + 50)
        for model in pairs(nearby) do
            if isTreeTarget(model) or isSpecialResourceTarget(model) then
                addEspTarget(targets, model, "TreeResource", origin)
            end
        end
    end

    if State.ESPFarmPlots then
        for _, plot in ipairs(CollectionService:GetTagged("FarmPlot")) do
            addEspTarget(targets, plot, "FarmPlot", origin)
        end
    end

    if State.ESPTameables then
        for _, npc in ipairs(CollectionService:GetTagged("NPC")) do
            if isTameableNpc(npc) then
                addEspTarget(targets, npc, "Tameable", origin)
            end
        end
    end

    if State.ESPCorpses then
        for _, corpse in ipairs(CollectionService:GetTagged("CultistCorpse")) do
            if corpse:IsA("Model") and not corpse:GetAttribute("Resurrected") then
                addEspTarget(targets, corpse, "Corpse", origin)
            end
        end
    end

    if State.ESPStructures then
        for _, struct in ipairs(CollectionService:GetTagged("CanBePickedUp")) do
            addEspTarget(targets, struct, "Structure", origin)
        end
        for _, struct in ipairs(CollectionService:GetTagged("Colourable")) do
            addEspTarget(targets, struct, "Structure", origin)
        end
    end

    if State.ESPChests then
        local itemsFolder = Workspace:FindFirstChild("Items")
        if itemsFolder then
            for _, item in ipairs(itemsFolder:GetChildren()) do
                if isChestTargetInstance(item) then
                    addEspTarget(targets, item, "Chest", origin)
                end
            end
        end
    end

    for instance, category in pairs(targets) do
        local tracked = ESP.Tracked[instance]
        if not tracked then
            tracked = createEspNode(instance, category)
            if tracked then
                ESP.Tracked[instance] = tracked
            end
        else
            tracked.Category = category
            local newAdornee = getModelAdornee(instance)
            if newAdornee then
                tracked.Billboard.Adornee = newAdornee
            end
        end
    end

    for instance in pairs(ESP.Tracked) do
        if not targets[instance] then
            removeEspNode(instance)
        end
    end
end

