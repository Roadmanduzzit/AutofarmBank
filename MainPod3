local function keyCodeToName(keyCode)
    return keyCode and keyCode.Name or "NONE"
end

local function parseKeyCodeFromText(text)
    local raw = tostring(text or "")
    raw = raw:gsub("^%s+", ""):gsub("%s+$", "")
    if raw == "" then
        return nil, "empty"
    end

    local normalized = string.upper(raw:gsub("%s+", ""))
    local aliases = {
        CTRL = "LEFTCONTROL",
        CONTROL = "LEFTCONTROL",
        SHIFT = "LEFTSHIFT",
        ALT = "LEFTALT",
        SPACEBAR = "SPACE",
        RETURN = "ENTER",
        ESC = "ESCAPE"
    }
    normalized = aliases[normalized] or normalized

    if normalized == "NONE" or normalized == "OFF" or normalized == "CLEAR" then
        return false, nil
    end

    for _, keyCode in ipairs(Enum.KeyCode:GetEnumItems()) do
        if string.upper(keyCode.Name) == normalized then
            return keyCode, nil
        end
    end

    return nil, "invalid"
end

local function notifyKeybind(message)
    if ui then
        ui.notify({
            title = "Keybind",
            message = message,
            duration = 2.5
        })
    end
end

local function toggleStateByKeybind(bindId)
    local cfg = KeybindConfig[bindId]
    if not cfg then
        return
    end

    local newState = not State[cfg.StateKey]
    State[cfg.StateKey] = newState
    notifyKeybind(cfg.Label .. ": " .. (newState and "ON" or "OFF"))
end

local function handleKeybindInput(keyCode)
    for _, bindId in ipairs(KeybindOrder) do
        if KeybindValues[bindId] == keyCode then
            toggleStateByKeybind(bindId)
            return true
        end
    end
    return false
end

