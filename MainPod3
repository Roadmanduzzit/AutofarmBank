local Timers = {
    Chop = 0,
    Mob = 0,
    Bag = 0,
    Tame = 0,
    PromptReact = 0,
    ChestTP = 0,
    Logs = 0,
    EspScan = 0
}

RunService.Heartbeat:Connect(function()
    local now = os.clock()

    if State.ChopTreeAura and (now - Timers.Chop) >= State.ChopInterval then
        Timers.Chop = now
        local targets = getNearestModelsByPredicate(State.ChopRange, isTreeTarget, State.ChopTargets)
        for _, target in ipairs(targets) do
            hitWithTool(target)
        end
    end

    if State.MobAura and (now - Timers.Mob) >= State.MobAuraInterval then
        Timers.Mob = now
        local targets = getNearestModelsByPredicate(State.MobAuraRange, isMobTarget, State.MobAuraTargets)
        for _, target in ipairs(targets) do
            hitWithTool(target)
        end
    end

    if State.ItemBagAura and (now - Timers.Bag) >= State.ItemBagInterval then
        Timers.Bag = now
        tryBagNearest()
    end

    if State.AutoTame and (now - Timers.Tame) >= State.AutoTameInterval then
        Timers.Tame = now
        tryAutoTame()
    end

    if State.InstantPromptReact and (now - Timers.PromptReact) >= State.PromptReactInterval then
        Timers.PromptReact = now
        reactToActivePrompts(now)
    end

    if State.ChestTP and (now - Timers.ChestTP) >= State.ChestTPInterval then
        Timers.ChestTP = now
        teleportToNextChest()
    end

    if State.BringLogs and (now - Timers.Logs) >= State.BringLogsInterval then
        Timers.Logs = now
        bringNearbyLogs()
    elseif not State.BringLogs and next(LogDragStates) ~= nil then
        releaseAllLogDrags()
    end

    if State.ESP and (now - Timers.EspScan) >= 1.0 then
        Timers.EspScan = now
        refreshEspTargets()
    end
end)

local FlyWasApplied = false
local NoclipCache = {}
local function applyNoclip()
    local character = LocalPlayer.Character
    if not character then
        return
    end

    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            if NoclipCache[part] == nil then
                NoclipCache[part] = part.CanCollide
            end
            part.CanCollide = false
        end
    end
end

local function restoreNoclip()
    for part, wasCollidable in pairs(NoclipCache) do
        if part and part.Parent then
            part.CanCollide = wasCollidable
        end
    end
    NoclipCache = {}
end

RunService.RenderStepped:Connect(function(deltaTime)
    local character = LocalPlayer.Character
    local root = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    if State.Noclip then
        applyNoclip()
    elseif next(NoclipCache) ~= nil then
        restoreNoclip()
    end

    if State.CFrameFly and root then
        local direction = getFlyMoveDirection()
        if humanoid then
            humanoid.PlatformStand = true
        end
        FlyWasApplied = true
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        if direction.Magnitude > 0 then
            root.CFrame = root.CFrame + direction * State.CFrameFlySpeed * deltaTime
        end
    elseif FlyWasApplied then
        if humanoid then
            humanoid.PlatformStand = false
        end
        FlyWasApplied = false
    end

    if State.CFrameWalkSpeedEnabled and not State.CFrameFly and root and humanoid then
        local moveDir = humanoid.MoveDirection
        if moveDir.Magnitude > 0 then
            local flatMove = Vector3.new(moveDir.X, 0, moveDir.Z)
            if flatMove.Magnitude > 0 then
                root.CFrame = root.CFrame + flatMove.Unit * State.CFrameWalkSpeed * deltaTime
            end
        end
    end

    if not State.ESP then
        for _, data in pairs(ESP.Tracked) do
            data.Billboard.Enabled = false
        end
        return
    end

    local rootPos = root and root.Position
    if not rootPos then
        return
    end

    ESP.FrameCounter = ESP.FrameCounter + 1
    local refreshText = (ESP.FrameCounter % 10) == 0

    for instance, data in pairs(ESP.Tracked) do
        if not instance or not instance.Parent then
            removeEspNode(instance)
        else
            local pos = getInstancePosition(instance)
            if not pos then
                removeEspNode(instance)
            else
                local distance = (pos - rootPos).Magnitude
                data.Billboard.Enabled = distance <= State.ESPDistance
                if refreshText then
                    updateEspText(data, distance)
                end
            end
        end
    end
end)

