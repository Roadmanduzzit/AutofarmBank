-- Nearby-target helpers
-- =============================================================================
local NearbyParams = OverlapParams.new()
NearbyParams.FilterType = Enum.RaycastFilterType.Exclude
NearbyParams.MaxParts = 300

local function getNearbyModels(radius)
    local root = getRootPart()
    if not root then
        return {}, nil
    end

    local ignore = {}
    if LocalPlayer.Character then
        table.insert(ignore, LocalPlayer.Character)
    end
    local particles = Workspace:FindFirstChild("Particles")
    if particles then
        table.insert(ignore, particles)
    end
    NearbyParams.FilterDescendantsInstances = ignore

    local results = {}
    local ok, parts = pcall(function()
        return Workspace:GetPartBoundsInRadius(root.Position, radius, NearbyParams)
    end)

    if ok and parts then
        for _, part in ipairs(parts) do
            local model = part:FindFirstAncestorOfClass("Model")
            if model then
                results[model] = true
            end
        end
    end

    return results, root.Position
end

local function getNearestModelByPredicate(radius, predicate)
    local models, origin = getNearbyModels(radius)
    if not origin then
        return nil, nil
    end

    local bestModel = nil
    local bestDist = nil

    for model in pairs(models) do
        if model and model.Parent and predicate(model) then
            local pos = getInstancePosition(model)
            if pos then
                local dist = (pos - origin).Magnitude
                if not bestDist or dist < bestDist then
                    bestModel = model
                    bestDist = dist
                end
            end
        end
    end

    return bestModel, bestDist
end

local function getNearestModelsByPredicate(radius, predicate, maxCount)
    local models, origin = getNearbyModels(radius)
    if not origin then
        return {}
    end

    local scored = {}
    for model in pairs(models) do
        if model and model.Parent and predicate(model) then
            local pos = getInstancePosition(model)
            if pos then
                table.insert(scored, {
                    Model = model,
                    Dist = (pos - origin).Magnitude
                })
            end
        end
    end

    table.sort(scored, function(a, b)
        return a.Dist < b.Dist
    end)

    local limit = math.max(1, math.floor(maxCount or 1))
    local result = {}
    for i = 1, math.min(limit, #scored) do
        result[i] = scored[i].Model
    end

    return result
end

