local function getRootPart()
    local character = LocalPlayer.Character
    if not character then
        return nil
    end
    return character:FindFirstChild("HumanoidRootPart")
end

local function getInstancePosition(instance)
    if not instance then
        return nil
    end

    if instance:IsA("BasePart") then
        return instance.Position
    end

    if instance:IsA("Model") then
        local ok, pivot = pcall(function()
            return instance:GetPivot()
        end)
        if ok and pivot then
            return pivot.Position
        end

        if instance.PrimaryPart then
            return instance.PrimaryPart.Position
        end

        local anyPart = instance:FindFirstChildWhichIsA("BasePart", true)
        if anyPart then
            return anyPart.Position
        end
    end

    return nil
end

local function getModelAdornee(instance)
    if not instance then
        return nil
    end

    if instance:IsA("BasePart") then
        return instance
    end

    if instance:IsA("Model") then
        return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
    end

    return nil
end

local function lower(value)
    return string.lower(tostring(value or ""))
end

local function getMovablePart(instance)
    if not instance then
        return nil
    end
    if instance:IsA("BasePart") then
        return instance
    end
    if instance:IsA("Model") then
        return instance.PrimaryPart or instance:FindFirstChildWhichIsA("BasePart", true)
    end
    return nil
end

local LogDragStates = {}

local function collectLogTargets()
    local items = Workspace:FindFirstChild("Items")
    if not items then
        return {}
    end

    local targets = {}
    local seen = {}

    local function addIfLog(inst, forceInclude)
        if not inst or seen[inst] then
            return
        end
        if not (inst:IsA("Model") or inst:IsA("BasePart")) then
            return
        end

        local nameLower = lower(inst.Name)
        if forceInclude or nameLower == "log" or string.find(nameLower, "log", 1, true) then
            seen[inst] = true
            table.insert(targets, inst)
        end
    end

    local function addFromContainer(container)
        if not container then
            return
        end

        if container:IsA("Model") or container:IsA("BasePart") then
            addIfLog(container, true)
            return
        end

        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("Folder") then
                for _, grandChild in ipairs(child:GetChildren()) do
                    addIfLog(grandChild, true)
                end
            else
                addIfLog(child, true)
            end
        end
    end

    addFromContainer(items:FindFirstChild("Logs"))
    addFromContainer(items:FindFirstChild("Log"))

    for _, child in ipairs(items:GetChildren()) do
        addIfLog(child, false)
    end

    return targets
end

local function tryRemoteVariants(remoteName, variants)
    for _, args in ipairs(variants) do
        local ok, result = callRemote(remoteName, unpack(args))
        if ok then
            if type(result) == "table" then
                if result.Success ~= false then
                    return true
                end
            else
                return true
            end
        end
    end
    return false
end

local function requestLogDragStart(logObj)
    local root = getRootPart()
    local variants = {
        { logObj },
        { logObj, true }
    }
    if root then
        table.insert(variants, { logObj, root.Position })
        table.insert(variants, { logObj, root.CFrame })
    end
    return tryRemoteVariants("RequestStartDraggingItem", variants)
end

local function requestLogDragStop(logObj)
    local variants = {
        { logObj },
        {}
    }
    return tryRemoteVariants("StopDraggingItem", variants)
end

local function releaseAllLogDrags()
    for logObj in pairs(LogDragStates) do
        requestLogDragStop(logObj)
    end
    LogDragStates = {}
end

local function updateLogDragOwnership(logObj, now)
    local state = LogDragStates[logObj]
    if not state then
        requestLogDragStart(logObj)
        LogDragStates[logObj] = {
            StartedAt = now,
            ReadyAt = now + State.BringLogsHoldTime,
            ExpireAt = now + State.BringLogsHoldTime + 4
        }
        return false
    end

    if state.ReleaseAt then
        return false
    end

    if now >= state.ReadyAt then
        return true
    end

    if (now - state.StartedAt) > (State.BringLogsHoldTime + 1.5) then
        requestLogDragStart(logObj)
        state.StartedAt = now
        state.ReadyAt = now + State.BringLogsHoldTime
        state.ExpireAt = now + State.BringLogsHoldTime + 4
    end

    return false
end

local function queueLogDragRelease(logObj, now)
    local state = LogDragStates[logObj]
    if not state then
        return
    end
    state.ReleaseAt = now + 0.15
    state.ExpireAt = math.max(state.ExpireAt or 0, now + 2.5)
end

local function moveLogToTarget(logObj, part, targetPos)
    local movedByPivot = false
    pcall(function()
        if logObj:IsA("Model") then
            logObj:PivotTo(CFrame.new(targetPos))
        else
            logObj.CFrame = CFrame.new(targetPos)
        end
        movedByPivot = true
    end)

    if (not movedByPivot) or (part.Position - targetPos).Magnitude > 6 then
        pcall(function()
            part.CFrame = CFrame.new(targetPos)
        end)
    end

    local delta = targetPos - part.Position
    if delta.Magnitude > 0.05 then
        part.AssemblyLinearVelocity = delta.Unit * math.clamp(delta.Magnitude * 18, 40, 260)
    else
        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end
    part.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    return (part.Position - targetPos).Magnitude <= 20
end

local function cleanupLogDragStates(now)
    for logObj, state in pairs(LogDragStates) do
        local releaseNow = state and state.ReleaseAt and now >= state.ReleaseAt
        local expired = state and state.ExpireAt and now > state.ExpireAt
        if releaseNow then
            requestLogDragStop(logObj)
            LogDragStates[logObj] = nil
        elseif not logObj or not logObj.Parent or expired then
            if logObj and logObj.Parent then
                requestLogDragStop(logObj)
            end
            LogDragStates[logObj] = nil
        end
    end
end

local function bringNearbyLogs()
    local root = getRootPart()
    if not root then
        return
    end

    local logTargets = collectLogTargets()
    if #logTargets == 0 then
        return
    end

    local now = os.clock()
    cleanupLogDragStates(now)
    if not State.BringLogsUseDragOwnership and next(LogDragStates) ~= nil then
        releaseAllLogDrags()
    end

    local moved = 0
    local maxCount = math.max(1, math.floor(State.BringLogsPerTick))
    local spread = math.max(1, State.BringLogsSpread)

    for _, logObj in ipairs(logTargets) do
        if moved >= maxCount then
            break
        end

        if (logObj:IsA("Model") or logObj:IsA("BasePart")) and not logObj:GetAttribute("Destroyed") then
            local pos = getInstancePosition(logObj)
            if pos and (pos - root.Position).Magnitude <= State.BringLogsRange then
                if State.BringLogsUseDragOwnership then
                    if not updateLogDragOwnership(logObj, now) then
                        continue
                    end
                end

                local offset = Vector3.new(
                    (math.random() - 0.5) * spread,
                    1.5,
                    (math.random() - 0.5) * spread
                )
                local targetPos = root.Position + root.CFrame.LookVector * 5 + offset

                local part = getMovablePart(logObj)
                if part then
                    local movedToPlayer = moveLogToTarget(logObj, part, targetPos)
                    if State.BringLogsUseDragOwnership then
                        if movedToPlayer then
                            queueLogDragRelease(logObj, now)
                        else
                            local state = LogDragStates[logObj]
                            if state then
                                state.ExpireAt = now + 2.5
                            end
                        end
                    end

                    if movedToPlayer then
                        moved = moved + 1
                    end
                end
            end
        end
    end
end

local ActivePrompts = {}
local PromptReactCooldowns = {}

local function getPromptWorldPosition(prompt)
    if not prompt or not prompt.Parent then
        return nil
    end

    local holder = prompt.Parent
    if holder:IsA("Attachment") then
        holder = holder.Parent
    end

    return getInstancePosition(holder)
end

local function canReactToPrompt(prompt, now)
    if not State.InstantPromptReact then
        return false
    end
    if not prompt or not prompt.Parent or not prompt.Enabled then
        return false
    end

    local last = PromptReactCooldowns[prompt]
    if last and (now - last) < math.max(0.02, State.PromptReactInterval * 0.5) then
        return false
    end

    local root = getRootPart()
    if root then
        local promptPos = getPromptWorldPosition(prompt)
        if promptPos then
            local maxDistance = tonumber(prompt.MaxActivationDistance) or 12
            if (promptPos - root.Position).Magnitude > (maxDistance + 6) then
                return false
            end
        end
    end

    return true
end

local function tryInstantPromptReact(prompt, now)
    now = now or os.clock()
    if not canReactToPrompt(prompt, now) then
        return false
    end

    local fired = false
    if typeof(fireproximityprompt) == "function" then
        local ok = pcall(fireproximityprompt, prompt)
        if not ok then
            ok = pcall(fireproximityprompt, prompt, 0)
        end
        fired = ok
    end

    if not fired and prompt.InputHoldBegin and prompt.InputHoldEnd then
        local oldHold = prompt.HoldDuration
        local ok = pcall(function()
            prompt.HoldDuration = 0
            prompt:InputHoldBegin()
            prompt:InputHoldEnd()
        end)
        pcall(function()
            prompt.HoldDuration = oldHold
        end)
        fired = ok
    end

    if fired then
        PromptReactCooldowns[prompt] = now
    end
    return fired
end

local function reactToActivePrompts(now)
    for prompt in pairs(ActivePrompts) do
        if not prompt or not prompt.Parent then
            ActivePrompts[prompt] = nil
            PromptReactCooldowns[prompt] = nil
        else
            tryInstantPromptReact(prompt, now)
        end
    end
end

ProximityPromptService.PromptShown:Connect(function(prompt)
    ActivePrompts[prompt] = true
    if State.InstantPromptReact then
        task.defer(function()
            tryInstantPromptReact(prompt, os.clock())
        end)
    end
end)

ProximityPromptService.PromptHidden:Connect(function(prompt)
    ActivePrompts[prompt] = nil
    PromptReactCooldowns[prompt] = nil
end)

