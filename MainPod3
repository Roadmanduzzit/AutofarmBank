local FlyInput = {
    W = false,
    A = false,
    S = false,
    D = false,
    Up = false,
    Down = false
}

local function setFlyInputState(keyCode, isDown)
    if keyCode == Enum.KeyCode.W then
        FlyInput.W = isDown
    elseif keyCode == Enum.KeyCode.A then
        FlyInput.A = isDown
    elseif keyCode == Enum.KeyCode.S then
        FlyInput.S = isDown
    elseif keyCode == Enum.KeyCode.D then
        FlyInput.D = isDown
    elseif keyCode == Enum.KeyCode.Space or keyCode == Enum.KeyCode.E then
        FlyInput.Up = isDown
    elseif keyCode == Enum.KeyCode.LeftControl
        or keyCode == Enum.KeyCode.Q
        or keyCode == Enum.KeyCode.LeftShift
    then
        FlyInput.Down = isDown
    end
end

