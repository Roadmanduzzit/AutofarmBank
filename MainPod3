local function isDamageableResourceModel(model)
    if not model or not model:IsA("Model") then
        return false
    end
    if model:GetAttribute("Destroyed") then
        return false
    end
    if model:GetAttribute("Health") ~= nil then
        return true
    end
    if model:FindFirstChild("HitRegisters") then
        return true
    end
    return false
end

local function isTreeTarget(model)
    if not isDamageableResourceModel(model) then
        return false
    end

    local resourceType = model:GetAttribute("Resource")
    if resourceType and Config.SpecialResources[resourceType] then
        return false
    end

    local modelName = lower(model.Name)
    if string.find(modelName, "tree") then
        return true
    end
    if resourceType and resourceType ~= "" then
        return true
    end

    return false
end

local function isSpecialResourceTarget(model)
    if not isDamageableResourceModel(model) then
        return false
    end

    local resourceType = model:GetAttribute("Resource")
    if resourceType and Config.SpecialResources[resourceType] then
        return true
    end

    local modelName = lower(model.Name)
    return string.find(modelName, "obsidiron")
        or string.find(modelName, "meteor")
        or string.find(modelName, "ice")
end

local function isBaggableModel(model)
    if not model or not model:IsA("Model") then
        return false
    end
    if model:GetAttribute("Destroyed") or model:GetAttribute("Ignited") then
        return false
    end
    if model:GetAttribute("Interaction") == "NightPlant" then
        return false
    end
    if CollectionService:HasTag(model, "ItemBag") then
        return false
    end

    local itemsFolder = Workspace:FindFirstChild("Items")
    local characters = Workspace:FindFirstChild("Characters")

    if model.Parent == itemsFolder then
        return true
    end
    if model.Parent == characters and model:GetAttribute("CanBeBagged") then
        return true
    end

    return false
end

local function isTameableNpc(model)
    if not model or not model:IsA("Model") then
        return false
    end
    if not model.Parent then
        return false
    end
    if not model:GetAttribute("CanBeTamed") then
        return false
    end
    if model:GetAttribute("Tamed") then
        return false
    end
    if model:GetAttribute("LocalTaming") then
        return false
    end

    local inProgress = model:GetAttribute("TamingInProgress")
    if inProgress and inProgress ~= LocalPlayer.UserId then
        return false
    end

    return true
end

local function isMobTarget(model)
    if not model or not model:IsA("Model") then
        return false
    end
    if not model.Parent then
        return false
    end
    if model:GetAttribute("Destroyed") then
        return false
    end

    local hasNpcTag = CollectionService:HasTag(model, "NPC")
    local hasNpcValue = model:FindFirstChild("NPC") ~= nil
    if not hasNpcTag and not hasNpcValue then
        return false
    end

    if State.MobAuraIgnoreTamed and model:GetAttribute("Tamed") then
        return false
    end
    if State.MobAuraIgnoreNotAttackable and model:GetAttribute("NotAttackable") then
        return false
    end

    local health = model:GetAttribute("Health")
    if typeof(health) == "number" and health <= 0 then
        return false
    end

    return true
end

