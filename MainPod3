local function getDamageAmount(toolModel, targetModel)
    local isNpcTarget = CollectionService:HasTag(targetModel, "NPC") or targetModel:FindFirstChild("NPC")
    local amount

    if isNpcTarget then
        amount = tonumber(toolModel:GetAttribute("WeaponDamage"))
            or tonumber(toolModel:GetAttribute("WeaponResourceDamage"))
            or 10
    else
        amount = tonumber(toolModel:GetAttribute("WeaponResourceDamage"))
            or tonumber(toolModel:GetAttribute("WeaponDamage"))
            or 10
    end

    local resourceType = targetModel:GetAttribute("Resource")
    if resourceType == "IceBlock" then
        local iceMultiplier = tonumber(toolModel:GetAttribute("IceDamageMultiplier"))
        if iceMultiplier then
            amount = amount * iceMultiplier
        end
    end

    return amount
end

local function hitWithTool(targetModel)
    local root = getRootPart()
    if not root then
        return
    end

    local toolModel = getBestDamageTool()
    if not toolModel then
        return
    end

    local amount = getDamageAmount(toolModel, targetModel)
    local ok, result = callRemote("ToolDamageObject", targetModel, toolModel, amount, root.CFrame)
    if ok and type(result) == "table" and result.Success == false then
        -- Server rejected this hit, ignore quietly.
    end
end

local BagCooldowns = {}
local function tryBagNearest()
    local bagTool = getBestItemBagTool()
    if not bagTool then
        return
    end

    local target = getNearestModelByPredicate(State.ItemBagRange, isBaggableModel)
    if not target then
        return
    end

    local now = os.clock()
    if BagCooldowns[target] and BagCooldowns[target] > now then
        return
    end
    BagCooldowns[target] = now + 1

    local ok, result = callRemote("RequestBagStoreItem", bagTool, target)
    if ok and type(result) == "table" and result.Success == false then
        BagCooldowns[target] = now + 2
    end
end

local TameCooldowns = {}
local function getClosestTameableNpc(maxDistance)
    local root = getRootPart()
    if not root then
        return nil
    end

    local origin = root.Position
    local best = nil
    local bestDist = nil
    local seen = {}

    local function considerNpc(npc)
        if not npc or seen[npc] then
            return
        end
        seen[npc] = true
        if not isTameableNpc(npc) then
            return
        end

        local pos = getInstancePosition(npc)
        if not pos then
            return
        end

        local dist = (pos - origin).Magnitude
        if dist <= maxDistance and (not bestDist or dist < bestDist) then
            best = npc
            bestDist = dist
        end
    end

    local characters = Workspace:FindFirstChild("Characters")
    if characters then
        for _, npc in ipairs(characters:GetChildren()) do
            if npc:IsA("Model") then
                considerNpc(npc)
            end
        end
    end

    for _, npc in ipairs(CollectionService:GetTagged("NPC")) do
        considerNpc(npc)
    end

    local nearby = getNearbyModels(maxDistance + 12)
    for model in pairs(nearby) do
        considerNpc(model)
    end

    return best
end

local function tryAutoTame()
    local flute = getBestFluteTool()
    if not flute then
        return
    end

    local npc = getClosestTameableNpc(State.AutoTameRange)
    if not npc then
        return
    end

    local now = os.clock()
    if TameCooldowns[npc] and TameCooldowns[npc] > now then
        return
    end
    TameCooldowns[npc] = now + 2

    npc:SetAttribute("LocalTaming", true)
    task.delay(2, function()
        if npc and npc.Parent and npc:GetAttribute("LocalTaming") then
            npc:SetAttribute("LocalTaming", nil)
        end
    end)

    callRemote("RequestTame_Neutral", npc, flute)

    if State.PerfectTame then
        task.spawn(function()
            local deadline = os.clock() + 1.6
            local firedHungry = false

            while State.AutoTame and npc and npc.Parent and flute and flute.Parent and os.clock() < deadline do
                local inProgress = npc:GetAttribute("TamingInProgress")
                if inProgress == nil or inProgress == LocalPlayer.UserId then
                    task.wait(0.15)
                    if State.AutoTame and npc and npc.Parent and flute and flute.Parent then
                        callRemote("RequestTame_Hungry", npc, flute)
                        firedHungry = true
                    end
                    break
                end
                task.wait(0.1)
            end

            if not firedHungry and State.AutoTame and npc and npc.Parent and flute and flute.Parent then
                callRemote("RequestTame_Hungry", npc, flute)
            end
        end)
    end
end

local LastChestTeleported = nil
local function isChestName(name)
    local normalized = lower(name):gsub("[^%w]", "")
    if normalized == "itemchest" then
        return true
    end

    local suffix = string.match(normalized, "^itemchest(%d+)$")
    if suffix then
        local chestIndex = tonumber(suffix)
        return chestIndex ~= nil and chestIndex >= 1 and chestIndex <= 5
    end

    return false
end

local function isChestTargetInstance(item)
    if not item or not (item:IsA("Model") or item:IsA("BasePart")) then
        return false
    end
    if item:GetAttribute("Destroyed") then
        return false
    end
    return isChestName(item.Name)
end

local function collectChestTargets()
    local itemsFolder = Workspace:FindFirstChild("Items")
    if not itemsFolder then
        return {}
    end

    local chests = {}
    for _, item in ipairs(itemsFolder:GetChildren()) do
        if isChestTargetInstance(item) then
            table.insert(chests, item)
        end
    end
    return chests
end

local function pickNextChestTarget(chests)
    if #chests == 0 then
        return nil
    end
    if #chests == 1 then
        return chests[1]
    end

    local pool = {}
    for _, chest in ipairs(chests) do
        if chest ~= LastChestTeleported then
            table.insert(pool, chest)
        end
    end
    if #pool == 0 then
        pool = chests
    end

    return pool[math.random(1, #pool)]
end

local function teleportToNextChest()
    local root = getRootPart()
    if not root then
        return false
    end

    local chests = collectChestTargets()
    local chest = pickNextChestTarget(chests)
    if not chest then
        return false
    end

    local chestPos = getInstancePosition(chest)
    if not chestPos then
        return false
    end

    local targetPos = chestPos + Vector3.new(0, 4, 0)
    pcall(function()
        root.CFrame = CFrame.new(targetPos)
    end)
    root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    LastChestTeleported = chest
    return true
end

