local menuTp = window:addMenu({ text = 'Teleports' })
local sectTp = menuTp:addSection({ text = 'Locations', side = 'left' })

local function TeleportTo(pos)
    local _, root = GetHumanoidAndRoot(GetCharacter())
    if root then
        root.CFrame = CFrame.new(pos)
    end
end

sectTp:addButton({ text = 'Sport Shop' }, function() TeleportTo(Vector3.new(-19, 4, -77)) end)
sectTp:addButton({ text = 'Gun Store' }, function() TeleportTo(Vector3.new(39, 4, 370)) end)
