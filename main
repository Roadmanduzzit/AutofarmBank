local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- Global Config
local DefaultConfig = {
    SilentAim = {
        Enabled = false,
        FOV = 200,
        ShowFOV = false,
        HitChance = 100,
        TargetPart = "Head",
        WallCheck = true,
        Visuals = false
    },
    Visuals = { Enabled = false, Box = false, Name = false, Health = false, Tool = false, MaxDist = 2500 },
    Movement = { SlideEnabled = false, SlideSpeed = 45, FlyEnabled = false, FlySpeed = 45, Noclip = false },
    Combat = { InfAmmo = false, RapidFire = false, NoRecoil = false },
    Autofarm = { Enabled = false, Speed = 30 },
    Misc = { InfStamina = false, CashPickup = false, PickupRange = 25 }
}

local function DeepCopy(source)
    local copy = {}
    for key, value in pairs(source) do
        if typeof(value) == "table" then
            copy[key] = DeepCopy(value)
        else
            copy[key] = value
        end
    end
    return copy
end

local function MergeWithDefaults(defaults, loaded)
    if typeof(defaults) ~= "table" then
        if typeof(loaded) == typeof(defaults) then
            return loaded
        end
        return defaults
    end

    local merged = {}
    local loadedTable = typeof(loaded) == "table" and loaded or nil
    for key, defaultValue in pairs(defaults) do
        local loadedValue = loadedTable and loadedTable[key] or nil
        merged[key] = MergeWithDefaults(defaultValue, loadedValue)
    end
    return merged
end

local function ClampConfigValues(cfg)
    cfg.SilentAim.FOV = math.clamp(cfg.SilentAim.FOV, 10, 500)
    cfg.SilentAim.HitChance = math.clamp(cfg.SilentAim.HitChance, 0, 100)
    cfg.Visuals.MaxDist = math.clamp(cfg.Visuals.MaxDist, 100, 5000)
    cfg.Movement.SlideSpeed = math.clamp(cfg.Movement.SlideSpeed, 16, 45)
    cfg.Movement.FlySpeed = math.clamp(cfg.Movement.FlySpeed, 16, 45)
    cfg.Autofarm.Speed = math.clamp(cfg.Autofarm.Speed, 10, 30)
    cfg.Misc.PickupRange = math.clamp(cfg.Misc.PickupRange, 1, 250)
    return cfg
end

local Config = ClampConfigValues(DeepCopy(DefaultConfig))

-- Logic Variables
local ESP_Storage = {}
local Movers = { SlideBV = nil, SlideBG = nil, FlyBV = nil, FlyBG = nil }
local MoveKeys = {[Enum.KeyCode.W]=false, [Enum.KeyCode.A]=false, [Enum.KeyCode.S]=false, [Enum.KeyCode.D]=false}
local NoclipConnection = nil
local AutofarmTicket = 0

-- Silent Aim Visuals
local FOVCircle = Drawing.new("Circle")
FOVCircle.Color = Color3.fromRGB(255, 0, 80)
FOVCircle.Thickness = 1.5
FOVCircle.NumSides = 64
FOVCircle.Filled = false
FOVCircle.Visible = false

local CurrentHighlight = nil
local CurrentTarget = nil
local Controls = {}

local ActiveConfigName = "default"
local ApplyConfigToControls = function() end

local CONFIG_FOLDER = "FocusConfigs"
local LAST_CONFIG_FILE = CONFIG_FOLDER .. "/last.txt"
local FALLBACK_FILE_PREFIX = "focus_config_"
local FALLBACK_LAST_FILE = "focus_last.txt"

local function SupportsFolderApi()
    return typeof(isfolder) == "function" and typeof(makefolder) == "function"
end

local function SafeUnit(vector)
    if vector.Magnitude > 0 then
        return vector.Unit
    end
    return Vector3.zero
end

local function GetCamera()
    return Workspace.CurrentCamera or Camera
end

local function GetCharacter()
    return LocalPlayer.Character
end

local function GetHumanoidAndRoot(character)
    if not character then
        return nil, nil
    end
    return character:FindFirstChildOfClass("Humanoid"), character:FindFirstChild("HumanoidRootPart")
end

local function NormalizeConfigName(name)
    local cleaned = tostring(name or ""):lower()
    cleaned = cleaned:gsub("%s+", "_")
    cleaned = cleaned:gsub("[^%w_.-]", "")
    if cleaned == "" then
        cleaned = "default"
    end
    return cleaned:sub(1, 32)
end

local function BuildConfigPath(name)
    local normalized = NormalizeConfigName(name)
    if SupportsFolderApi() then
        return string.format("%s/%s.json", CONFIG_FOLDER, normalized)
    end
    return string.format("%s%s.json", FALLBACK_FILE_PREFIX, normalized)
end

local function GetLastConfigPath()
    if SupportsFolderApi() then
        return LAST_CONFIG_FILE
    end
    return FALLBACK_LAST_FILE
end

local function EnsureConfigFolder()
    if not SupportsFolderApi() then
        return true
    end

    local existsOk, exists = pcall(isfolder, CONFIG_FOLDER)
    if not existsOk then
        return false, tostring(exists)
    end

    if not exists then
        local makeOk, makeErr = pcall(makefolder, CONFIG_FOLDER)
        if not makeOk then
            return false, tostring(makeErr)
        end
    end

    return true
end

local function ReadFileSafe(path)
    if typeof(readfile) ~= "function" then
        return nil, "readfile unavailable"
    end
    local ok, result = pcall(readfile, path)
    if not ok then
        return nil, tostring(result)
    end
    return result
end

local function WriteFileSafe(path, content)
    if typeof(writefile) ~= "function" then
        return false, "writefile unavailable"
    end
    local ok, result = pcall(writefile, path, content)
    if not ok then
        return false, tostring(result)
    end
    return true
end

local function SaveConfig(configName)
    local folderOk, folderErr = EnsureConfigFolder()
    if not folderOk then
        return false, folderErr
    end

    local normalized = NormalizeConfigName(configName)
    local encodeOk, payload = pcall(function()
        return HttpService:JSONEncode(Config)
    end)
    if not encodeOk then
        return false, tostring(payload)
    end

    local writeOk, writeErr = WriteFileSafe(BuildConfigPath(normalized), payload)
    if not writeOk then
        return false, writeErr
    end

    ActiveConfigName = normalized
    WriteFileSafe(GetLastConfigPath(), normalized)
    return true, normalized
end

local function LoadConfig(configName)
    local normalized = NormalizeConfigName(configName)
    local raw, readErr = ReadFileSafe(BuildConfigPath(normalized))
    if not raw then
        return false, readErr
    end

    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(raw)
    end)
    if not decodeOk or typeof(decoded) ~= "table" then
        return false, "invalid json config"
    end

    Config = ClampConfigValues(MergeWithDefaults(DefaultConfig, decoded))
    ActiveConfigName = normalized
    ApplyConfigToControls()
    WriteFileSafe(GetLastConfigPath(), normalized)
    return true, normalized
end

local function DeleteConfig(configName)
    if typeof(delfile) ~= "function" then
        return false, "delfile unavailable"
    end

    local normalized = NormalizeConfigName(configName)
    local path = BuildConfigPath(normalized)
    if typeof(isfile) == "function" then
        local existsOk, exists = pcall(isfile, path)
        if existsOk and not exists then
            return false, "config not found"
        end
    end

    local deleteOk, deleteErr = pcall(delfile, path)
    if not deleteOk then
        return false, tostring(deleteErr)
    end
    return true, normalized
end

local function GetConfigNames()
    local folderOk, folderErr = EnsureConfigFolder()
    if not folderOk then
        return {}, folderErr
    end
    if not SupportsFolderApi() then
        return {}, "listing requires folder API support"
    end
    if typeof(listfiles) ~= "function" then
        return {}, "listfiles unavailable"
    end

    local listOk, files = pcall(listfiles, CONFIG_FOLDER)
    if not listOk then
        return {}, tostring(files)
    end

    local names = {}
    for _, filePath in ipairs(files) do
        local name = tostring(filePath):match("([^/\\]+)%.json$")
        if name then
            table.insert(names, name)
        end
    end
    table.sort(names)
    return names
end

local function LoadLastConfig()
    local name, readErr = ReadFileSafe(GetLastConfigPath())
    if not name then
        return false, readErr
    end
    name = tostring(name):gsub("%s+", "")
    if name == "" then
        return false, "last config file empty"
    end
    return LoadConfig(name)
end

local function ResetConfigToDefaults()
    Config = ClampConfigValues(DeepCopy(DefaultConfig))
    ActiveConfigName = "default"
    ApplyConfigToControls()
end

Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
    Camera = Workspace.CurrentCamera
end)

-- [[ 3. SILENT AIM FUNCTIONS (CAMERA HOOK) ]] --

-- WallCheck
local function IsVisible(part)
    if not Config.SilentAim.WallCheck then return true end
    local cam = GetCamera()
    if not cam then
        return false
    end

    local origin = cam.CFrame.Position
    local direction = part.Position - origin
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {GetCharacter(), cam, Workspace:FindFirstChild("OBJECTS"), Workspace:FindFirstChild("Ray_Ignore")}
    params.FilterType = Enum.RaycastFilterType.Exclude
    
    local result = Workspace:Raycast(origin, direction, params)
    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end
    return true
end

-- Highlight (Red Chams)
local function UpdateHighlight(targetChar)
    if CurrentHighlight then CurrentHighlight:Destroy(); CurrentHighlight = nil end
    
    if Config.SilentAim.Visuals and targetChar then
        local hl = Instance.new("Highlight")
        hl.Adornee = targetChar
        hl.FillColor = Color3.fromRGB(255, 0, 0)
        hl.OutlineColor = Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.5
        hl.OutlineTransparency = 0.5
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = targetChar
        CurrentHighlight = hl
    end
end

-- Get Target
local function GetClosestTarget()
    local cam = GetCamera()
    if not cam then
        return nil
    end

    local MousePos = UserInputService:GetMouseLocation()
    local ClosestDist = Config.SilentAim.FOV
    local Target = nil
    local Char = nil

    if Config.SilentAim.Enabled then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                local Part = v.Character:FindFirstChild(Config.SilentAim.TargetPart) or v.Character:FindFirstChild("Head")
                
                if Part then
                    local ScreenPos, OnScreen = cam:WorldToViewportPoint(Part.Position)
                    if OnScreen then
                        local Dist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                        if Dist < ClosestDist then
                            if IsVisible(Part) then
                                ClosestDist = Dist
                                Target = Part
                                Char = v.Character
                            end
                        end
                    end
                end
            end
        end
    end

    if Char ~= CurrentTarget then
        CurrentTarget = Char
        UpdateHighlight(Char)
    end
    
    return Target
end

-- THE CAMERA HOOK
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local Method = getnamecallmethod()
    local cam = GetCamera()

    if cam and (Method == "ScreenPointToRay" or Method == "ViewportPointToRay") and self == cam and Config.SilentAim.Enabled then
        if CurrentTarget then
            local TargetPart = CurrentTarget:FindFirstChild(Config.SilentAim.TargetPart) or CurrentTarget:FindFirstChild("Head")
            if TargetPart and math.random(1, 100) <= Config.SilentAim.HitChance then
                local Direction = (TargetPart.Position - cam.CFrame.Position)
                return Ray.new(cam.CFrame.Position, Direction)
            end
        end
    end

    return OldNamecall(self, ...)
end))

-- [[ 4. MOVEMENT FUNCTIONS ]] --
local function UpdateMovers(state, type)
    local char = GetCharacter()
    local hum, root = GetHumanoidAndRoot(char)
    
    if type == "Slide" then
        if state then
            if not root then
                return
            end
            if not Movers.SlideBV then
                Movers.SlideBV = Instance.new("BodyVelocity", root)
                Movers.SlideBV.MaxForce = Vector3.new(1e5,0,1e5)
                Movers.SlideBG = Instance.new("BodyGyro", root)
                Movers.SlideBG.MaxTorque = Vector3.new(1e5,0,1e5)
                Movers.SlideBG.P = 10000
            end
        else
            if Movers.SlideBV then Movers.SlideBV:Destroy(); Movers.SlideBV = nil end
            if Movers.SlideBG then Movers.SlideBG:Destroy(); Movers.SlideBG = nil end
        end
    elseif type == "Fly" then
        if state then
            if not root then
                return
            end
            if not Movers.FlyBV then
                Movers.FlyBV = Instance.new("BodyVelocity", root)
                Movers.FlyBV.MaxForce = Vector3.new(1e9,1e9,1e9)
                Movers.FlyBG = Instance.new("BodyGyro", root)
                Movers.FlyBG.MaxTorque = Vector3.new(1e9,1e9,1e9)
                Movers.FlyBG.P = 10000
            end
            if hum then
                hum.PlatformStand = true
            end
        else
            if Movers.FlyBV then Movers.FlyBV:Destroy(); Movers.FlyBV = nil end
            if Movers.FlyBG then Movers.FlyBG:Destroy(); Movers.FlyBG = nil end
            if hum then
                hum.PlatformStand = false
            end
        end
    end
end

local function EnsureMovementInstances()
    if Config.Movement.SlideEnabled and (not Movers.SlideBV or not Movers.SlideBG) then
        UpdateMovers(true, "Slide")
    end
    if Config.Movement.FlyEnabled and (not Movers.FlyBV or not Movers.FlyBG) then
        UpdateMovers(true, "Fly")
    end
end

local function SetNoclipEnabled(state)
    Config.Movement.Noclip = state
    if state then
        if NoclipConnection then
            NoclipConnection:Disconnect()
        end
        NoclipConnection = RunService.Stepped:Connect(function()
            local char = GetCharacter()
            if not char then
                return
            end
            for _, p in pairs(char:GetDescendants()) do
                if p:IsA("BasePart") then
                    p.CanCollide = false
                end
            end
        end)
    elseif NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
end

local function StartSpillAutofarm()
    AutofarmTicket += 1
    local ticket = AutofarmTicket
    task.spawn(function()
        local spillSys = Workspace:FindFirstChild("SpillSystem")
        while Config.Autofarm.Enabled and AutofarmTicket == ticket do
            if not spillSys or not spillSys.Parent then
                spillSys = Workspace:FindFirstChild("SpillSystem")
                task.wait(1)
                continue
            end

            for _, spill in pairs(spillSys:GetChildren()) do
                if not Config.Autofarm.Enabled or AutofarmTicket ~= ticket then
                    return
                end

                local target = (spill:IsA("Model") and spill.PrimaryPart) or (spill:IsA("BasePart") and spill)
                local decal = spill:FindFirstChildWhichIsA("Decal", true)
                if target and decal and decal.Transparency < 0.1 then
                    local _, root = GetHumanoidAndRoot(GetCharacter())
                    if root then
                        local dist = (root.Position - target.Position).Magnitude
                        local time = dist / math.max(Config.Autofarm.Speed, 1)
                        local tween = TweenService:Create(root, TweenInfo.new(time, Enum.EasingStyle.Linear), {CFrame = CFrame.new(target.Position + Vector3.new(0,3,0))})
                        tween:Play()

                        local elapsed = 0
                        while elapsed < time do
                            if not Config.Autofarm.Enabled or AutofarmTicket ~= ticket then
                                tween:Cancel()
                                return
                            end
                            task.wait(0.1)
                            elapsed += 0.1
                        end

                        if Config.Autofarm.Enabled and AutofarmTicket == ticket then
                            local prompt = spill:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if prompt then
                                fireproximityprompt(prompt)
                            end
                        end
                        task.wait(2)
                    end
                end
            end
            task.wait(1)
        end
    end)
end

local function SetAutofarmEnabled(state)
    Config.Autofarm.Enabled = state
    if state then
        StartSpillAutofarm()
    else
        AutofarmTicket += 1
    end
end

-- [[ 5. ESP LOGIC ]] --
local function CreateDrawing(t, p) local d = Drawing.new(t);
for k,v in pairs(p) do d[k]=v end; return d end

local function RemoveESP(plr)
    if ESP_Storage[plr] then
        for _, d in pairs(ESP_Storage[plr]) do if d.Remove then d:Remove() end end
        ESP_Storage[plr] = nil
    end
    if plr.Character and CurrentTarget == plr.Character then
        CurrentTarget = nil
        UpdateHighlight(nil)
    end
end

local function HandleESP()
    local cam = GetCamera()
    if not cam then
        return
    end

    if not Config.Visuals.Enabled then 
        for _, p in pairs(ESP_Storage) do for _, d in pairs(p) do d.Visible = false end end
        return 
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if not ESP_Storage[plr] then
                ESP_Storage[plr] = {
                    Box = CreateDrawing("Square", {Thickness=1, Color=Color3.new(1,1,1), Filled=false}),
                    Name = CreateDrawing("Text", {Size=13, Center=true, Outline=true, Color=Color3.new(1,1,1)}),
                    Bar = CreateDrawing("Square", {Filled=true}),
                    Tool = CreateDrawing("Text", {Size=12, Center=true, Outline=true, Color=Color3.new(0.8,0.8,1)})
                }
            end

            local d = ESP_Storage[plr]
            local char = plr.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            local show = false

            if root and hum and hum.Health > 0 then
                local pos, vis = cam:WorldToViewportPoint(root.Position)
                if vis and (root.Position - cam.CFrame.Position).Magnitude <= Config.Visuals.MaxDist then
                    show = true
                    local h = 1000/pos.Z * 3.5;
                    local w = h/2; local x = pos.X - w/2;
                    local y = pos.Y - h/2
                    
                    if Config.Visuals.Box then d.Box.Visible=true;
                    d.Box.Size=Vector2.new(w,h); d.Box.Position=Vector2.new(x,y) else d.Box.Visible=false end
                    if Config.Visuals.Name then d.Name.Visible=true;
                    d.Name.Text=plr.Name; d.Name.Position=Vector2.new(x+w/2, y-16) else d.Name.Visible=false end
                    if Config.Visuals.Health then
                        local hp = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
                        d.Bar.Visible=true;
                        d.Bar.Size=Vector2.new(2, h*hp); d.Bar.Position=Vector2.new(x-5, y+h-(h*hp)); d.Bar.Color=Color3.fromHSV(hp*0.3,1,1)
                    else d.Bar.Visible=false end
                    
                    if Config.Visuals.Tool then
                        local tool = char:FindFirstChildWhichIsA("Tool")
                        if tool then d.Tool.Visible = true;
                        d.Tool.Text = tool.Name; d.Tool.Position = Vector2.new(x + w/2, y + h + 2) else d.Tool.Visible = false end
                    else d.Tool.Visible = false end
                end
            end
            if not show then for _, o in pairs(d) do o.Visible = false end end
        end
    end
end

Players.PlayerRemoving:Connect(RemoveESP)

-- [[ 6. UI SETUP (DOLLARWARE) ]] --
local uiLoader = loadstring(game:HttpGet('https://raw.githubusercontent.com/topitbopit/dollarware/main/library.lua'))
local ui = uiLoader({ rounding = true, theme = 'midnight', smoothDragging = true })
local window = ui.newWindow({ text = ' Focus ', resize = true, size = Vector2.new(600, 450) })

local function Notify(title, message, duration)
    ui.notify({ title = title, message = message, duration = duration or 3 })
    print(string.format("[Focus] %s: %s", tostring(title), tostring(message)))
end

local function SetToggleState(toggle, state)
    if not toggle then
        return
    end

    if state then
        if not toggle:getState() then
            toggle:enable()
        end
    else
        if toggle:getState() then
            toggle:disable()
        end
    end
end

local function SetSliderValue(slider, value)
    if slider and typeof(value) == "number" then
        slider:setValue(value)
    end
end

