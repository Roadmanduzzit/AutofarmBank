sectTp:addButton({ text = 'BlackMarket' }, function() TeleportTo(Vector3.new(259, 4, 428)) end)

ApplyConfigToControls = function()
    Config = ClampConfigValues(MergeWithDefaults(DefaultConfig, Config))

    SetToggleState(Controls.SilentAimEnabled, Config.SilentAim.Enabled)
    SetToggleState(Controls.SilentAimShowFOV, Config.SilentAim.ShowFOV)
    SetToggleState(Controls.SilentAimVisuals, Config.SilentAim.Visuals)
    SetSliderValue(Controls.SilentAimFOV, Config.SilentAim.FOV)
    SetToggleState(Controls.SilentAimWallCheck, Config.SilentAim.WallCheck)
    SetSliderValue(Controls.SilentAimHitChance, Config.SilentAim.HitChance)

    SetToggleState(Controls.CombatInfAmmo, Config.Combat.InfAmmo)
    SetToggleState(Controls.CombatRapidFire, Config.Combat.RapidFire)
    SetToggleState(Controls.CombatNoRecoil, Config.Combat.NoRecoil)

    SetToggleState(Controls.ESPEnabled, Config.Visuals.Enabled)
    SetToggleState(Controls.ESPBoxes, Config.Visuals.Box)
    SetToggleState(Controls.ESPNames, Config.Visuals.Name)
    SetToggleState(Controls.ESPHealth, Config.Visuals.Health)
    SetToggleState(Controls.ESPTool, Config.Visuals.Tool)
    SetSliderValue(Controls.ESPDistance, Config.Visuals.MaxDist)

    SetToggleState(Controls.MovementSlide, Config.Movement.SlideEnabled)
    SetSliderValue(Controls.MovementSlideSpeed, Config.Movement.SlideSpeed)
    SetToggleState(Controls.MovementFly, Config.Movement.FlyEnabled)
    SetSliderValue(Controls.MovementFlySpeed, Config.Movement.FlySpeed)
    SetToggleState(Controls.MovementNoclip, Config.Movement.Noclip)
    SetToggleState(Controls.MiscInfStamina, Config.Misc.InfStamina)

    SetSliderValue(Controls.AutofarmSpeed, Config.Autofarm.Speed)
    SetToggleState(Controls.AutofarmEnabled, Config.Autofarm.Enabled)
    SetToggleState(Controls.CashMagnet, Config.Misc.CashPickup)
    SetSliderValue(Controls.CashRange, Config.Misc.PickupRange)

    FOVCircle.Radius = Config.SilentAim.FOV
    FOVCircle.Visible = Config.SilentAim.ShowFOV and Config.SilentAim.Enabled
    if not Config.SilentAim.Visuals then
        UpdateHighlight(nil)
    end
end

-- > TAB 7: SETTINGS
local menuSettings = window:addMenu({ text = 'Settings' })
local sectSettings = menuSettings:addSection({ text = 'Config System', side = 'left' })
local sectSettingsTools = menuSettings:addSection({ text = 'Tools', side = 'right' })

sectSettings:addTextbox({ text = 'Config Name' }, function(v)
    ActiveConfigName = NormalizeConfigName(v)
end)

sectSettings:addButton({ text = 'Save Config' }, function()
    local ok, result = SaveConfig(ActiveConfigName)
    if ok then
        Notify("Config Saved", "Saved as " .. result .. ".json")
    else
        Notify("Save Failed", tostring(result))
    end
end)

sectSettings:addButton({ text = 'Load Config' }, function()
    local ok, result = LoadConfig(ActiveConfigName)
    if ok then
        Notify("Config Loaded", "Loaded " .. result .. ".json")
    else
        Notify("Load Failed", tostring(result))
    end
end)

sectSettings:addButton({ text = 'Delete Config' }, function()
    local ok, result = DeleteConfig(ActiveConfigName)
    if ok then
        Notify("Config Deleted", "Deleted " .. result .. ".json")
    else
        Notify("Delete Failed", tostring(result))
    end
end)

sectSettingsTools:addButton({ text = 'Load Last Saved' }, function()
    local ok, result = LoadLastConfig()
    if ok then
        Notify("Last Loaded", "Loaded " .. result .. ".json")
    else
        Notify("Load Failed", tostring(result))
    end
end)

sectSettingsTools:addButton({ text = 'List Configs' }, function()
    local names, listErr = GetConfigNames()
    if listErr then
        Notify("List Failed", tostring(listErr))
        return
    end

    if #names == 0 then
        Notify("Configs", "No saved configs found")
    else
        Notify("Configs", table.concat(names, ", "), 5)
    end
end)

sectSettingsTools:addButton({ text = 'Reset Defaults' }, function()
    ResetConfigToDefaults()
    Notify("Config Reset", "Defaults restored")
end)

local loadedLast, loadedName = LoadLastConfig()
if loadedLast then
    Notify("Config", "Auto-loaded " .. loadedName .. ".json", 2)
else
    ApplyConfigToControls()
end

-- [[ 7. MAIN LOOPS ]] --
RunService.RenderStepped:Connect(function()
    local cam = GetCamera()
    if not cam then
        return
    end

    -- Silent Aim Logic (Visuals)
    FOVCircle.Position = UserInputService:GetMouseLocation()
    FOVCircle.Visible = Config.SilentAim.ShowFOV and Config.SilentAim.Enabled
    
    if Config.SilentAim.Enabled then
        GetClosestTarget() -- Updates Target & Chams
    else
        UpdateHighlight(nil)
    end

    -- ESP & Movement
    HandleESP()
    EnsureMovementInstances()
    
    local camCF = cam.CFrame
    local look, right = camCF.LookVector, camCF.RightVector
    local moveDir = Vector3.zero
    if MoveKeys[Enum.KeyCode.W] then moveDir = moveDir + look end
    if MoveKeys[Enum.KeyCode.S] then moveDir = moveDir - look end
    if MoveKeys[Enum.KeyCode.A] then moveDir = moveDir - right end
    if MoveKeys[Enum.KeyCode.D] then moveDir = moveDir + right end

    if Config.Movement.FlyEnabled and Movers.FlyBV and Movers.FlyBG then
        if moveDir.Magnitude > 0 then
            Movers.FlyBV.Velocity = moveDir.Unit * Config.Movement.FlySpeed
            Movers.FlyBG.CFrame = CFrame.lookAt(Movers.FlyBV.Parent.Position, Movers.FlyBV.Parent.Position + moveDir)
        else Movers.FlyBV.Velocity = Vector3.zero; Movers.FlyBG.CFrame = camCF end
    end
    if Config.Movement.SlideEnabled and Movers.SlideBV and Movers.SlideBG then
        local flatLook = SafeUnit(Vector3.new(look.X, 0, look.Z))
        local flatRight = SafeUnit(Vector3.new(right.X, 0, right.Z))
        local flatDir = Vector3.zero
        if MoveKeys[Enum.KeyCode.W] then flatDir = flatDir + flatLook end
        if MoveKeys[Enum.KeyCode.S] then flatDir = flatDir - flatLook end
        if MoveKeys[Enum.KeyCode.A] then flatDir = flatDir - flatRight end
        if MoveKeys[Enum.KeyCode.D] then flatDir = flatDir + flatRight end
        
        if flatDir.Magnitude > 0 then
            Movers.SlideBV.Velocity = flatDir.Unit * Config.Movement.SlideSpeed
            Movers.SlideBG.CFrame = CFrame.lookAt(Movers.SlideBV.Parent.Position, Movers.SlideBV.Parent.Position + flatDir)
        else Movers.SlideBV.Velocity = Vector3.zero end
    end

    -- Gun Mods
    local char = GetCharacter()
    local tool = char and char:FindFirstChildWhichIsA("Tool")
    local stats = tool and tool:FindFirstChild("Stats")
    if stats then
        local fireRate = stats:FindFirstChild("FireRate")
        local gunType = stats:FindFirstChild("GunType")
        local recoil = stats:FindFirstChild("Recoil")
        local clipSize = stats:FindFirstChild("ClipSize")
        local maxAmmo = stats:FindFirstChild("MaxAmmo")

        if Config.Combat.RapidFire and fireRate and gunType then
            fireRate.Value = 0
            gunType.Value = "Auto"
        end
        if Config.Combat.NoRecoil and recoil then
            recoil.Value = 0
        end
        if Config.Combat.InfAmmo and clipSize and maxAmmo and clipSize.Value <= 0 then
            local gunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes")
            local reloadRemote = gunRemotes and gunRemotes:FindFirstChild("Reload")
            if reloadRemote then
                reloadRemote:FireServer(tool, true)
            end
            clipSize.Value = maxAmmo.Value
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if Config.Misc.CashPickup then
        local _, root = GetHumanoidAndRoot(GetCharacter())
        local folder = Workspace:FindFirstChild("OBJECTS")
        if root and folder then
            for _, item in pairs(folder:GetChildren()) do
                if item.Name == "CashHandle" and (item.Position - root.Position).Magnitude <= Config.Misc.PickupRange then
                    local p = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if p and p.Enabled then p.HoldDuration = 0; fireproximityprompt(p) end
                end
            end
        end
    end
end)

UserInputService.InputBegan:Connect(function(i, g)
    -- Re-added the UI Toggle functionality
    if i.KeyCode == Enum.KeyCode.RightControl then
        if window.Toggle then
            pcall(function()
                window:Toggle()
            end)
        elseif window.Main then
            window.Main.Visible = not window.Main.Visible 
        end
    end
    
    if not g and MoveKeys[i.KeyCode] ~= nil then MoveKeys[i.KeyCode] = true end
end)

UserInputService.InputEnded:Connect(function(i)
    if MoveKeys[i.KeyCode] ~= nil then MoveKeys[i.KeyCode] = false end
end)

local oldIdx;
oldIdx = hookmetamethod(game, "__newindex", function(t, k, v)
    if Config.Misc.InfStamina and typeof(t) == "Instance" and t.Name == "Stamina" and k == "Value" then
        return oldIdx(t, k, 100)
    end
    return oldIdx(t, k, v)
end)

