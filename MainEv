                open = not open
                optionsFrame.Visible = open
                arrowLabel.Text = open and "^" or "v"
            end)

            BuildOptions()
            SelectOption(options[1], false)

            RegisterWidget(tabName, "Dropdown", config.Title, function()
                return selected
            end, function(savedValue)
                if savedValue ~= nil then
                    SelectOption(tostring(savedValue), true)
                end
