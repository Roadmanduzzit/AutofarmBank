	local function startAutoCrouch()
		featureStates.AutoCrouch = true
		previousCrouchState = false
		spamDown = true

		if not guiInstance then
			createExtraCrouchGui()
		end
		if guiInstance then
			guiInstance.Enabled = true
			local button = guiInstance.Frame.crouchGuiButton
			button.Text = "Stop"
			button.BackgroundColor3 = Color3.fromRGB(0, 120, 0)
		end

		if crouchConnection then
			crouchConnection:Disconnect()
		end
		crouchConnection =
			RunService.Heartbeat:Connect(
				function()
					local character = player.Character
					if not character or not character:FindFirstChild("Humanoid") then
						return
					end
					local humanoid = character.Humanoid
					local mode = featureStates.AutoCrouchMode

					if mode == "Normal" then
						fireKeybind(spamDown, "Crouch")
						spamDown = not spamDown
					else
						local isAir =
						(humanoid.FloorMaterial == Enum.Material.Air) and
						(humanoid:GetState() ~= Enum.HumanoidStateType.Seated)
						local shouldCrouch = (mode == "Air" and isAir) or (mode == "Ground" and not isAir)
						if shouldCrouch ~= previousCrouchState then
							fireKeybind(shouldCrouch, "Crouch")
							previousCrouchState = shouldCrouch
						end
					end
				end
			)

		if keybindConnection then
			keybindConnection:Disconnect()
		end
		keybindConnection =
			UserInputService.InputBegan:Connect(
				function(input, gameProcessed)
					if gameProcessed then
						return
					end
					if input.KeyCode == Enum.KeyCode.C then
						featureStates.AutoCrouch = not featureStates.AutoCrouch
						local button = guiInstance and guiInstance.Frame:FindFirstChild("crouchGuiButton")
						if button then
							button.Text = featureStates.AutoCrouch and "Stop" or "Start"
							button.BackgroundColor3 =
							featureStates.AutoCrouch and Color3.fromRGB(0, 120, 0) or Color3.fromRGB(186, 0, 0)
						end
						if featureStates.AutoCrouch then
							startAutoCrouch()
						else
							stopAutoCrouch()
						end
						if AutoCrouchToggle then
							AutoCrouchToggle:Set(featureStates.AutoCrouch)
						end
					end
				end
			)

		player.CharacterAdded:Connect(
			function()
				previousCrouchState = false
				spamDown = true
			end
		)
	end

	local function stopAutoCrouch()
		featureStates.AutoCrouch = false
		if previousCrouchState then
			fireKeybind(false, "Crouch")
			previousCrouchState = false
		end
		if crouchConnection then
