        function pageApi:Slider(title, description, minValue, maxValue, callback)
            local height = description and 74 or 60
            local card = CreateCard(height, false)
            local value = minValue
            local dragging = false
            local step = 1

            New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 14, 0, 8),
                Size = UDim2.new(1, -88, 0, 18),
                Text = tostring(title or ""),
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = Theme.Text,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = card
            })

            if description then
                New("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 14, 0, 28),
                    Size = UDim2.new(1, -88, 0, 14),
                    Text = tostring(description or ""),
                    Font = Enum.Font.Gotham,
                    TextSize = 11,
                    TextColor3 = Theme.TextMuted,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = card
                })
            end

            local valueLabel = New("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -60, 0, 10),
                Size = UDim2.new(0, 44, 0, 16),
                Text = tostring(minValue or 0),
                Font = Enum.Font.GothamBold,
                TextSize = 12,
                TextColor3 = Theme.AccentAlt,
                TextXAlignment = Enum.TextXAlignment.Right,
                Parent = card
            })

            local track = New("Frame", {
                BackgroundColor3 = Theme.BorderSoft,
                Size = UDim2.new(1, -28, 0, 6),
                Position = UDim2.new(0, 14, 1, -18),
                BorderSizePixel = 0,
                Parent = card
            })
            Corner(track, 4)

            local fill = New("Frame", {
                BackgroundColor3 = Theme.Accent,
                Size = UDim2.new(0, 0, 1, 0),
                BorderSizePixel = 0,
                Parent = track
            })
            Corner(fill, 4)
            Gradient(fill, Theme.Accent, Theme.AccentAlt, 0)

            local knob = New("Frame", {
                BackgroundColor3 = Theme.Text,
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(0, -7, 0.5, 0),
                AnchorPoint = Vector2.new(0, 0.5),
                Parent = track
            })
            Corner(knob, 999)

            local hitbox = New("TextButton", {
                BackgroundTransparency = 1,
                Text = "",
                Size = UDim2.new(1, 10, 1, 14),
                Position = UDim2.new(0, -5, 0, -4),
                AutoButtonColor = false,
                Parent = track
            })

            local function Render()
                local alpha
                if maxValue == minValue then
                    alpha = 0
                else
                    alpha = (value - minValue) / (maxValue - minValue)
                end

                alpha = Clamp(alpha, 0, 1)
                fill.Size = UDim2.new(alpha, 0, 1, 0)
                knob.Position = UDim2.new(alpha, -7, 0.5, 0)
                valueLabel.Text = tostring(value)
            end

            local function SetValue(newValue, shouldCallback)
                local rounded = Round(Clamp(tonumber(newValue) or minValue, minValue, maxValue), step)
                value = rounded
                Render()
                if shouldCallback and callback then
                    pcall(callback, value)
                end
            end

            local function SetFromInput(xPosition)
                local alpha = Clamp(
                    (xPosition - track.AbsolutePosition.X) / track.AbsoluteSize.X,
                    0,
                    1
                )
                local raw = minValue + ((maxValue - minValue) * alpha)
                SetValue(raw, true)
            end

            hitbox.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    SetFromInput(input.Position.X)
                end
            end)

            hitbox.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                    or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if not dragging then
                    return
                end

                if input.UserInputType ~= Enum.UserInputType.MouseMovement
                    and input.UserInputType ~= Enum.UserInputType.Touch then
                    return
                end

                SetFromInput(input.Position.X)
            end)

            SetValue(minValue, false)

            RegisterWidget(tabName, "Slider", title, function()
                return value
            end, function(savedValue)
                SetValue(savedValue, true)
            end)

            return {
                SetValue = function(_, newValue)
                    SetValue(newValue, true)
                end,
                GetValue = function()
                    return value
                end
            }
        end

