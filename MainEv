            tostring(kind or "Widget"),
            tostring(title or kind or "Item")
        }, "::")

        local count = (windowState.keyCounts[keyBase] or 0) + 1
        windowState.keyCounts[keyBase] = count

        local key = keyBase
        if count > 1 then
            key = keyBase .. "::" .. tostring(count)
