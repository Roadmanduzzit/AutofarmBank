					local add = math.max(0.1, 2.5 * (0.04 / 1))
					speed = math.min(getgenv().EasyTrimp.BaseSpeed + getgenv().EasyTrimp.ExtraSpeed, speed + add)
				end
			else
				airTick = 0
				airSum = 0
				speed = math.max(getgenv().EasyTrimp.BaseSpeed - getgenv().EasyTrimp.FloorDrop, speed - (2.5 * dt))
			end

