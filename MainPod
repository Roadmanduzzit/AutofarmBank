RunService.RenderStepped:Connect(function()
    if not State.AutoMinigame then return end
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    local minigameUI = playerGui:FindFirstChild("HitTheZoneCircleUI")
    if minigameUI and minigameUI:FindFirstChild("Holder") and minigameUI.Holder.Visible then
        local main = minigameUI.Holder:FindFirstChild("Main")
        if main and main:FindFirstChild("Target") and main:FindFirstChild("Arrow") then
            local arrowRot = main.Arrow.Rotation % 360
            local targetRot = main.Target.Rotation % 360
            local diff = math.abs(arrowRot - targetRot)
            
            if diff <= 25 or (360 - diff) <= 25 then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                task.wait(0.1)
            end
        end
    end
end)

local lastHarvest = 0
RunService.Heartbeat:Connect(function()
    if not State.AutoHarvest then return end
    local now = os.clock()
    if now - lastHarvest >= State.AutoHarvestInterval then
        lastHarvest = now
        local fishFolder = Workspace:FindFirstChild("Fish")
        if fishFolder then
            for _, obj in ipairs(fishFolder:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.ActionText == "Collect" and obj.Enabled then
                    fireproximityprompt(obj, 1)
                end
            end
        end
    end
end)

local lastSell = 0
RunService.Heartbeat:Connect(function()
    if not State.AutoSell then return end
    local now = os.clock()
    if now - lastSell >= State.SellInterval then
        lastSell = now
        local remote = GetRemote()
        if remote then
            pcall(function() remote:FireServer(unpack({ Config.OpCodes.OpenSell })) end)
            task.delay(0.5, function()
                pcall(function() remote:FireServer(unpack({ Config.OpCodes.SellAll })) end)
            end)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not State.AutoBuy then return end
    local remote = GetRemote()
    if not remote then return end
    
    for _ = 1, State.BuySpeed do
        for fishName, isSelected in pairs(State.BuyFishes) do
            if isSelected then
                local payload = { { { "Fish", fishName }, Config.OpCodes.BuyOp } }
                pcall(function() remote:FireServer(unpack(payload)) end)
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    if not State.AutoPlace then return end
    local remote = GetRemote()
    if not remote then return end
    
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return end
    local basePos = char.PrimaryPart.Position

    for _ = 1, State.PlaceSpeed do
        for fishName, isSelected in pairs(State.PlaceFishes) do
            if isSelected then
                local offsetX = (math.random() - 0.5) * 8
                local offsetZ = (math.random() - 0.5) * 8
                local pos = Vector3.new(basePos.X + offsetX, basePos.Y, basePos.Z + offsetZ)
                
                local payload = { { { fishName, pos, "Mid" }, Config.OpCodes.PlaceOp } }
                pcall(function() remote:FireServer(unpack(payload)) end)
            end
        end
    end
end)
