-- ==============================================================================
-- 👁️ ESP SYSTEM (Hybrid UI-Scraper & Tag System)
-- ==============================================================================
local FishESP = { Tracked = {}, Connections = {} }

function FishESP:GetMutators(instance, fishUI)
    local mutators = {}
    local found = {}

    -- Method 1: Scrape from the game's actual hidden UI (Most reliable for dynamic updates)
    if fishUI and fishUI:FindFirstChild("Holder") and fishUI.Holder:FindFirstChild("Mutations") then
        for _, child in ipairs(fishUI.Holder.Mutations:GetChildren()) do
            if child:IsA("TextLabel") and child.Visible and child.Name ~= "MutationNameTemplate" and child.Name ~= "PlusTemplate" then
                if not found[child.Name] then
                    table.insert(mutators, child.Name)
                    found[child.Name] = true
                end
            end
        end
    end

    -- Method 2: Fallback to CollectionService tags
    for _, tag in ipairs(CollectionService:GetTags(instance)) do
        if string.find(tag, "Mutator$") then
            local m = string.gsub(tag, "Mutator", "")
            if not found[m] then
                table.insert(mutators, m)
                found[m] = true
            end
        end
    end

    return mutators
end

function FishESP:CreateNode(instance, isEgg)
    if not instance.PrimaryPart then return nil end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "FishESP_Node"
    billboard.Adornee = instance.PrimaryPart
    billboard.Size = UDim2.new(0, 150, 0, 80)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    
    pcall(function() billboard.Parent = CoreGui end)
    if not billboard.Parent then billboard.Parent = LocalPlayer:WaitForChild("PlayerGui") end

    local frame = Instance.new("Frame", billboard)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 0.5
    frame.BackgroundColor3 = Config.ESPColors.Background
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 6)

    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, -10, 1, -10)
    label.Position = UDim2.new(0, 5, 0, 5)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Code
    label.TextSize = 14
    label.TextColor3 = isEgg and Config.ESPColors.Egg or Config.ESPColors.Fish
    label.TextWrapped = true
    label.RichText = true
    label.TextYAlignment = Enum.TextYAlignment.Top

    return billboard, label
end

function FishESP:UpdateNode(data)
    if not data.Instance or not data.Instance.Parent or not data.Instance.PrimaryPart then return end

    local text = ""
    local fishUI = data.Instance.PrimaryPart:FindFirstChild("FishInfoUI")

    if data.IsEgg then
        local progress = "Waiting..."
        -- Scrape live egg percentage
        if fishUI and fishUI:FindFirstChild("Holder") and fishUI.Holder:FindFirstChild("Progress") then
            progress = fishUI.Holder.Progress.Text
        end
        text = "<b>[Egg]</b>\nProgress: " .. progress
    else
        local fishId = data.Instance:GetAttribute("FishId") or "Unknown"
        local weight = data.Instance:GetAttribute("Weight") or 0
        
        -- Override generic ID with exact display name from UI
        if fishUI and fishUI:FindFirstChild("Holder") and fishUI.Holder:FindFirstChild("FishName") then
            fishId = fishUI.Holder.FishName.Text
        end
        
        text = string.format("<b>%s</b>\nWeight: %.2f kg", tostring(fishId), typeof(weight) == "number" and weight or 0)
    end

    local mutators = self:GetMutators(data.Instance, fishUI)
    if #mutators > 0 then
        local hex = string.format("#%02X%02X%02X", Config.ESPColors.Mutation.R*255, Config.ESPColors.Mutation.G*255, Config.ESPColors.Mutation.B*255)
        text = text .. string.format("\n<font color=\"%s\">[%s]</font>", hex, table.concat(mutators, " | "))
    end
    
    data.Label.Text = text
end

function FishESP:Add(instance, isEgg)
    if self.Tracked[instance] then return end
    
    task.spawn(function()
        if not instance.PrimaryPart then
            instance:GetPropertyChangedSignal("PrimaryPart"):Wait()
        end
        
        if not instance or not instance.Parent then return end

        local billboard, label = self:CreateNode(instance, isEgg)
        if billboard then
            self.Tracked[instance] = {
                Instance = instance,
                Billboard = billboard,
                Label = label,
                IsEgg = isEgg
            }
            self:UpdateNode(self.Tracked[instance])
        end
    end)
end

function FishESP:Remove(instance)
    local data = self.Tracked[instance]
    if data then
        if data.Billboard then data.Billboard:Destroy() end
        self.Tracked[instance] = nil
    end
end

function FishESP:Init()
    for _, inst in ipairs(CollectionService:GetTagged("SpawnedEgg")) do self:Add(inst, true) end
    for _, inst in ipairs(CollectionService:GetTagged("Fish")) do self:Add(inst, false) end

    table.insert(self.Connections, CollectionService:GetInstanceAddedSignal("SpawnedEgg"):Connect(function(i) self:Add(i, true) end))
    table.insert(self.Connections, CollectionService:GetInstanceAddedSignal("Fish"):Connect(function(i) self:Add(i, false) end))
    
    table.insert(self.Connections, CollectionService:GetInstanceRemovedSignal("SpawnedEgg"):Connect(function(i) self:Remove(i) end))
    table.insert(self.Connections, CollectionService:GetInstanceRemovedSignal("Fish"):Connect(function(i) self:Remove(i) end))

    local updateCounter = 0
    table.insert(self.Connections, RunService.RenderStepped:Connect(function()
        local camPos = Camera.CFrame.Position
        updateCounter = updateCounter + 1
        local shouldUpdateData = (updateCounter % 30 == 0) -- Force data refresh every ~0.5 seconds

        for inst, data in pairs(self.Tracked) do
            if inst and inst.PrimaryPart then
                local isValidParent = inst.Parent == Workspace:FindFirstChild("Fish") or inst.Parent == ReplicatedStorage:FindFirstChild("TempFishFolder")
                
                if State.ESP and isValidParent then
                    local dist = (inst.PrimaryPart.Position - camPos).Magnitude
                    data.Billboard.Enabled = dist <= 200
                    
                    if shouldUpdateData then 
                        self:UpdateNode(data) 
                    end
                else
                    data.Billboard.Enabled = false
                end
            else
                self:Remove(inst)
            end
        end
    end))
end

FishESP:Init()

