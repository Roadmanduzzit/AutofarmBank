    local function loadLibraryFromUrl(url)
        local body = nil
        local okHttp, httpBody = pcall(function()
            return game:HttpGet(url)
        end)
        if okHttp and type(httpBody) == "string" and #httpBody > 0 then
            body = httpBody
        end

        if not body then
            local req = (syn and syn.request) or (http and http.request) or request
            if req then
                local okReq, resp = pcall(function()
                    return req({ Url = url, Method = "GET" })
                end)
                if okReq and resp and type(resp.Body) == "string" and #resp.Body > 0 then
                    body = resp.Body
                end
            end
        end

        if not body then
            return false, "no body"
        end

        local okLoad, result = pcall(function()
            return loadstring(body)()
        end)
        if okLoad and type(result) == "function" then
            return true, result
        end
        if okLoad and type(result) == "table" and (type(result.Load) == "function" or type(result.newWindow) == "function" or type(result.Window) == "function") then
            return true, result
        end
        return false, result
    end

