                Visible = false,
                Filled = true,
                Thickness = 1,
                Color = Color3.new(0, 0, 0),
                Transparency = 1
            }),
            HealthBar = makeDrawing("Square", {
                Visible = false,
                Filled = true,
                Thickness = 1,
                Color = Color3.fromRGB(0, 255, 0),
                Transparency = 1
            }),
            Name = makeDrawing("Text", {
                Visible = false,
                Center = true,
                Outline = true,
                Font = 2,
                Size = 13,
                Color = Color3.new(1, 1, 1),
                Transparency = 1,
                Text = ""
            }),
            Info = makeDrawing("Text", {
                Visible = false,
                Center = true,
                Outline = true,
                Font = 2,
                Size = 13,
                Color = Color3.new(1, 1, 1),
                Transparency = 1,
                Text = ""
            }),
            TracerOutline = makeDrawing("Line", {
                Visible = false,
                Thickness = 3,
                Color = Color3.new(0, 0, 0),
                Transparency = 1,
                From = Vector2.new(0, 0),
                To = Vector2.new(0, 0)
            }),
            Tracer = makeDrawing("Line", {
                Visible = false,
                Thickness = 1.5,
                Color = Color3.new(1, 1, 1),
                Transparency = 1,
                From = Vector2.new(0, 0),
                To = Vector2.new(0, 0)
            })
        }

        DrawingESPEntries[player] = entry
        return entry
    end

    local function getTracerOrigin(viewportSize, originMode)
        local width = viewportSize.X / 2
        local mode = tostring(originMode or "Bottom")

        if mode == "Top" then
            return Vector2.new(width, 0)
        end
        if mode == "Center" then
            return Vector2.new(width, viewportSize.Y / 2)
        end

        return Vector2.new(width, viewportSize.Y)
    end

    local function updateDrawingESP()
        if not hasDrawingApi then
            return
        end

        local settings = Config.DrawingESP
        if type(settings) ~= "table" then
            return
        end

        if not settings.Enabled then
            for _, entry in pairs(DrawingESPEntries) do
                hideEntry(entry)
            end
            return
        end

        local currentCamera = Workspace.CurrentCamera or Camera
        if not currentCamera then
            return
        end

        local tracerFrom = getTracerOrigin(currentCamera.ViewportSize, settings.TracerOrigin)
        local alivePlayers = {}

        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                alivePlayers[player] = true
                local entry = getEntry(player)
                if not entry then
                    continue
                end

                local character = player.Character
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")

                if not character or not humanoid or humanoid.Health <= 0 or not rootPart then
                    hideEntry(entry)
                    continue
                end

                if settings.TeamCheck and LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team then
                    hideEntry(entry)
                    continue
                end

                local rootScreenPos, onScreen = currentCamera:WorldToViewportPoint(rootPart.Position)
                if not onScreen or rootScreenPos.Z <= 0 then
                    hideEntry(entry)
                    continue
                end

                local distance = (currentCamera.CFrame.Position - rootPart.Position).Magnitude
                if distance > settings.MaxDistance then
                    hideEntry(entry)
                    continue
                end

                local head = character:FindFirstChild("Head")
                local topWorld = (head and head.Position or (rootPart.Position + Vector3.new(0, 2.5, 0))) + Vector3.new(0, 0.6, 0)
                local bottomWorld = rootPart.Position - Vector3.new(0, 3, 0)

                local topScreenPos = currentCamera:WorldToViewportPoint(topWorld)
                local bottomScreenPos = currentCamera:WorldToViewportPoint(bottomWorld)

                local height = math.clamp(math.abs(topScreenPos.Y - bottomScreenPos.Y), 18, 2000)
                local width = math.max(10, height * 0.55)
                local x = rootScreenPos.X - (width / 2)
                local y = rootScreenPos.Y - (height / 2)

                local thickness = math.clamp(tonumber(settings.Thickness) or 2, 1, 6)
                local textSize = math.clamp(math.floor(tonumber(settings.TextSize) or 13), 10, 22)
                local baseColor = settings.Color
                if settings.UseTeamColor and player.TeamColor then
                    baseColor = player.TeamColor.Color
                end
                if typeof(baseColor) ~= "Color3" then
                    baseColor = Color3.fromRGB(255, 255, 255)
                end

                local showBox = settings.ShowBox == true
                if entry.Box and entry.BoxOutline then
                    entry.BoxOutline.Visible = showBox
                    entry.BoxOutline.Color = Color3.new(0, 0, 0)
                    entry.BoxOutline.Thickness = thickness + 2
                    entry.BoxOutline.Position = Vector2.new(x, y)
                    entry.BoxOutline.Size = Vector2.new(width, height)

                    entry.Box.Visible = showBox
                    entry.Box.Color = baseColor
                    entry.Box.Thickness = thickness
                    entry.Box.Position = Vector2.new(x, y)
                    entry.Box.Size = Vector2.new(width, height)
                end

                local showHealthbar = settings.ShowHealthbar == true
                if entry.HealthOutline and entry.HealthBar then
                    local hp = math.clamp(humanoid.Health / math.max(1, humanoid.MaxHealth), 0, 1)
                    local barHeight = math.max(1, height * hp)
                    local hpColor = Color3.fromRGB(255 - math.floor(255 * hp), math.floor(255 * hp), 0)

                    entry.HealthOutline.Visible = showHealthbar
                    entry.HealthOutline.Position = Vector2.new(x - 6, y - 1)
                    entry.HealthOutline.Size = Vector2.new(4, height + 2)
                    entry.HealthOutline.Color = Color3.new(0, 0, 0)

                    entry.HealthBar.Visible = showHealthbar
                    entry.HealthBar.Position = Vector2.new(x - 5, y + (height - barHeight))
                    entry.HealthBar.Size = Vector2.new(2, barHeight)
                    entry.HealthBar.Color = hpColor
                end

                local showNameTag = settings.ShowNameTag == true
                if entry.Name then
                    entry.Name.Visible = showNameTag
                    entry.Name.Text = player.Name
                    entry.Name.Position = Vector2.new(rootScreenPos.X, y - 14)
                    entry.Name.Size = textSize
                    entry.Name.Color = baseColor
                end

                local infoParts = {}
                if settings.ShowDistance then
                    infoParts[#infoParts + 1] = string.format("%dst", math.floor(distance + 0.5))
                end
                if settings.ShowHeldItem then
                    local heldTool = character:FindFirstChildOfClass("Tool")
                    infoParts[#infoParts + 1] = heldTool and heldTool.Name or "None"
                end

                local infoText = table.concat(infoParts, " | ")
                if entry.Info then
                    local showInfo = infoText ~= ""
                    entry.Info.Visible = showInfo
                    if showInfo then
                        entry.Info.Text = infoText
                        entry.Info.Position = Vector2.new(rootScreenPos.X, y + height + 4)
                        entry.Info.Size = textSize
                        entry.Info.Color = baseColor
                    end
                end

                local showTracers = settings.ShowTracers == true
                if entry.Tracer and entry.TracerOutline then
                    local tracerTo = Vector2.new(rootScreenPos.X, y + height)

                    entry.TracerOutline.Visible = showTracers
                    entry.TracerOutline.Color = Color3.new(0, 0, 0)
                    entry.TracerOutline.Thickness = thickness + 2
                    entry.TracerOutline.From = tracerFrom
                    entry.TracerOutline.To = tracerTo

                    entry.Tracer.Visible = showTracers
                    entry.Tracer.Color = baseColor
                    entry.Tracer.Thickness = thickness
                    entry.Tracer.From = tracerFrom
                    entry.Tracer.To = tracerTo
                end
            end
        end

        for player, _ in pairs(DrawingESPEntries) do
            if (not alivePlayers[player]) or (not player.Parent) then
                removeEntry(player)
            end
        end
    end

    local function startDrawingESP()
        if DrawingESPBound then
            return
        end
        DrawingESPBound = true

        if not hasDrawingApi then
            warn("[DrawingESP] Drawing API is unavailable in this executor.")
            return
        end

        RunService:BindToRenderStep("Focus_DrawingESP", 201, updateDrawingESP)

        if not DrawingESPRemoveConnection then
            DrawingESPRemoveConnection = Players.PlayerRemoving:Connect(function(player)
                removeEntry(player)
            end)
        end
    end

    startDrawingESP()
end

