            else
                hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0)
            end
            
            local rotVelocity = hrp.RotVelocity
            if rotVelocity.X ~= 0 or rotVelocity.Y ~= 0 or rotVelocity.Z ~= 0 then
