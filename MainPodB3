        local function DupeCurrentItem()
            if Cooldown then return false end
            Cooldown = true

            if statusLabel then
                statusLabel.Text = "Executing..."
                statusLabel.TextColor3 = Color3.fromRGB(255,255,0)
            end

            pcall(function()
