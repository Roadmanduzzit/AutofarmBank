    local hasDrawingApi = (type(Drawing) == "table") and (type(Drawing.new) == "function")
    local DrawingESPEntries = {}
    local DrawingESPBound = false
    local DrawingESPRemoveConnection = nil

    local function makeDrawing(className, properties)
        local ok, obj = pcall(function()
            return Drawing.new(className)
        end)
        if not ok or not obj then
            return nil
        end

        for property, value in pairs(properties) do
            obj[property] = value
        end

        return obj
    end

    local function hideEntry(entry)
        if not entry then
            return
        end

        for _, obj in pairs(entry) do
            if obj then
                obj.Visible = false
            end
        end
    end

    local function removeEntry(player)
        local entry = DrawingESPEntries[player]
        if not entry then
            return
        end

        for _, obj in pairs(entry) do
            if obj then
                obj.Visible = false
                if obj.Remove then
                    obj:Remove()
                end
            end
        end

        DrawingESPEntries[player] = nil
    end

